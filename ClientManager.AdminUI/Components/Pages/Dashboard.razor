@page "/"
@using ClientManager.Shared.Models.Responses
@inject StatisticsApiService StatsService
@inject ClientApiService ClientService
@inject ServiceApiService ServiceService
@inject ResourcePoolApiService PoolService
@inject GlobalRateLimitApiService RateLimitApi
@inject EntityColorService Colors
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="cm-page-header">
    <h1>Welcome</h1>
    <p>Your system's performance at a glance.</p>
</div>

@if (_loading)
{
    <StatCardsSkeleton Count="5" />
    <div class="cm-dashboard__charts" style="margin-top: var(--space-xl);">
        <ChartSkeleton />
        <ChartSkeleton />
    </div>
    <TableSkeleton RowCount="6" />
}
else if (_error is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Light">@_error</RadzenAlert>
}
else
{
    <div class="cm-dashboard__stats">
        <div class="cm-stat-card cm-stat-card--primary cm-stat-card--clickable" @onclick='() => Nav.NavigateTo("/clients")'>
            <div class="cm-stat-card__arrow">
                <RadzenIcon Icon="north_east" />
            </div>
            <div class="cm-stat-card__value">@_overview?.TotalClients</div>
            <div class="cm-stat-card__label">Clients</div>
        </div>
        <div class="cm-stat-card cm-stat-card--clickable" @onclick='() => Nav.NavigateTo("/services")'>
            <div class="cm-stat-card__arrow">
                <RadzenIcon Icon="north_east" />
            </div>
            <div class="cm-stat-card__value">@_overview?.TotalServices</div>
            <div class="cm-stat-card__label">Services</div>
        </div>
        <div class="cm-stat-card cm-stat-card--clickable" @onclick='() => Nav.NavigateTo("/resource-pools")'>
            <div class="cm-stat-card__arrow">
                <RadzenIcon Icon="north_east" />
            </div>
            <div class="cm-stat-card__value">@_overview?.TotalResourcePools</div>
            <div class="cm-stat-card__label">Resource Pools</div>
        </div>
        <div class="cm-stat-card cm-stat-card--clickable" @onclick='() => Nav.NavigateTo("/monitor")'>
            <div class="cm-stat-card__arrow">
                <RadzenIcon Icon="north_east" />
            </div>
            <div class="cm-stat-card__value">@_globalUsage</div>
            <div class="cm-stat-card__label">Requests / min</div>
        </div>
        <div class="cm-stat-card cm-stat-card--clickable" @onclick='() => Nav.NavigateTo("/allocations")'>
            <div class="cm-stat-card__arrow">
                <RadzenIcon Icon="north_east" />
            </div>
            <div class="cm-stat-card__value">@(_acquisitionPct)%</div>
            <div class="cm-stat-card__label">Pool Acquisition</div>
        </div>
    </div>

    <div class="cm-dashboard__charts">
        <div class="cm-dashboard__chart-card">
            <div class="cm-dashboard__chart-header">
                <div class="cm-dashboard__filters">
                    <RadzenDropDown @bind-Value="_selectedFilterType"
                        Data="@_filterTypes" TextProperty="Label" ValueProperty="Value"
                        Placeholder="Filter by..." Change="@OnFilterChanged" Style="width:160px;" />
                    <RadzenDropDown @bind-Value="_selectedTargetId"
                        Data="@_filterTargets" TextProperty="Name" ValueProperty="Id"
                        Placeholder="Select target..." Change="@OnFilterChanged" Style="width:180px;" />
                    <RadzenDropDown @bind-Value="_selectedClientIds" Multiple="true"
                        Data="@_clients" TextProperty="Name" ValueProperty="Id"
                        Placeholder="All clients" Style="width:200px;"
                        Change="@OnFilterChanged" />
                </div>
                <ChartSettingsDropdown OnTimeRangeChanged="OnTimeRangeChanged"
                                       OnPollingIntervalChanged="OnPollingIntervalChanged"
                                       OnAxisScaleChanged="OnAxisScaleChanged" />
            </div>
            <span class="cm-dashboard__chart-title">Usage Over Time</span>
            <RadzenChart Style="height: 400px;">
                @foreach (var targetChart in _targetCharts)
                {
                    @foreach (var clientArea in GetChartSeries(targetChart))
                    {
                        <RadzenStackedAreaSeries Data="@clientArea.Points"
                            CategoryProperty="Label" ValueProperty="Value"
                            Title="@clientArea.ClientName"
                            Fill="@Colors.GetColor(clientArea.ClientId)"
                            Stroke="@Colors.GetColor(clientArea.ClientId)">
                            <TooltipTemplate Context="point">
                                <span>@clientArea.ClientName: @(point.OriginalValue.ToString("N0"))</span>
                            </TooltipTemplate>
                        </RadzenStackedAreaSeries>
                    }
                    <RadzenLineSeries Data="@TransformPoints(targetChart.CapSeries)"
                        CategoryProperty="Label" ValueProperty="Value"
                        Title="Cap" LineType="LineType.Dashed"
                        Stroke="var(--color-text-secondary)">
                        <TooltipTemplate Context="point">
                            <span>Cap: @(point.OriginalValue.ToString("N0"))</span>
                        </TooltipTemplate>
                    </RadzenLineSeries>
                }
                <RadzenCategoryAxis />
                <RadzenValueAxis Formatter="@(_axisScaleType == AxisScaleType.Logarithmic ? LogarithmicScaleHelper.FormatAxisLabel : LogarithmicScaleHelper.FormatLinearAxisLabel)" />
                <RadzenLegend Position="LegendPosition.Right" />
            </RadzenChart>
        </div>

        <div class="cm-dashboard__chart-card">
            <div class="cm-dashboard__chart-header">
                <span class="cm-dashboard__chart-title">Usage Per Client</span>
            </div>
            @if (_perClientUsage.Count > 0)
            {
                <RadzenChart Style="height: 300px;">
                    <RadzenDonutSeries Data="@_perClientUsage" CategoryProperty="ClientName"
                        ValueProperty="Value"
                        Fills="@_perClientUsage.Select(p => Colors.GetColor(p.ClientId)).ToArray()" />
                    <RadzenLegend Position="LegendPosition.Right" />
                </RadzenChart>
            }
            else
            {
                <div style="height: 300px; display: flex; align-items: center; justify-content: center; color: var(--color-text-muted);">
                    No usage data available
                </div>
            }
        </div>
    </div>

    <div class="cm-dashboard__table-card">
        <div class="cm-dashboard__chart-header">
            <span class="cm-dashboard__chart-title">Client Overview</span>
            <RadzenTextBox Placeholder="Search clients..." @bind-Value="_tableSearch"
                Change="@OnTableSearchChanged"
                @oninput="@(args => { _tableSearch = args.Value?.ToString(); OnTableSearchChanged(); })"
                Style="width: 250px;" />
        </div>

        <RadzenDataGrid Data="@_filteredClientSummaries" TItem="ClientSummaryTableRow"
            AllowSorting="true" AllowPaging="true" PageSize="10"
            PagerHorizontalAlign="HorizontalAlign.Center">
            <Columns>
                <RadzenDataGridColumn TItem="ClientSummaryTableRow" Property="ClientId" Title="Client ID" Width="150px" />
                <RadzenDataGridColumn TItem="ClientSummaryTableRow" Property="DisplayName" Title="Who Am I?" Width="150px" />
                <RadzenDataGridColumn TItem="ClientSummaryTableRow" Property="AccessibleServices" Title="Services" Width="100px" />
                <RadzenDataGridColumn TItem="ClientSummaryTableRow" Property="TotalRateLimitCap" Title="Rate Limit Cap" Width="140px" />
                <RadzenDataGridColumn TItem="ClientSummaryTableRow" Property="AccessiblePools" Title="Pools" Width="100px" />
                <RadzenDataGridColumn TItem="ClientSummaryTableRow" Property="SlotsDisplay" Title="Slots (Used/Total)" Width="160px" />
            </Columns>
        </RadzenDataGrid>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private SystemOverviewResponse? _overview;

    private string _globalUsage = "-";
    private int _acquisitionPct;

    private string _selectedFilterType = "Service";
    private string? _selectedTargetId;
    private IEnumerable<string>? _selectedClientIds;
    private string? _tableSearch;

    // Polling state
    private Timer? _timer;
    private TimeSpan _pollingInterval = TimeSpan.FromSeconds(10);
    private bool _isVisible = true;
    private IJSObjectReference? _visibilityModule;
    private DotNetObjectReference<Dashboard>? _dotNetRef;

    private List<FilterOption> _filterTypes = new()
    {
        new("Service", "Service"),
        new("Resource Pool", "ResourcePool")
    };
    private List<NamedItem> _filterTargets = new();
    private List<NamedItem> _allServices = new();
    private List<NamedItem> _allPools = new();
    private List<NamedItem> _clients = new();

    private List<TargetChartData> _targetCharts = new();
    private List<ClientUsagePoint> _perClientUsage = new();
    private int _chartLoadVersion;

    private TimeRangePreset _timeRange = TimeRangePreset.Default;
    private AxisScaleType _axisScaleType = AxisScaleType.Linear;

    private const string AllTargetsId = "__all__";

    private List<ClientSummaryTableRow> _clientSummaries = new();
    private List<ClientSummaryTableRow> _filteredClientSummaries = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _overview = await StatsService.GetOverviewAsync();
            StartTimer();

            var services = await ServiceService.GetAllAsync();
            var pools = await PoolService.GetAllAsync();
            var clients = await ClientService.GetAllAsync();

            _clients = clients.Select(c => new NamedItem(c.Id, c.Name)).ToList();
            _allServices = new List<NamedItem> { new(AllTargetsId, "All Services") }
                .Concat(services.Select(s => new NamedItem(s.Id, s.Name))).ToList();
            _allPools = new List<NamedItem> { new(AllTargetsId, "All Resource Pools") }
                .Concat(pools.Select(p => new NamedItem(p.Id, p.Name))).ToList();
            _filterTargets = _allServices;

            // Load global usage stats
            var globalUsage = await StatsService.GetGlobalUsageStatsAsync();
            if (globalUsage is not null)
            {
                _globalUsage = globalUsage.RequestsPerMinute > 0
                    ? globalUsage.RequestsPerMinute.ToString("N0")
                    : "-";
                _acquisitionPct = (int)Math.Round(globalUsage.AcquisitionPercentage);
            }

            // Load client summaries from dedicated endpoint
            var summaries = await StatsService.GetClientSummariesAsync();
            _clientSummaries = summaries.Select(r => new ClientSummaryTableRow(
                r.ClientId, r.DisplayName, r.AccessibleServices,
                r.TotalRateLimitCap, r.AccessiblePools,
                $"{r.UsedSlots}/{r.TotalAccessibleSlots}"
            )).ToList();
            _filteredClientSummaries = _clientSummaries;

            // Select first target; chart load is triggered by TimeRangeSelector
            if (_filterTargets.Count > 0)
            {
                _selectedTargetId = _filterTargets[0].Id;
            }
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnTimeRangeChanged(TimeRangePreset preset)
    {
        _timeRange = preset;
        await LoadChartDataAsync();
    }

    private async Task OnFilterChanged(object? _)
    {
        // Update targets list when filter type changes
        if (_selectedFilterType == "Service")
        {
            _filterTargets = _allServices;
        }
        else
        {
            _filterTargets = _allPools;
        }

        if (_filterTargets.Count > 0 && (_selectedTargetId is null || !_filterTargets.Any(t => t.Id == _selectedTargetId)))
        {
            _selectedTargetId = _filterTargets[0].Id;
        }

        await LoadChartDataAsync();
    }

    private async Task LoadChartDataAsync()
    {
        if (_selectedTargetId is null) return;

        var loadVersion = System.Threading.Interlocked.Increment(ref _chartLoadVersion);

        try
        {
            var newCharts = new List<TargetChartData>();
            List<ClientUsagePoint> newDonut;

            if (_selectedTargetId == AllTargetsId)
            {
                await LoadAllTargetsChartDataAsync(newCharts);

                // For "All" mode, derive per-client donut from historical API (same path as line chart)
                var donutTo = _timeRange.GetTo();
                var donutFrom = _timeRange.GetFrom(donutTo);
                var isRateBased = _selectedFilterType == "Service";

                var targets = _selectedFilterType == "Service"
                    ? _allServices.Where(t => t.Id != AllTargetsId)
                    : _allPools.Where(t => t.Id != AllTargetsId);
                var targetIds = targets.Select(t => t.Id).ToList();

                var donutClients = _selectedClientIds?.Any() == true
                    ? _clients.Where(c => _selectedClientIds.Contains(c.Id)).ToList()
                    : _clients;

                var donutBreakdowns = await StatsService.GetClientUsageBreakdownAsync(
                    _selectedFilterType,
                    targetIds,
                    _selectedClientIds,
                    donutFrom,
                    donutTo,
                    _timeRange.Granularity);
                var totalsByClientId = donutBreakdowns
                    .SelectMany(breakdown => breakdown.Entries)
                    .GroupBy(entry => entry.ClientId)
                    .ToDictionary(
                        group => group.Key,
                        group => isRateBased
                            ? group.Sum(entry => (double)entry.GrantedCount)
                            : group.Sum(entry => (double)entry.ActiveCount));

                newDonut = new List<ClientUsagePoint>();
                foreach (var client in donutClients)
                {
                    var totalValue = totalsByClientId.GetValueOrDefault(client.Id);
                    if (totalValue > 0)
                    {
                        newDonut.Add(new ClientUsagePoint(client.Id, client.Name, totalValue));
                    }
                }
            }
            else
            {
                newDonut = await LoadSingleTargetChartDataAsync(newCharts);
            }

            if (newDonut.Count > ChartAggregator.DefaultTopN)
            {
                var ranked = newDonut
                    .OrderByDescending(p => p.Value)
                    .ToList();
                var top = ranked.Take(ChartAggregator.DefaultTopN).ToList();
                var othersValue = ranked.Skip(ChartAggregator.DefaultTopN).Sum(p => p.Value);
                top.Add(new ClientUsagePoint(ChartAggregator.OthersId, ChartAggregator.OthersLabel, othersValue));
                newDonut = top;
            }

            if (loadVersion != _chartLoadVersion)
            {
                return;
            }

            _targetCharts = newCharts;
            _perClientUsage = newDonut;
        }
        catch (HttpRequestException)
        {
            if (loadVersion != _chartLoadVersion)
            {
                return;
            }

            // Chart data load failed - leave current data in place
        }
    }

    private async Task<List<ClientUsagePoint>> LoadSingleTargetChartDataAsync(List<TargetChartData> charts)
    {
        var now = _timeRange.GetTo();
        var from = _timeRange.GetFrom(now);
        var isRateBased = _selectedFilterType == "Service";
        var chartAggregationMode = GetChartAggregationMode(isRateBased);

        // Use _clients list directly for client discovery (reliable path)
        var clientsToQuery = _selectedClientIds?.Any() == true
            ? _clients.Where(c => _selectedClientIds.Contains(c.Id)).ToList()
            : _clients;

        // Get cap and window for scaling
        double baseCap = 0;
        TimeSpan? rateWindow = null;

        if (isRateBased)
        {
            var rateLimits = await RateLimitApi.GetByTargetTypeAsync(TargetType.Service);
            var limit = rateLimits.FirstOrDefault(r => r.TargetId == _selectedTargetId);
            if (limit is not null)
            {
                baseCap = limit.MaxRequests;
                rateWindow = limit.Window;
            }
        }
        else
        {
            var pools = await PoolService.GetAllAsync();
            baseCap = pools.FirstOrDefault(p => p.Id == _selectedTargetId)?.MaxSlots ?? 0;
        }

        var historiesByClientId = (await StatsService.GetHistoricalUsageByClientAsync(
                _selectedFilterType,
                new[] { _selectedTargetId! },
                clientsToQuery.Select(client => client.Id),
                from,
                now,
                _timeRange.Granularity))
            .ToDictionary(history => history.ClientId);

        // Aggregate each client's data to 12 buckets (skip clients with no data)
        var clientAggregations = new Dictionary<string, (NamedItem Client, ChartBucketAggregator.AggregationResult Result)>();
        var clientUsageValues = new Dictionary<string, double>();

        // Always generate bucket structure for the time range (cap line needs it even with no data)
        var emptyAggregation = ChartBucketAggregator.Aggregate([], from, now, mode: chartAggregationMode);
        var bucketDuration = emptyAggregation.BucketDuration;

        foreach (var client in clientsToQuery)
        {
            historiesByClientId.TryGetValue(client.Id, out var clientHistory);
            var rawPoints = (clientHistory?.Points ?? [])
                .Select(p => new ChartBucketAggregator.RawPoint(
                    p.Timestamp,
                    GetHistoricalPointValue(p, isRateBased)))
                .ToList();

            if (rawPoints.Count == 0) continue;

            var aggregation = ChartBucketAggregator.Aggregate(rawPoints, from, now, mode: chartAggregationMode);
            clientAggregations[client.Id] = (client, aggregation);
            clientUsageValues[client.Id] = GetClientUsageValue(clientHistory?.Points ?? [], isRateBased);
        }

        // Build common bucket labels (use first client's aggregation, or empty buckets for cap line)
        var referenceBuckets = clientAggregations.Values.FirstOrDefault().Result?.Buckets
            ?? emptyAggregation.Buckets;
        var bucketLabels = referenceBuckets.Select(b => b.Label).ToList();

        // Build client area series
        var clientAreas = new List<ClientAreaSeries>();
        foreach (var (clientId, (client, agg)) in clientAggregations)
        {
            var points = agg.Buckets
                .Select(b => new ChartPoint(b.Label, b.Value))
                .ToList();
            clientAreas.Add(new ClientAreaSeries(clientId, client.Name, points));
        }

        // Scale cap for rate-based limits
        var scaledCap = baseCap;
        if (isRateBased && rateWindow.HasValue && rateWindow.Value > TimeSpan.Zero && bucketDuration > TimeSpan.Zero)
        {
            var scaleFactor = bucketDuration.TotalSeconds / rateWindow.Value.TotalSeconds;
            scaledCap = baseCap * scaleFactor;
        }

        var capPoints = bucketLabels
            .Select(label => new ChartPoint(label, scaledCap))
            .ToList();

        // Derive donut data from per-client aggregated values (no extra API call)
        var donutData = new List<ClientUsagePoint>();
        foreach (var (clientId, (client, agg)) in clientAggregations)
        {
            var totalValue = clientUsageValues.GetValueOrDefault(clientId);
            if (totalValue > 0)
                donutData.Add(new ClientUsagePoint(clientId, client.Name, totalValue));
        }

        // Apply top-N client aggregation (limit to 10 clients + Others)
        var aggregatedAreas = ChartAggregator.Aggregate(
            clientAreas.Select(c => new ChartAggregator.AggregatedSeries(
                c.ClientId, c.ClientName,
                c.Points.Select(p => new ChartAggregator.AggregatedPoint(p.Label, p.Value)).ToList()
            )).ToList());

        clientAreas = aggregatedAreas.Select(a => new ClientAreaSeries(
            a.Id, a.Name,
            a.Points.Select(p => new ChartPoint(p.Label, p.Value)).ToList()
        )).ToList();

        var targetName = _filterTargets.FirstOrDefault(t => t.Id == _selectedTargetId)?.Name ?? "";
        charts.Add(new TargetChartData(targetName, clientAreas, capPoints));

        return donutData;
    }

    private async Task LoadAllTargetsChartDataAsync(List<TargetChartData> charts)
    {
        var now = _timeRange.GetTo();
        var from = _timeRange.GetFrom(now);
        var isRateBased = _selectedFilterType == "Service";
        var chartAggregationMode = GetChartAggregationMode(isRateBased);
        var emptyAggregation = ChartBucketAggregator.Aggregate([], from, now, mode: chartAggregationMode);

        var targets = (_selectedFilterType == "Service"
            ? _allServices : _allPools).Where(t => t.Id != AllTargetsId).ToList();

        var targetIds = targets.Select(t => t.Id).ToList();

        // Collect cap info for scaling
        double totalBaseCap = 0;
        TimeSpan? rateWindow = null;

        if (isRateBased)
        {
            var rateLimits = await RateLimitApi.GetByTargetTypeAsync(
                TargetType.Service);
            foreach (var target in targets)
            {
                var limit = rateLimits.FirstOrDefault(r => r.TargetId == target.Id);
                if (limit is not null)
                {
                    totalBaseCap += limit.MaxRequests;
                    rateWindow ??= limit.Window; // Use first window as reference
                }
            }
        }
        else
        {
            var pools = await PoolService.GetAllAsync();
            foreach (var target in targets)
            {
                var cap = pools.FirstOrDefault(p => p.Id == target.Id)?.MaxSlots ?? 0;
                totalBaseCap += cap;
            }
        }

        // Batch history fetch for all targets
        var histories = await StatsService.GetHistoricalUsageAsync(
            _selectedFilterType, targetIds, null, from, now, _timeRange.Granularity);

        var targetAggregations = histories
            .Select(history => ChartBucketAggregator.Aggregate(
                history.Points.Select(point => new ChartBucketAggregator.RawPoint(
                    point.Timestamp,
                    GetHistoricalPointValue(point, isRateBased))),
                from,
                now,
                mode: chartAggregationMode))
            .ToList();
        var referenceBuckets = targetAggregations.FirstOrDefault()?.Buckets
            ?? emptyAggregation.Buckets;
        var sortedPoints = SumBuckets(targetAggregations, referenceBuckets);

        // Scale cap for rate-based limits
        var scaledCap = totalBaseCap;
        if (isRateBased && rateWindow.HasValue && rateWindow.Value > TimeSpan.Zero)
        {
            var scaleFactor = emptyAggregation.BucketDuration.TotalSeconds / rateWindow.Value.TotalSeconds;
            scaledCap = totalBaseCap * scaleFactor;
        }

        var capPoints = sortedPoints
            .Select(p => new ChartPoint(p.Label, scaledCap))
            .ToList();

        var label = _selectedFilterType == "Service" ? "All Services" : "All Resource Pools";
        charts.Add(new TargetChartData(label,
            new List<ClientAreaSeries> { new("total", "Total", sortedPoints) },
            capPoints));
    }

    private static ChartBucketAggregator.AggregationMode GetChartAggregationMode(bool isRateBased)
        => isRateBased
            ? ChartBucketAggregator.AggregationMode.Sum
            : ChartBucketAggregator.AggregationMode.Latest;

    private static double GetHistoricalPointValue(HistoricalUsagePoint point, bool isRateBased)
        => isRateBased ? point.GrantedCount : point.ActiveCount;

    private static double GetClientUsageValue(IEnumerable<HistoricalUsagePoint> points, bool isRateBased)
    {
        if (isRateBased)
        {
            return points.Sum(point => (double)point.GrantedCount);
        }

        return points
            .OrderByDescending(point => point.Timestamp)
            .Select(point => (double)point.ActiveCount)
            .FirstOrDefault();
    }

    private static List<ChartPoint> SumBuckets(
        IEnumerable<ChartBucketAggregator.AggregationResult> aggregations,
        IReadOnlyList<ChartBucketAggregator.AggregatedBucket> referenceBuckets)
    {
        var aggregationList = aggregations.ToList();
        return referenceBuckets
            .Select((bucket, index) => new ChartPoint(
                bucket.Label,
                aggregationList.Sum(aggregation => aggregation.Buckets[index].Value)))
            .ToList();
    }

    private void OnTableSearchChanged()
    {
        if (string.IsNullOrWhiteSpace(_tableSearch))
        {
            _filteredClientSummaries = _clientSummaries;
        }
        else
        {
            _filteredClientSummaries = _clientSummaries
                .Where(c => c.ClientId.Contains(_tableSearch, StringComparison.OrdinalIgnoreCase)
                    || c.DisplayName.Contains(_tableSearch, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private record FilterOption(string Label, string Value);
    private record NamedItem(string Id, string Name);
    private record ChartPoint(string Label, double Value)
    {
        public double OriginalValue { get; init; } = Value;
    }
    private record ClientAreaSeries(string ClientId, string ClientName, List<ChartPoint> Points);
    private record TargetChartData(string TargetName, List<ClientAreaSeries> ClientSeries, List<ChartPoint> CapSeries);
    private record ClientUsagePoint(string ClientId, string ClientName, double Value);
    private record ClientSummaryTableRow(string ClientId, string DisplayName, int AccessibleServices,
        string TotalRateLimitCap, int AccessiblePools, string SlotsDisplay);

    // --- Polling & Visibility ---

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _visibilityModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/visibility.js");
            _dotNetRef = DotNetObjectReference.Create(this);
            await _visibilityModule.InvokeVoidAsync("register", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnVisibilityChanged(bool visible)
    {
        _isVisible = visible;
        if (visible)
        {
            await RefreshDataAsync();
            await InvokeAsync(StateHasChanged);
            StartTimer();
        }
        else
        {
            _timer?.Dispose();
            _timer = null;
        }
    }

    private void StartTimer()
    {
        _timer?.Dispose();
        _timer = new Timer(_ =>
        {
            if (!_isVisible) return;
            _ = InvokeAsync(async () =>
            {
                await RefreshDataAsync();
                StateHasChanged();
            });
        }, null, _pollingInterval, _pollingInterval);
    }

    private Task OnPollingIntervalChanged(PollingIntervalPreset preset)
    {
        _pollingInterval = preset.Interval;
        StartTimer();
        return Task.CompletedTask;
    }

    private Task OnAxisScaleChanged(AxisScaleType scale)
    {
        _axisScaleType = scale;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private List<ChartPoint> TransformPoints(List<ChartPoint> points) =>
        _axisScaleType == AxisScaleType.Logarithmic
            ? points.Select(p => p with { Value = LogarithmicScaleHelper.Transform(p.Value), OriginalValue = p.Value }).ToList()
            : points;

    private List<ClientAreaSeries> GetChartSeries(TargetChartData chart) =>
        _axisScaleType == AxisScaleType.Logarithmic
            ? TransformStackedLogarithmic(chart.ClientSeries)
            : chart.ClientSeries;

    private static List<ClientAreaSeries> TransformStackedLogarithmic(List<ClientAreaSeries> series)
    {
        if (series.Count == 0) return series;

        var totals = new Dictionary<string, double>();
        foreach (var s in series)
            foreach (var p in s.Points)
                totals[p.Label] = totals.GetValueOrDefault(p.Label) + p.Value;

        return series.Select(s => new ClientAreaSeries(s.ClientId, s.ClientName,
            s.Points.Select(p =>
            {
                var total = totals.GetValueOrDefault(p.Label);
                if (total <= 0) return p with { Value = 0, OriginalValue = p.Value };
                var logTotal = LogarithmicScaleHelper.Transform(total);
                return p with { Value = (p.Value / total) * logTotal, OriginalValue = p.Value };
            }).ToList()
        )).ToList();
    }

    private async Task RefreshDataAsync()
    {
        try
        {
            // Refresh global usage stats
            var globalUsage = await StatsService.GetGlobalUsageStatsAsync();
            if (globalUsage is not null)
            {
                _globalUsage = globalUsage.RequestsPerMinute > 0
                    ? globalUsage.RequestsPerMinute.ToString("N0")
                    : "-";
                _acquisitionPct = (int)Math.Round(globalUsage.AcquisitionPercentage);
            }

            // Refresh charts
            await LoadChartDataAsync();
        }
        catch (HttpRequestException)
        {
            // Leave current data in place on error
        }
    }

    public async ValueTask DisposeAsync()
    {
        _timer?.Dispose();
        if (_visibilityModule is not null)
        {
            await _visibilityModule.InvokeVoidAsync("unregister");
            await _visibilityModule.DisposeAsync();
        }
        _dotNetRef?.Dispose();
    }
}
