@page "/quotas"
@inject GlobalRateLimitApiService RateLimitApi
@inject NavigationManager Nav
@inject DialogService Dialog
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="cm-page-header">
    <h1>Quotas</h1>
    <p>Manage request quotas applied to resource pools.</p>
</div>

@if (_deleteError is not null)
{
    <div class="alert alert-danger">@_deleteError</div>
}

@if (_loading)
{
    <TableSkeleton />
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="cm-list-page__table-card">
        <div class="cm-list-page__header cm-list-page__header--quota">
            <div class="cm-list-page__search-field">
                <RadzenTextBox Placeholder="Search quotas..."
                    Value="@_search"
                    ValueChanged="@((string v) => { _search = v; StateHasChanged(); })"
                    @oninput="@(args => { _search = args.Value?.ToString(); StateHasChanged(); })" />
            </div>
            <div class="cm-list-page__header-actions">
                <RadzenButton Text="Create Quota" Icon="add"
                    class="cm-list-page__create-btn"
                    title="Create quota"
                    Click="@(() => Nav.NavigateTo("/quotas/new"))"
                    ButtonStyle="ButtonStyle.Primary" />
            </div>
        </div>

        <RadzenDataGrid Data="@_filteredLimits" TItem="GlobalRateLimit"
            AllowSorting="true" AllowPaging="true" PageSize="@_pageSize"
            PagerHorizontalAlign="HorizontalAlign.Center">
            <Columns>
                <RadzenDataGridColumn TItem="GlobalRateLimit" Property="Id" Title="ID" Width="130px" />
                <RadzenDataGridColumn TItem="GlobalRateLimit" Property="TargetId" Title="Resource Pool" MinWidth="140px" />
                <RadzenDataGridColumn TItem="GlobalRateLimit" Property="Strategy" Title="Strategy"
                    Width="215px" MinWidth="215px" TextAlign="TextAlign.Center"
                    CssClass="cm-list-page__col-center cm-list-page__col-status">
                    <Template Context="limit">
                        <span class="@RateLimitStrategyBadge.GetCssClass(limit.Strategy)">@limit.Strategy</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GlobalRateLimit" Property="MaxRequests" Title="Max Requests"
                    Width="140px" MinWidth="140px" TextAlign="TextAlign.Center"
                    HeaderCssClass="cm-list-page__col-center cm-list-page__col-header"
                    CssClass="cm-list-page__col-center cm-list-page__col-status" />
                <RadzenDataGridColumn TItem="GlobalRateLimit" Title="Window" Width="88px" MinWidth="88px"
                    TextAlign="TextAlign.Center" HeaderCssClass="cm-list-page__col-center cm-list-page__col-header"
                    CssClass="cm-list-page__col-center cm-list-page__col-status">
                    <Template Context="limit">@FormatWindow(limit.Window)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GlobalRateLimit" Title="Actions" Width="120px" MinWidth="120px"
                    Sortable="false" TextAlign="TextAlign.Center"
                    CssClass="cm-list-page__col-center cm-list-page__col-actions">
                    <Template Context="limit">
                        <div class="cm-list-page__actions-cell">
                            <RadzenButton Icon="edit" Size="ButtonSize.Small" Variant="Variant.Text"
                                title="Edit quota"
                                Click="@(() => Nav.NavigateTo($"/quotas/{limit.Id}"))" />
                            <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Text"
                                ButtonStyle="ButtonStyle.Danger" title="Delete quota"
                                Click="@(async () => await DeleteAsync(limit.Id))" />
                        </div>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private string? _deleteError;
    private string? _search;
    private List<GlobalRateLimit> _limits = [];
    private int _pageSize = 10;
    private IJSObjectReference? _tableJs;
    private DotNetObjectReference<QuotaList>? _selfRef;

    private IEnumerable<GlobalRateLimit> _filteredLimits =>
        string.IsNullOrWhiteSpace(_search)
            ? _limits
            : _limits.Where(l =>
                l.Id.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                l.TargetId.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _tableJs = await JS.InvokeAsync<IJSObjectReference>("import", "./js/table.js");
            _selfRef = DotNetObjectReference.Create(this);
            await _tableJs.InvokeVoidAsync("register", _selfRef);
            await RecalculatePageSizeAsync();
        }
    }

    [JSInvokable]
    public async Task OnWindowResize() => await RecalculatePageSizeAsync();

    private async Task RecalculatePageSizeAsync()
    {
        _pageSize = await _tableJs!.InvokeAsync<int>("getPageSize", 45);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_tableJs is not null)
        {
            await _tableJs.InvokeVoidAsync("unregister");
            await _tableJs.DisposeAsync();
        }
        _selfRef?.Dispose();
    }

    private async Task LoadAsync()
    {
        try
        {
            _limits = await RateLimitApi.GetByTargetTypeAsync(TargetType.ResourcePool);
            _error = null;
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private Task DeleteAsync(string id) =>
        ListDeleteSupport.ExecuteAsync(
            Dialog,
            "quota",
            id,
            () => RateLimitApi.DeleteAsync(id),
            LoadAsync,
            message => _deleteError = message,
            StateHasChanged);

    private static string FormatWindow(TimeSpan window)
    {
        if (window.TotalHours >= 1) return $"{window.TotalHours:0.#}h";
        if (window.TotalMinutes >= 1) return $"{window.TotalMinutes:0.#}m";
        return $"{window.TotalSeconds:0.#}s";
    }
}
