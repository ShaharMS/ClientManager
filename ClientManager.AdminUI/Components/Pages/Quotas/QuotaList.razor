@page "/quotas"
@inject GlobalRateLimitApiService RateLimitApi
@inject ResourcePoolApiService PoolApi
@inject NavigationManager Nav
@inject DialogService Dialog
@inject ApiErrorLocalizer errors
@inject IJSRuntime JS
@inject UrlQuerySync UrlQuery
@implements IAsyncDisposable

<div class="cm-page-header">
    <h1>@L["Pages.Quotas.Title"]</h1>
    <p>@L["Pages.Quotas.Subtitle"]</p>
</div>

@if (_deleteError is not null)
{
    <div class="alert alert-danger">@_deleteError</div>
}

@if (_loading)
{
    <TableSkeleton />
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="cm-list-page__table-card cm-rate-limit-grid">
        <div class="cm-list-page__header cm-list-page__header--quota">
            <div class="cm-list-page__search-field">
                <RadzenTextBox Placeholder="@L["Pages.Quotas.Search"]"
                    Value="@_search"
                    ValueChanged="OnSearchChanged"
                    @oninput="OnSearchInput" />
            </div>
            <div class="cm-list-page__header-actions">
                <span class="cm-list-page__create-btn-wrap @(_canCreateMore ? null : "cm-list-page__create-btn-wrap--disabled")"
                      title="@(_canCreateMore ? L["Pages.Quotas.CreateTooltip"] : _createDisabledTooltip)">
                    <RadzenButton Text="@L["Pages.Quotas.CreateButton"]" Icon="add"
                        class="cm-list-page__create-btn"
                        Click="@(() => Nav.NavigateTo("/quotas/new"))"
                        ButtonStyle="ButtonStyle.Primary" Disabled="@(!_canCreateMore)" />
                </span>
            </div>
        </div>

        <RadzenDataGrid Data="@_filteredLimits" TItem="GlobalRateLimit" EmptyText="@L["DataGrid.NoRecords"]"
            AllowSorting="true" AllowPaging="true" PageSize="@_pageSize"
            Settings="@_gridSettings" SettingsChanged="OnGridSettingsChanged"
            PagerHorizontalAlign="HorizontalAlign.Center">
            <Columns>
                <RadzenDataGridColumn TItem="GlobalRateLimit" Title="@L["Columns.ResourcePool"]"
                    Property="TargetId" CssClass="cm-col-label" HeaderCssClass="cm-col-label">
                    <Template Context="limit">
                        @GetPoolName(limit.TargetId)
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GlobalRateLimit" Property="Strategy" Title="@L["Columns.Strategy"]"
                    CssClass="cm-col-strategy cm-rate-limit-grid__wide-only" HeaderCssClass="cm-col-strategy cm-rate-limit-grid__wide-only">
                    <Template Context="limit">
                        <span class="@RateLimitStrategyBadge.GetCssClass(limit.Strategy)">@RateLimitStrategyLabels.GetLabel(limit.Strategy, L)</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GlobalRateLimit" Property="MaxRequests" Title="@L["Columns.MaxRequests"]"
                    CssClass="cm-col-scalar-wide cm-rate-limit-grid__wide-only" HeaderCssClass="cm-col-scalar-wide cm-rate-limit-grid__wide-only" />
                <RadzenDataGridColumn TItem="GlobalRateLimit" Title="@L["Columns.Window"]"
                    CssClass="cm-col-scalar-narrow cm-rate-limit-grid__wide-only" HeaderCssClass="cm-col-scalar-narrow cm-rate-limit-grid__wide-only">
                    <Template Context="limit">@TimeSpanFormatter.FormatCompact(limit.Window, L)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GlobalRateLimit" Title="@($"{L["Columns.MaxRequests"]} / {L["Columns.Window"]}")"
                    Sortable="false" CssClass="cm-col-scalar-wide cm-rate-limit-grid__narrow-only"
                    HeaderCssClass="cm-col-scalar-wide cm-rate-limit-grid__narrow-only">
                    <Template Context="limit">@TimeSpanFormatter.FormatRequestsWindow(limit.MaxRequests, limit.Window, L)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GlobalRateLimit" Title="@L["Columns.Actions"]" Sortable="false"
                    CssClass="cm-col-actions" HeaderCssClass="cm-col-actions">
                    <Template Context="limit">
                        <div class="cm-list-page__actions-cell">
                            <RadzenButton Icon="edit" Size="ButtonSize.Small" Variant="Variant.Text"
                                title="@L["Pages.Quotas.EditTooltip"]"
                                Click="@(() => Nav.NavigateTo($"/quotas/{limit.Id}"))" />
                            <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Text"
                                ButtonStyle="ButtonStyle.Danger" title="@L["Pages.Quotas.DeleteTooltip"]"
                                Click="@(async () => await DeleteAsync(limit))" />
                        </div>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private string? _deleteError;
    private string? _search;
    private List<GlobalRateLimit> _limits = [];
    private Dictionary<string, string> _poolNames = new(StringComparer.OrdinalIgnoreCase);
    private int _pageSize = 10;
    private int _urlPage = 1;
    private string? _urlSortProperty;
    private SortOrder? _urlSortOrder;
    private DataGridSettings _gridSettings = new() { CurrentPage = 0 };
    private bool _canCreateMore = true;
    private string? _createDisabledTooltip;
    private IJSObjectReference? _tableJs;
    private DotNetObjectReference<QuotaList>? _selfRef;

    private IEnumerable<GlobalRateLimit> _filteredLimits =>
        string.IsNullOrWhiteSpace(_search)
            ? _limits
            : _limits.Where(l =>
                l.TargetId.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                GetPoolName(l.TargetId).Contains(_search, StringComparison.OrdinalIgnoreCase));

    private ListPageUrlSupport.GridQueryState CurrentQueryState =>
        new(
            _search,
            null,
            QueryParamParsers.ReadGridPage(_gridSettings),
            QueryParamParsers.ReadGridSort(_gridSettings).Property,
            QueryParamParsers.ReadGridSort(_gridSettings).Order);

    protected override async Task OnInitializedAsync()
    {
        UrlQuery.SuppressWrite = true;
        var urlState = ListPageUrlSupport.Parse(UrlQuery.Parse(), hasEnabledFilter: false);
        _search = urlState.Search;
        _urlPage = urlState.Page;
        _urlSortProperty = urlState.SortProperty;
        _urlSortOrder = urlState.SortOrder;
        UrlQuery.SuppressWrite = false;

        await LoadAsync();
        ApplyGridSettingsFromUrl();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _tableJs = await JS.InvokeAsync<IJSObjectReference>("import", "./js/table.js");
            _selfRef = DotNetObjectReference.Create(this);
            await _tableJs.InvokeVoidAsync("register", _selfRef);
            await RecalculatePageSizeAsync();
        }
    }

    [JSInvokable]
    public async Task OnWindowResize() => await RecalculatePageSizeAsync();

    private async Task RecalculatePageSizeAsync()
    {
        _pageSize = await _tableJs!.InvokeAsync<int>("getPageSize", 45);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_tableJs is not null)
        {
            await _tableJs.InvokeVoidAsync("unregister");
            await _tableJs.DisposeAsync();
        }
        _selfRef?.Dispose();
        UrlQuery.Dispose();
    }

    private void ApplyGridSettingsFromUrl()
    {
        var page = QueryParamParsers.ClampPage(_urlPage, _filteredLimits.Count(), _pageSize);
        _gridSettings = QueryParamParsers.ApplyGridSettings(_gridSettings, page, _urlSortProperty, _urlSortOrder);
        _gridSettings.PageSize = _pageSize;
    }

    private void SyncUrl() => ListPageUrlSupport.Sync(UrlQuery, CurrentQueryState, hasEnabledFilter: false);

    private void SyncUrlDebounced() =>
        ListPageUrlSupport.SyncDebounced(UrlQuery, CurrentQueryState, hasEnabledFilter: false, InvokeAsync);

    private void OnSearchChanged(string? value)
    {
        _search = value;
        _gridSettings.CurrentPage = 0;
        SyncUrlDebounced();
        StateHasChanged();
    }

    private void OnSearchInput(ChangeEventArgs args)
    {
        _search = args.Value?.ToString();
        _gridSettings.CurrentPage = 0;
        SyncUrlDebounced();
        StateHasChanged();
    }

    private void OnGridSettingsChanged(DataGridSettings settings)
    {
        _gridSettings = settings;
        SyncUrl();
    }

    private async Task LoadAsync()
    {
        try
        {
            _limits = await RateLimitApi.GetByTargetTypeAsync(TargetType.ResourcePool);
            var pools = await PoolApi.GetAllAsync();
            _poolNames = pools.ToDictionary(p => p.Id, p => p.Name, StringComparer.OrdinalIgnoreCase);

            await RefreshCreateAvailabilityAsync(pools);
            _error = null;
        }
        catch (HttpRequestException ex)
        {
            _error = errors.Format("Api.UnableToConnect", ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshCreateAvailabilityAsync(IReadOnlyList<ResourcePool>? pools = null)
    {
        pools ??= await PoolApi.GetAllAsync();
        var limitedTargets = _limits
            .Select(l => l.TargetId)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        _canCreateMore = pools.Any(p => !limitedTargets.Contains(p.Id));
        _createDisabledTooltip = _canCreateMore ? null : L["Pages.Quotas.CreateDisabledTooltip"];
    }

    private string GetPoolName(string poolId) =>
        _poolNames.GetValueOrDefault(poolId, poolId);

    private Task DeleteAsync(GlobalRateLimit limit) =>
        ListDeleteSupport.ExecuteAsync(
            Dialog,
            L,
            errors,
            L["Dialog.EntityLabel.QuotaForResourcePool"],
            GetPoolName(limit.TargetId),
            () => RateLimitApi.DeleteAsync(limit.Id),
            LoadAsync,
            message => _deleteError = message,
            StateHasChanged);

}
