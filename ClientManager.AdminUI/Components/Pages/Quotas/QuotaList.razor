@page "/quotas"
@inject GlobalRateLimitApiService RateLimitApi
@inject ResourcePoolApiService PoolApi
@inject NavigationManager Nav
@inject DialogService Dialog
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="cm-page-header">
    <h1>Quotas</h1>
    <p>Manage request quotas applied to resource pools.</p>
</div>

@if (_deleteError is not null)
{
    <div class="alert alert-danger">@_deleteError</div>
}

@if (_loading)
{
    <TableSkeleton />
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="cm-list-page__table-card">
        <div class="cm-list-page__header cm-list-page__header--quota">
            <div class="cm-list-page__search-field">
                <RadzenTextBox Placeholder="Search quotas..."
                    Value="@_search"
                    ValueChanged="@((string v) => { _search = v; StateHasChanged(); })"
                    @oninput="@(args => { _search = args.Value?.ToString(); StateHasChanged(); })" />
            </div>
            <div class="cm-list-page__header-actions">
                <span class="cm-list-page__create-btn-wrap @(_canCreateMore ? null : "cm-list-page__create-btn-wrap--disabled")"
                      title="@(_canCreateMore ? "Create quota" : _createDisabledTooltip)">
                    <RadzenButton Text="Create Quota" Icon="add"
                        class="cm-list-page__create-btn"
                        Click="@(() => Nav.NavigateTo("/quotas/new"))"
                        ButtonStyle="ButtonStyle.Primary" Disabled="@(!_canCreateMore)" />
                </span>
            </div>
        </div>

        <RadzenDataGrid Data="@_filteredLimits" TItem="GlobalRateLimit"
            AllowSorting="true" AllowPaging="true" PageSize="@_pageSize"
            PagerHorizontalAlign="HorizontalAlign.Center">
            <Columns>
                <RadzenDataGridColumn TItem="GlobalRateLimit" Title="Resource Pool"
                    Property="TargetId" CssClass="cm-col-label" HeaderCssClass="cm-col-label">
                    <Template Context="limit">
                        @GetPoolName(limit.TargetId)
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GlobalRateLimit" Property="Strategy" Title="Strategy"
                    CssClass="cm-col-strategy" HeaderCssClass="cm-col-strategy">
                    <Template Context="limit">
                        <span class="@RateLimitStrategyBadge.GetCssClass(limit.Strategy)">@limit.Strategy</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GlobalRateLimit" Property="MaxRequests" Title="Max Requests"
                    CssClass="cm-col-scalar-wide" HeaderCssClass="cm-col-scalar-wide" />
                <RadzenDataGridColumn TItem="GlobalRateLimit" Title="Window"
                    CssClass="cm-col-scalar-narrow" HeaderCssClass="cm-col-scalar-narrow">
                    <Template Context="limit">@FormatWindow(limit.Window)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GlobalRateLimit" Title="Actions" Sortable="false"
                    CssClass="cm-col-actions" HeaderCssClass="cm-col-actions">
                    <Template Context="limit">
                        <div class="cm-list-page__actions-cell">
                            <RadzenButton Icon="edit" Size="ButtonSize.Small" Variant="Variant.Text"
                                title="Edit quota"
                                Click="@(() => Nav.NavigateTo($"/quotas/{limit.Id}"))" />
                            <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Text"
                                ButtonStyle="ButtonStyle.Danger" title="Delete quota"
                                Click="@(async () => await DeleteAsync(limit))" />
                        </div>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private string? _deleteError;
    private string? _search;
    private List<GlobalRateLimit> _limits = [];
    private Dictionary<string, string> _poolNames = new(StringComparer.OrdinalIgnoreCase);
    private int _pageSize = 10;
    private bool _canCreateMore = true;
    private string? _createDisabledTooltip;
    private IJSObjectReference? _tableJs;
    private DotNetObjectReference<QuotaList>? _selfRef;

    private IEnumerable<GlobalRateLimit> _filteredLimits =>
        string.IsNullOrWhiteSpace(_search)
            ? _limits
            : _limits.Where(l =>
                l.TargetId.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                GetPoolName(l.TargetId).Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _tableJs = await JS.InvokeAsync<IJSObjectReference>("import", "./js/table.js");
            _selfRef = DotNetObjectReference.Create(this);
            await _tableJs.InvokeVoidAsync("register", _selfRef);
            await RecalculatePageSizeAsync();
        }
    }

    [JSInvokable]
    public async Task OnWindowResize() => await RecalculatePageSizeAsync();

    private async Task RecalculatePageSizeAsync()
    {
        _pageSize = await _tableJs!.InvokeAsync<int>("getPageSize", 45);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_tableJs is not null)
        {
            await _tableJs.InvokeVoidAsync("unregister");
            await _tableJs.DisposeAsync();
        }
        _selfRef?.Dispose();
    }

    private async Task LoadAsync()
    {
        try
        {
            _limits = await RateLimitApi.GetByTargetTypeAsync(TargetType.ResourcePool);
            var pools = await PoolApi.GetAllAsync();
            _poolNames = pools.ToDictionary(p => p.Id, p => p.Name, StringComparer.OrdinalIgnoreCase);

            await RefreshCreateAvailabilityAsync(pools);
            _error = null;
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshCreateAvailabilityAsync(IReadOnlyList<ResourcePool>? pools = null)
    {
        pools ??= await PoolApi.GetAllAsync();
        var limitedTargets = _limits
            .Select(l => l.TargetId)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        _canCreateMore = pools.Any(p => !limitedTargets.Contains(p.Id));
        _createDisabledTooltip = _canCreateMore ? null : "Every resource pool already has a quota.";
    }

    private string GetPoolName(string poolId) =>
        _poolNames.GetValueOrDefault(poolId, poolId);

    private Task DeleteAsync(GlobalRateLimit limit) =>
        ListDeleteSupport.ExecuteAsync(
            Dialog,
            "quota for resource pool",
            GetPoolName(limit.TargetId),
            () => RateLimitApi.DeleteAsync(limit.Id),
            LoadAsync,
            message => _deleteError = message,
            StateHasChanged);

    private static string FormatWindow(TimeSpan window)
    {
        if (window.TotalHours >= 1) return $"{window.TotalHours:0.#}h";
        if (window.TotalMinutes >= 1) return $"{window.TotalMinutes:0.#}m";
        return $"{window.TotalSeconds:0.#}s";
    }
}
