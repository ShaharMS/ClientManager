@page "/quotas/new"
@page "/quotas/{Id}"
@inject GlobalRateLimitApiService RateLimitApi
@inject ResourcePoolApiService PoolApi
@inject NavigationManager Nav

<EditorPageTemplate TModel="RateLimitFormModel"
    Id="@Id" IsNew="@_isNew"
    BackPath="quotas" BackLinkText="← Back to Quotas"
    CreateTitle="Create Quota" CreateDescription="@_createDescription"
    EditTitle="@_editTitle" EditTitlePrefix="Edit Quota: " EditDescription="Update quota configuration."
    FormName="quotaForm" Model="@_model" Loading="@_loading" Error="@_error"
    SubmitDisabled="@_submitDisabled" SubmitTitle="@_submitTitle"
    OnValidSubmit="SaveAsync">
    @if (_saveError is not null)
    {
        <div class="alert alert-danger" style="margin-bottom: var(--space-md);">@_saveError</div>
    }
    <div class="cm-editor__field">
        <label>Resource Pool</label>
        <EntityIdInput @bind-Value="_model.TargetId" Suggestions="_poolIds"
            DisabledSuggestions="@_limitedPoolIds"
            DisabledSuggestionMessage="Already has a quota"
            Mode="EntityIdInputMode.Reference" EntityName="resource pool"
            Disabled="@(_isNew && !_canCreate)" />
    </div>
    <div class="cm-editor__field">
        <label>Strategy</label>
        <RadzenDropDown TValue="RateLimitStrategy" @bind-Value="_model.Strategy"
            Data="@(Enum.GetValues<RateLimitStrategy>())" Style="width: 100%;"
            Change="@(_ => StateHasChanged())" />
    </div>
    <div class="cm-editor__field">
        <label>Max Requests</label>
        <RadzenNumeric TValue="int" @bind-Value="_model.MaxRequests" Style="width: 100%;" />
    </div>
    <div class="cm-editor__field">
        <label>Window</label>
        <DurationInput @bind-Value="_model.WindowSeconds" />
    </div>
    @if (_model.Strategy == RateLimitStrategy.TokenBucket)
    {
        <div class="cm-editor__field">
            <label>Tokens Per Refill</label>
            <RadzenNumeric TValue="int?" @bind-Value="_model.TokensPerRefill" Style="width: 100%;" />
        </div>
    }
</EditorPageTemplate>

@code {
    private const string AllPoolsLimitedTooltip = "Every resource pool already has a quota.";

    [Parameter] public string? Id { get; set; }
    private bool _isNew => string.IsNullOrEmpty(Id) || Id == "new";
    private bool _loading = true;
    private string? _error;
    private string? _saveError;
    private string _createDescription = "Define a request quota for a resource pool.";
    private string? _editTitle;
    private RateLimitFormModel _model = new() { TargetType = TargetType.ResourcePool };
    private List<string> _poolIds = [];
    private Dictionary<string, string> _poolNames = new(StringComparer.OrdinalIgnoreCase);
    private List<string> _limitedPoolIds = [];
    private bool _canCreate;
    private bool _submitDisabled;
    private string? _submitTitle;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var pools = await PoolApi.GetAllAsync();
            _poolIds = pools.Select(p => p.Id).ToList();
            _poolNames = pools.ToDictionary(p => p.Id, p => p.Name, StringComparer.OrdinalIgnoreCase);
            var existingLimits = await RateLimitApi.GetByTargetTypeAsync(TargetType.ResourcePool);
            var limitedTargets = existingLimits
                .Select(l => l.TargetId)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            if (!_isNew)
            {
                var limit = await RateLimitApi.GetByIdAsync(Id!);
                if (limit is null)
                {
                    _error = "Quota not found.";
                    return;
                }

                _editTitle = $"Edit Quota: {GetPoolName(limit.TargetId)}";

                limitedTargets.Remove(limit.TargetId);

                _model = new RateLimitFormModel
                {
                    Id = limit.Id,
                    TargetId = limit.TargetId,
                    TargetType = TargetType.ResourcePool,
                    Strategy = limit.Strategy,
                    MaxRequests = limit.MaxRequests,
                    WindowSeconds = limit.Window.TotalSeconds,
                    TokensPerRefill = limit.TokensPerRefill
                };
            }

            _limitedPoolIds = _poolIds
                .Where(id => limitedTargets.Contains(id))
                .ToList();

            if (_isNew)
            {
                _model.TargetId = _poolIds.FirstOrDefault(id => !limitedTargets.Contains(id)) ?? string.Empty;
                RefreshCreateState();
            }
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void RefreshCreateState()
    {
        if (!_isNew)
        {
            _submitDisabled = false;
            _submitTitle = null;
            return;
        }

        _canCreate = _poolIds.Any(id => !_limitedPoolIds.Contains(id, StringComparer.OrdinalIgnoreCase));
        _submitDisabled = !_canCreate;
        _submitTitle = _canCreate ? null : AllPoolsLimitedTooltip;
        _createDescription = _canCreate
            ? "Define a request quota for a resource pool."
            : AllPoolsLimitedTooltip;
    }

    private async Task SaveAsync()
    {
        if (_isNew && (!_canCreate || _limitedPoolIds.Any(id => string.Equals(id, _model.TargetId, StringComparison.OrdinalIgnoreCase))))
        {
            _saveError = AllPoolsLimitedTooltip;
            StateHasChanged();
            return;
        }

        var limit = new GlobalRateLimit
        {
            Id = _isNew ? EntityIdGenerator.FromTarget(_model.TargetId) : _model.Id,
            TargetId = _model.TargetId,
            TargetType = TargetType.ResourcePool,
            Strategy = _model.Strategy,
            MaxRequests = _model.MaxRequests,
            Window = TimeSpan.FromSeconds(_model.WindowSeconds),
            TokensPerRefill = _model.Strategy == RateLimitStrategy.TokenBucket
                ? _model.TokensPerRefill : null
        };

        try
        {
            _saveError = null;

            if (_isNew)
            {
                await RateLimitApi.CreateAsync(limit);
            }
            else
            {
                await RateLimitApi.UpdateAsync(Id!, limit with { Id = _model.Id });
            }
        }
        catch (HttpRequestException ex)
        {
            _saveError = $"Save failed: {ex.Message}";
            StateHasChanged();
            return;
        }

        Nav.NavigateTo("/quotas");
    }

    private string GetPoolName(string poolId) =>
        _poolNames.GetValueOrDefault(poolId, poolId);
}
