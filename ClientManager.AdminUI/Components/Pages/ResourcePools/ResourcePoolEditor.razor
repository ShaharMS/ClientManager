@page "/resource-pools/new"
@page "/resource-pools/{Id}"
@inject ResourcePoolApiService PoolApi
@inject NavigationManager Nav

<div style="margin-bottom: var(--space-md);">
    <RadzenLink Path="resource-pools" Text="← Back to Resource Pools" Style="font-size: var(--font-size-sm);" />
</div>

<div class="cm-page-header">
    <h1>@(_isNew ? "Create Resource Pool" : $"Edit Resource Pool: {Id}")</h1>
    <p>@(_isNew ? "Define a new resource pool." : "Update resource pool configuration.")</p>
</div>

@if (_loading)
{
    <FormSkeleton />
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="cm-editor">
        <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="poolForm">
            <DataAnnotationsValidator />

            <div class="cm-editor__card">
                <div class="cm-editor__field">
                    <label>Pool ID</label>
                    <EntityIdInput @bind-Value="_model.Id" Suggestions="_existingIds"
                        Mode="EntityIdInputMode.Unique" EntityName="resource pool" Disabled="@(!_isNew)" />
                </div>
                <div class="cm-editor__field">
                    <label>Name</label>
                    <RadzenTextBox @bind-Value="_model.Name" Style="width: 100%;" />
                </div>
                <div class="cm-editor__field">
                    <label>Max Slots</label>
                    <RadzenNumeric TValue="uint" @bind-Value="_model.MaxSlots" Style="width: 100%;" />
                </div>
                <div class="cm-editor__field">
                    <label>Allocation TTL (seconds)</label>
                    <RadzenNumeric TValue="double" @bind-Value="_model.AllocationTtlSeconds" Style="width: 100%;" />
                </div>
            </div>

            <div class="cm-editor__actions">
                <RadzenButton Text="Save" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary" />
                <RadzenButton Text="Cancel" Variant="Variant.Outlined" Click="@(() => Nav.NavigateTo("/resource-pools"))" />
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter] public string? Id { get; set; }
    private bool _isNew => string.IsNullOrEmpty(Id) || Id == "new";
    private bool _loading = true;
    private string? _error;
    private PoolFormModel _model = new();
    private List<string> _existingIds = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var all = await PoolApi.GetAllAsync();
            _existingIds = all.Select(p => p.Id).ToList();

            if (!_isNew)
            {
                var pool = await PoolApi.GetByIdAsync(Id!);
                if (pool is null)
                {
                    _error = $"Resource pool '{Id}' not found.";
                    return;
                }
                _model = new PoolFormModel
                {
                    Id = pool.Id,
                    Name = pool.Name,
                    MaxSlots = pool.MaxSlots,
                    AllocationTtlSeconds = pool.AllocationTtl.TotalSeconds
                };
            }
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        var pool = new ResourcePool
        {
            Id = _model.Id,
            Name = _model.Name,
            MaxSlots = _model.MaxSlots,
            AllocationTtl = TimeSpan.FromSeconds(_model.AllocationTtlSeconds)
        };

        try
        {
            if (_isNew)
                await PoolApi.CreateAsync(pool);
            else
                await PoolApi.UpdateAsync(Id!, pool);

            Nav.NavigateTo("/resource-pools");
        }
        catch (HttpRequestException ex)
        {
            _error = $"Save failed: {ex.Message}";
        }
    }

    private class PoolFormModel
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public uint MaxSlots { get; set; } = 10;
        public double AllocationTtlSeconds { get; set; } = 300;
    }
}
