@page "/resource-pools/new"
@page "/resource-pools/{Id}"
@inject ResourcePoolApiService PoolApi
@inject NavigationManager Nav
@inject ApiErrorLocalizer errors

<EditorPageTemplate TModel="PoolFormModel"
    Id="@Id" IsNew="@_isNew"
    BackPath="resource-pools" BackLinkText="@L["Pages.ResourcePools.BackLink"]"
    CreateTitle="@L["Pages.ResourcePools.CreateTitle"]" CreateDescription="@L["Pages.ResourcePools.CreateDescription"]"
    EditTitlePrefix="@L["Pages.ResourcePools.EditTitlePrefix"]" EditDescription="@L["Pages.ResourcePools.EditDescription"]"
    FormName="poolForm" Model="@_model" Loading="@_loading" Error="@_error"
    OnValidSubmit="SaveAsync">
    <div class="cm-editor__field">
        <label>@L["Pages.ResourcePools.PoolId"]</label>
        <EntityIdInput @bind-Value="_model.Id" Suggestions="_existingIds"
            Mode="EntityIdInputMode.Unique" EntityName="@L["Dialog.EntityLabel.ResourcePool"]" Disabled="@(!_isNew)" />
    </div>
    <div class="cm-editor__field">
        <label>@L["Pages.ResourcePools.Name"]</label>
        <RadzenTextBox @bind-Value="_model.Name" Style="width: 100%;" />
    </div>
    <div class="cm-editor__field">
        <label>@L["Pages.ResourcePools.Enabled"]</label>
        <RadzenSwitch @bind-Value="_model.IsEnabled" />
    </div>
    <div class="cm-editor__field">
        <label>@L["Pages.ResourcePools.MaxSlots"]</label>
        <RadzenNumeric TValue="uint" @bind-Value="_model.MaxSlots" Style="width: 100%;" />
    </div>
    <div class="cm-editor__field">
        <label>@L["Pages.ResourcePools.AllocationTtl"]</label>
        <DurationInput @bind-Value="_model.AllocationTtlSeconds" />
    </div>
</EditorPageTemplate>

@code {
    [Parameter] public string? Id { get; set; }
    private bool _isNew => string.IsNullOrEmpty(Id) || Id == "new";
    private bool _loading = true;
    private string? _error;
    private PoolFormModel _model = new();
    private List<string> _existingIds = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _existingIds = (await PoolApi.GetAllAsync()).Select(p => p.Id).ToList();

            if (!_isNew)
            {
                var pool = await PoolApi.GetByIdAsync(Id!);
                if (pool is null)
                {
                    _error = L["Pages.ResourcePools.NotFound"];
                    return;
                }

                _model = new PoolFormModel
                {
                    Id = pool.Id,
                    Name = pool.Name,
                    MaxSlots = pool.MaxSlots,
                    AllocationTtlSeconds = pool.AllocationTtl.TotalSeconds,
                    IsEnabled = pool.IsEnabled
                };
            }
        }
        catch (HttpRequestException ex)
        {
            _error = errors.Format("Api.UnableToConnect", ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        var pool = new ResourcePool
        {
            Id = _model.Id,
            Name = _model.Name,
            MaxSlots = _model.MaxSlots,
            AllocationTtl = TimeSpan.FromSeconds(_model.AllocationTtlSeconds),
            IsEnabled = _model.IsEnabled
        };

        try
        {
            if (_isNew)
            {
                await PoolApi.CreateAsync(pool);
            }
            else
            {
                await PoolApi.UpdateAsync(Id!, pool);
            }
        }
        catch (HttpRequestException ex)
        {
            _error = errors.Format("Pages.ResourcePools.SaveFailed", ex);
            return;
        }

        Nav.NavigateTo("/resource-pools");
    }
}
