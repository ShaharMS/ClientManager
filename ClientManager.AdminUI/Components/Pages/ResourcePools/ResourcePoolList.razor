@page "/resource-pools"
@using System.Globalization
@inject ResourcePoolApiService PoolApi
@inject NavigationManager Nav
@inject DialogService Dialog
@inject ApiErrorLocalizer errors
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="cm-page-header">
    <h1>@L["Pages.ResourcePools.Title"]</h1>
    <p>@L["Pages.ResourcePools.Subtitle"]</p>
</div>

@if (_actionError is not null)
{
    <div class="alert alert-danger">@_actionError</div>
}

@if (_loading)
{
    <TableSkeleton />
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="cm-list-page__table-card">
        <div class="cm-list-page__header cm-list-page__header--with-filter cm-list-page__header--resource-pools">
            <div class="cm-list-page__filter-field">
                <RadzenDropDown TValue="bool?" Data="@_enabledOptions"
                    TextProperty="Label" ValueProperty="Value"
                    Value="@_enabledFilter"
                    ValueChanged="@((bool? v) => OnEnabledFilterChanged(v))"
                    Placeholder="@L["Filter.AllStatuses"]" AllowClear="true" />
            </div>
            <div class="cm-list-page__header-actions">
                <RadzenButton Text="@L["Pages.ResourcePools.CreateButton"]" Icon="add"
                    class="cm-list-page__create-btn"
                    title="@L["Pages.ResourcePools.CreateTooltip"]"
                    Click="@(() => Nav.NavigateTo("/resource-pools/new"))"
                    ButtonStyle="ButtonStyle.Primary" />
            </div>
            <div class="cm-list-page__search-field">
                <RadzenTextBox Placeholder="@L["Pages.ResourcePools.Search"]"
                    Value="@_search"
                    ValueChanged="@((string v) => { _search = v; StateHasChanged(); })"
                    @oninput="@(args => { _search = args.Value?.ToString(); StateHasChanged(); })" />
            </div>
        </div>

        <RadzenDataGrid Data="@_filteredPools" TItem="ResourcePool" EmptyText="@L["DataGrid.NoRecords"]"
            AllowSorting="true" AllowPaging="true" PageSize="@_pageSize"
            PagerHorizontalAlign="HorizontalAlign.Center">
            <Columns>
                <RadzenDataGridColumn TItem="ResourcePool" Property="Id" Title="@L["Columns.Id"]"
                    CssClass="cm-col-id" HeaderCssClass="cm-col-id" />
                <RadzenDataGridColumn TItem="ResourcePool" Property="Name" Title="@L["Columns.Name"]"
                    CssClass="cm-col-name" HeaderCssClass="cm-col-name" />
                <RadzenDataGridColumn TItem="ResourcePool" Property="MaxSlots" Title="@L["Columns.MaxSlots"]"
                    CssClass="cm-col-scalar" HeaderCssClass="cm-col-scalar" />
                <RadzenDataGridColumn TItem="ResourcePool" Title="@L["Columns.AllocationTtl"]"
                    CssClass="cm-col-scalar-wide" HeaderCssClass="cm-col-scalar-wide">
                    <Template Context="pool">@TimeSpanFormatter.FormatCompact(pool.AllocationTtl, L)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ResourcePool" Title="@L["Columns.Status"]" Sortable="false"
                    CssClass="cm-col-status" HeaderCssClass="cm-col-status">
                    <Template Context="pool">
                        @if (pool.IsEnabled)
                        {
                            <span class="cm-badge cm-badge--success">@L["Common.Enabled"]</span>
                        }
                        else
                        {
                            <span class="cm-badge cm-badge--muted">@L["Common.Disabled"]</span>
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ResourcePool" Title="@L["Columns.Actions"]" Sortable="false"
                    CssClass="cm-col-actions-wide" HeaderCssClass="cm-col-actions-wide">
                    <Template Context="pool">
                        <div class="cm-list-page__actions-cell">
                        <RadzenButton Icon="edit" Size="ButtonSize.Small" Variant="Variant.Text"
                            title="@L["Pages.ResourcePools.EditTooltip"]"
                            Click="@(() => Nav.NavigateTo($"/resource-pools/{pool.Id}"))" />
                        @if (pool.IsEnabled)
                        {
                            <RadzenButton Icon="block" Size="ButtonSize.Small" Variant="Variant.Text"
                                ButtonStyle="ButtonStyle.Warning" title="@L["Pages.ResourcePools.DisableTooltip"]"
                                Click="@(async () => await ToggleEnabledAsync(pool))" />
                        }
                        else
                        {
                            <RadzenButton Icon="lock_open" Size="ButtonSize.Small" Variant="Variant.Text"
                                ButtonStyle="ButtonStyle.Success" title="@L["Pages.ResourcePools.EnableTooltip"]"
                                Click="@(async () => await ToggleEnabledAsync(pool))" />
                        }
                        <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Text"
                            ButtonStyle="ButtonStyle.Danger" title="@L["Pages.ResourcePools.DeleteTooltip"]"
                            Click="@(async () => await DeleteAsync(pool.Id))" />
                        </div>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private string? _actionError;
    private string? _search;
    private bool? _enabledFilter;
    private List<ResourcePool> _pools = [];
    private int _pageSize = 10;
    private IJSObjectReference? _tableJs;
    private DotNetObjectReference<ResourcePoolList>? _selfRef;
    private List<object> _enabledOptions = [];

    private IEnumerable<ResourcePool> _filteredPools =>
        string.IsNullOrWhiteSpace(_search)
            ? _pools
            : _pools.Where(p =>
                p.Id.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _enabledOptions =
        [
            new { Label = L["Common.Enabled"], Value = (bool?)true },
            new { Label = L["Common.Disabled"], Value = (bool?)false }
        ];
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _tableJs = await JS.InvokeAsync<IJSObjectReference>("import", "./js/table.js");
            _selfRef = DotNetObjectReference.Create(this);
            await _tableJs.InvokeVoidAsync("register", _selfRef);
            await RecalculatePageSizeAsync();
        }
    }

    [JSInvokable]
    public async Task OnWindowResize() => await RecalculatePageSizeAsync();

    private async Task RecalculatePageSizeAsync()
    {
        _pageSize = await _tableJs!.InvokeAsync<int>("getPageSize", 45);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_tableJs is not null)
        {
            await _tableJs.InvokeVoidAsync("unregister");
            await _tableJs.DisposeAsync();
        }
        _selfRef?.Dispose();
    }

    private async Task LoadAsync()
    {
        try
        {
            if (_enabledFilter.HasValue)
            {
                var query = new DocumentQuery { Take = 100 }
                    .Where(nameof(ResourcePool.IsEnabled), ClientManager.Shared.Models.Search.FilterOperator.Equals, _enabledFilter.Value);
                var result = await PoolApi.SearchAsync(query);
                _pools = result.Items.ToList();
            }
            else
            {
                _pools = await PoolApi.GetAllAsync();
            }
            _error = null;
        }
        catch (HttpRequestException ex)
        {
            _error = errors.Format("Api.UnableToConnect", ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnEnabledFilterChanged(bool? value)
    {
        _enabledFilter = value;
        _loading = true;
        await LoadAsync();
    }

    private Task ToggleEnabledAsync(ResourcePool pool) =>
        ListToggleEnabledSupport.ExecuteAsync(
            Dialog,
            L,
            errors,
            L["Dialog.EntityLabel.ResourcePool"],
            pool.Id,
            pool.IsEnabled,
            async () =>
            {
                var updated = pool with { IsEnabled = !pool.IsEnabled };
                await PoolApi.UpdateAsync(pool.Id, updated);
            },
            LoadAsync,
            message => _actionError = message,
            StateHasChanged,
            disableMessage: string.Format(CultureInfo.CurrentCulture, L["Dialog.ConfirmDisable.ResourcePool"], pool.Id),
            enableMessage: string.Format(CultureInfo.CurrentCulture, L["Dialog.ConfirmEnable.ResourcePool"], pool.Id));

    private Task DeleteAsync(string id) =>
        ListDeleteSupport.ExecuteAsync(
            Dialog,
            L,
            errors,
            L["Dialog.EntityLabel.ResourcePool"],
            id,
            () => PoolApi.DeleteAsync(id),
            LoadAsync,
            message => _actionError = message,
            StateHasChanged);

}
