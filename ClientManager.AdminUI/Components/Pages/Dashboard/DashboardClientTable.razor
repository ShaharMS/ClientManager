@using ClientManager.AdminUI.Models.Dashboard

<div class="cm-dashboard__table-card">
    <div class="cm-chart-card__header">
        <span class="cm-chart-card__title cm-chart-card__title--plain">@L["Pages.Dashboard.ClientOverview"]</span>
        <div class="cm-list-page__search-field" style="width: 250px; flex: 0 0 auto;">
            <RadzenTextBox Placeholder="@L["Pages.Dashboard.SearchClients"]" Value="@SearchText"
                ValueChanged="@OnSearchTextChanged"
                @oninput="OnSearchInput" />
        </div>
    </div>

    <RadzenDataGrid Data="@FilteredRows" TItem="ClientSummaryTableRow" EmptyText="@L["DataGrid.NoRecords"]"
        AllowSorting="true" AllowPaging="true" PageSize="10"
        PagerHorizontalAlign="HorizontalAlign.Center">
        <Columns>
            <RadzenDataGridColumn TItem="ClientSummaryTableRow" Property="ClientId" Title="@L["Columns.ClientId"]"
                CssClass="cm-col-id" HeaderCssClass="cm-col-id" />
            <RadzenDataGridColumn TItem="ClientSummaryTableRow" Property="DisplayName" Title="@L["Columns.Name"]"
                CssClass="cm-col-name" HeaderCssClass="cm-col-name" />
            <RadzenDataGridColumn TItem="ClientSummaryTableRow" Property="AccessibleServices" Title="@L["Columns.Services"]"
                CssClass="cm-col-scalar-count" HeaderCssClass="cm-col-scalar-count" />
            <RadzenDataGridColumn TItem="ClientSummaryTableRow" Property="TotalRateLimitRequests" Title="@L["Columns.RateLimitCap"]"
                CssClass="cm-col-scalar-wide" HeaderCssClass="cm-col-scalar-wide">
                <Template Context="row">@UtilizationHelper.FormatRequestsPerMinute(L, row.TotalRateLimitRequests)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ClientSummaryTableRow" Property="AccessiblePools" Title="@L["Columns.Pools"]"
                CssClass="cm-col-scalar-count" HeaderCssClass="cm-col-scalar-count" />
            <RadzenDataGridColumn TItem="ClientSummaryTableRow" Property="MaxSlots" Title="@L["Columns.MaxSlots"]"
                CssClass="cm-col-scalar-count" HeaderCssClass="cm-col-scalar-count" />
        </Columns>
    </RadzenDataGrid>
</div>

@code {
    [Parameter] public List<ClientSummaryTableRow> AllRows { get; set; } = [];
    [Parameter] public List<ClientSummaryTableRow> FilteredRows { get; set; } = [];
    [Parameter] public string? SearchText { get; set; }
    [Parameter] public EventCallback<string?> SearchTextChanged { get; set; }
    [Parameter] public EventCallback OnSearchChanged { get; set; }

    private async Task OnSearchTextChanged(string? value)
    {
        await SearchTextChanged.InvokeAsync(value);
        await OnSearchChanged.InvokeAsync();
    }

    private async Task OnSearchInput(ChangeEventArgs args)
    {
        await SearchTextChanged.InvokeAsync(args.Value?.ToString());
        await OnSearchChanged.InvokeAsync();
    }
}
