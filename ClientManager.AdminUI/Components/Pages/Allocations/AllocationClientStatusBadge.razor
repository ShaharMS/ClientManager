@using ClientManager.AdminUI.Localization
@using ClientManager.AdminUI.Models.Allocations
@using ClientManager.AdminUI.Utils

@if (!IsAccessMetric && Row.CapValue > 0 && Row.CurrentValue >= Row.CapValue)
{
    <StatusBadge Text="@L[TermKeys.DeniedOutOfSlots]" Variant="StatusBadgeVariant.Danger" />
}
else
{
    var badge = DenialStatusBadgeResolver.Resolve(
        Row.DeniedRateLimitedCount,
        Row.DeniedBlockedCount,
        Row.DeniedUnauthenticatedCount,
        Row.CurrentValue,
        Row.CapValue,
        includeCapacityDenials: !IsAccessMetric,
        deniedCapacity: Row.DeniedCapacityLimitedCount);
    <StatusBadge Text="@L[badge.TermKey]" Variant="@badge.Variant" />
}

@code {
    [Parameter, EditorRequired] public AllocationClientRow Row { get; set; } = null!;
    [Parameter] public bool IsAccessMetric { get; set; }
}
