@using ClientManager.AdminUI.Models
@using ClientManager.AdminUI.Models.Allocations
@using ClientManager.AdminUI.Utils

<div class="cm-list-page__table-card" style="margin-top: var(--space-lg);">
    <div class="cm-dashboard__chart-header">
        <span class="cm-dashboard__chart-title">@Title</span>
    </div>
    <RadzenDataGrid @ref="_grid" Data="@Rows" TItem="PoolSummaryRow" EmptyText="@L["DataGrid.NoRecords"]"
        AllowSorting="true" AllowPaging="true" PageSize="15"
        PagerHorizontalAlign="HorizontalAlign.Center">
        <Columns>
            <RadzenDataGridColumn TItem="PoolSummaryRow" Property="Name" Title="@L["Columns.Pool"]"
                CssClass="cm-col-label" HeaderCssClass="cm-col-label" />
            <RadzenDataGridColumn TItem="PoolSummaryRow" Title="@(IsAccessMetric ? L["Columns.Requests"] : L["Columns.Active"])"
                CssClass="cm-col-scalar" HeaderCssClass="cm-col-scalar">
                <Template Context="pool">@pool.CurrentValue.ToString("N0")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="PoolSummaryRow" Title="@(IsAccessMetric ? L["Columns.Cap"] : L["Columns.Max"])"
                CssClass="cm-col-scalar" HeaderCssClass="cm-col-scalar">
                <Template Context="pool">@(IsAccessMetric ? UtilizationHelper.FormatCap(pool.CapValue) : pool.CapValue.ToString("N0"))</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="PoolSummaryRow" Title="@(IsAccessMetric ? L["Columns.Remaining"] : L["Columns.Available"])"
                CssClass="cm-col-scalar" HeaderCssClass="cm-col-scalar">
                <Template Context="pool">@(IsAccessMetric ? UtilizationHelper.FormatRemaining(pool.RemainingValue) : (pool.RemainingValue ?? 0).ToString("N0"))</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="PoolSummaryRow" Title="@L["Columns.Denied"]"
                CssClass="cm-col-scalar-wide" HeaderCssClass="cm-col-scalar-wide">
                <Template Context="pool">
                    <DeniedBreakdownCell Total="@pool.DeniedLast5Min"
                        Unauthenticated="@pool.DeniedUnauthenticatedCount"
                        Blocked="@pool.DeniedBlockedCount"
                        RateLimited="@pool.DeniedRateLimitedCount"
                        CapacityLimited="@pool.DeniedCapacityLimitedCount"
                        ViewMode="@DeniedViewMode"
                        ShowBreakdown="@ShowDeniedBreakdown" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="PoolSummaryRow" Title="@L["Columns.Utilization"]"
                CssClass="cm-col-bar" HeaderCssClass="cm-col-bar">
                <Template Context="pool">
                    @if (pool.CapValue > 0 || !IsAccessMetric)
                    {
                        var pct = pool.CapValue > 0 ? (int)(pool.CurrentValue * 100.0 / pool.CapValue) : 0;
                        <UtilizationProgressBar Percent="@pct" />
                    }
                    else
                    {
                        <span>-</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="PoolSummaryRow" Title="@L["Columns.Status"]" Sortable="false"
                CssClass="cm-col-status" HeaderCssClass="cm-col-status">
                <Template Context="pool">
                    <div class="cm-list-page__actions-cell">
                        <AllocationPoolStatusBadge Row="pool" IsAccessMetric="IsAccessMetric" />
                    </div>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public List<PoolSummaryRow> Rows { get; set; } = [];
    [Parameter] public bool IsAccessMetric { get; set; }
    [Parameter] public bool ShowDeniedBreakdown { get; set; }
    [Parameter] public DeniedViewMode DeniedViewMode { get; set; }
    private RadzenDataGrid<PoolSummaryRow>? _grid;

    public async Task ReloadAsync(Func<Func<Task>, Task> dispatchAsync)
    {
        if (_grid is not null)
        {
            await dispatchAsync(_grid.Reload);
        }
    }
}
