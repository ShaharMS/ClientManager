@page "/allocations"
@inject StatisticsApiService StatsService
@inject ClientApiService ClientService
@inject EntityColorService Colors
@implements IDisposable

<div class="cm-page-header">
    <h1>Active Allocations</h1>
    <p>Real-time resource pool utilization — refreshes every 10 seconds.</p>
</div>

<div class="cm-monitor__filters">
    <RadzenDropDown TValue="string" @bind-Value="_selectedPoolId"
        Data="@_poolOptions" TextProperty="Name" ValueProperty="Id"
        Placeholder="Select pool..." Style="width: 220px;"
        Change="@OnFilterChanged" />
    <RadzenDropDown @bind-Value="_selectedClientIds" Multiple="true"
        Data="@_clientOptions" TextProperty="Name" ValueProperty="Id"
        Placeholder="All clients" Style="width: 200px;"
        Change="@OnFilterChanged" />
    <span class="cm-badge cm-badge--success" style="margin-left: auto;">
        <RadzenIcon Icon="fiber_manual_record" Style="font-size: 10px;" /> Auto-refreshing
    </span>
</div>

@if (_error is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Light">@_error</RadzenAlert>
}

@if (_loading)
{
    <SkeletonBlock CssClass="cm-skeleton--text" Style="height: 3px; margin-bottom: var(--space-sm);" />
}

<div class="cm-monitor__chart-card">
    @if (_targetCharts.Count > 0)
    {
        @foreach (var targetChart in _targetCharts)
        {
            <div class="cm-dashboard__chart-header">
                <span class="cm-dashboard__chart-title">@targetChart.TargetName — Slot Usage</span>
            </div>
            <RadzenChart Style="height: 400px;">
                @foreach (var clientArea in targetChart.ClientSeries)
                {
                    <RadzenStackedAreaSeries Data="@clientArea.Points"
                        CategoryProperty="Label" ValueProperty="Value"
                        Title="@clientArea.ClientName"
                        Fill="@Colors.GetColor(clientArea.ClientId)"
                        Stroke="@Colors.GetColor(clientArea.ClientId)" />
                }
                <RadzenLineSeries Data="@targetChart.CapSeries"
                    CategoryProperty="Label" ValueProperty="Value"
                    Title="Max Slots" LineType="LineType.Dashed"
                    Stroke="var(--color-text-secondary)" />
                <RadzenCategoryAxis />
                <RadzenValueAxis />
                <RadzenLegend Position="LegendPosition.Right" />
            </RadzenChart>
        }
    }
    else
    {
        <ChartSkeleton />
    }
</div>

<div class="cm-list-page__table-card" style="margin-top: var(--space-lg);">
    <div class="cm-dashboard__chart-header">
        <span class="cm-dashboard__chart-title">Client Allocation Detail</span>
    </div>
    <RadzenDataGrid Data="@_clientDetailRows" TItem="AllocationClientRow"
        AllowSorting="true" AllowPaging="true" PageSize="15"
        PagerHorizontalAlign="HorizontalAlign.Center">
        <Columns>
            <RadzenDataGridColumn TItem="AllocationClientRow" Property="ClientName" Title="Client" />
            <RadzenDataGridColumn TItem="AllocationClientRow" Property="PoolName" Title="Pool" />
            <RadzenDataGridColumn TItem="AllocationClientRow" Property="ActiveSlots" Title="Active" Width="90px" />
            <RadzenDataGridColumn TItem="AllocationClientRow" Property="MaxSlots" Title="Max" Width="80px" />
            <RadzenDataGridColumn TItem="AllocationClientRow" Title="Utilization" Width="180px">
                <Template Context="row">
                    @{
                        var pct = row.MaxSlots > 0
                            ? (int)(row.ActiveSlots * 100.0 / row.MaxSlots) : 0;
                        var barStyle = pct >= 100 ? ProgressBarStyle.Danger
                            : pct >= 75 ? ProgressBarStyle.Warning : ProgressBarStyle.Success;
                    }
                    <RadzenProgressBar Value="@pct" Max="100" ShowValue="true"
                        ProgressBarStyle="@barStyle" Style="height: 18px;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AllocationClientRow" Property="DeniedLast5Min" Title="Denied (5m)" Width="110px" />
            <RadzenDataGridColumn TItem="AllocationClientRow" Title="Status" Width="120px" Sortable="false">
                <Template Context="row">
                    @if (row.ActiveSlots >= row.MaxSlots && row.MaxSlots > 0)
                    {
                        <span class="cm-badge" style="background: #fee2e2; color: #991b1b;">At Capacity</span>
                    }
                    else if (row.DeniedLast5Min > 0)
                    {
                        <span class="cm-badge" style="background: #fef3c7; color: #92400e;">Contention</span>
                    }
                    else
                    {
                        <span class="cm-badge cm-badge--success">Available</span>
                    }
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>

<hr class="cm-monitor__separator" />

<div class="cm-list-page__table-card" style="margin-top: var(--space-lg);">
    <div class="cm-dashboard__chart-header">
        <span class="cm-dashboard__chart-title">All Resource Pools</span>
    </div>
    <RadzenDataGrid Data="@_pools" TItem="ResourcePoolStatistics"
        AllowSorting="true" AllowPaging="true" PageSize="15"
        PagerHorizontalAlign="HorizontalAlign.Center">
        <Columns>
            <RadzenDataGridColumn TItem="ResourcePoolStatistics" Property="Name" Title="Pool" />
            <RadzenDataGridColumn TItem="ResourcePoolStatistics" Property="ActiveAllocations" Title="Active" Width="100px" />
            <RadzenDataGridColumn TItem="ResourcePoolStatistics" Property="MaxSlots" Title="Max" Width="100px" />
            <RadzenDataGridColumn TItem="ResourcePoolStatistics" Property="AvailableSlots" Title="Available" Width="100px" />
            <RadzenDataGridColumn TItem="ResourcePoolStatistics" Title="Utilization" Width="200px">
                <Template Context="pool">
                    @{
                        var pct = pool.MaxSlots > 0
                            ? (int)(pool.ActiveAllocations * 100.0 / pool.MaxSlots) : 0;
                        var barStyle = pct >= 100 ? ProgressBarStyle.Danger
                            : pct >= 75 ? ProgressBarStyle.Warning : ProgressBarStyle.Success;
                    }
                    <RadzenProgressBar Value="@pct" Max="100" ShowValue="true"
                        ProgressBarStyle="@barStyle" Style="height: 20px;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ResourcePoolStatistics" Title="Status" Width="110px" Sortable="false">
                <Template Context="pool">
                    @if (pool.AvailableSlots == 0)
                    {
                        <span class="cm-badge" style="background: #fee2e2; color: #991b1b;">At Capacity</span>
                    }
                    else
                    {
                        <span class="cm-badge cm-badge--success">Available</span>
                    }
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>

@code {
    private const string AllPoolsId = "__all__";

    private List<ResourcePoolStatistics> _pools = [];
    private List<NamedItem> _poolOptions = [];
    private List<ClientOption> _clientOptions = [];
    private string _selectedPoolId = AllPoolsId;
    private IEnumerable<string>? _selectedClientIds;

    private bool _loading;
    private string? _error;
    private Timer? _timer;

    private List<TargetChartData> _targetCharts = [];
    private List<AllocationClientRow> _clientDetailRows = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _pools = await StatsService.GetResourcePoolStatsAsync();
            var clients = await ClientService.GetAllAsync();
            _clientOptions = clients
                .Select(c => new ClientOption(c.Id, c.Name))
                .ToList();

            _poolOptions = new List<NamedItem> { new(AllPoolsId, "All Pools") }
                .Concat(_pools.Select(p => new NamedItem(p.ResourcePoolId, p.Name)))
                .ToList();
            _selectedPoolId = AllPoolsId;

            await LoadDataAsync();
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }

        _timer = new Timer(async _ =>
        {
            await LoadDataAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async Task OnFilterChanged()
    {
        _loading = true;
        StateHasChanged();
        await LoadDataAsync();
        _loading = false;
        StateHasChanged();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _pools = await StatsService.GetResourcePoolStatsAsync();

            var now = DateTime.UtcNow;
            var from = now.AddHours(-1);
            var recentFrom = now.AddMinutes(-5);

            var visiblePools = _selectedPoolId == AllPoolsId
                ? _pools
                : _pools.Where(p => p.ResourcePoolId == _selectedPoolId).ToList();

            // Fetch all breakdowns in parallel
            var breakdownTasks = visiblePools.Select(pool =>
                StatsService.GetClientUsageBreakdownAsync(
                    "ResourcePool", pool.ResourcePoolId, _selectedClientIds))
                .ToList();
            var breakdowns = await Task.WhenAll(breakdownTasks);

            var charts = new List<TargetChartData>();
            var rows = new List<AllocationClientRow>();

            if (_selectedPoolId == AllPoolsId)
            {
                var aggregated = new Dictionary<string, double>();
                var totalMaxSlots = 0;

                // Build list of all history tasks across all pools
                var historyRequests = new List<(string PoolName, int MaxSlots, string ClientId, string ClientName)>();
                for (var i = 0; i < visiblePools.Count; i++)
                {
                    var pool = visiblePools[i];
                    totalMaxSlots += pool.MaxSlots;
                    foreach (var entry in breakdowns[i]?.Entries ?? [])
                    {
                        historyRequests.Add((pool.Name, pool.MaxSlots, entry.ClientId, entry.ClientName));
                    }
                }

                // Fetch all histories in parallel
                var historyTasks = historyRequests.Select(r =>
                    StatsService.GetHistoricalUsageAsync(
                        "ResourcePool",
                        visiblePools.First(p => p.Name == r.PoolName).ResourcePoolId,
                        r.ClientId, from, now, "FiveMinute")).ToList();
                var recentTasks = historyRequests.Select(r =>
                    StatsService.GetHistoricalUsageAsync(
                        "ResourcePool",
                        visiblePools.First(p => p.Name == r.PoolName).ResourcePoolId,
                        r.ClientId, recentFrom, now, "FiveMinute")).ToList();

                var histories = await Task.WhenAll(historyTasks);
                var recents = await Task.WhenAll(recentTasks);

                for (var i = 0; i < historyRequests.Count; i++)
                {
                    var request = historyRequests[i];
                    foreach (var point in histories[i]?.Points ?? [])
                    {
                        var label = point.Timestamp.ToLocalTime().ToString("HH:mm");
                        if (!aggregated.ContainsKey(label))
                            aggregated[label] = 0;
                        aggregated[label] += (double)point.ActiveCount;
                    }

                    var lastPoint = recents[i]?.Points.LastOrDefault();
                    var active = (int)(lastPoint?.ActiveCount ?? 0);
                    var denied = recents[i]?.Points.Sum(p => p.DeniedCount) ?? 0;
                    rows.Add(new AllocationClientRow(
                        request.ClientId, request.ClientName, request.PoolName,
                        active, request.MaxSlots, denied));
                }

                var sortedPoints = aggregated
                    .OrderBy(kv => kv.Key)
                    .Select(kv => new ChartPoint(kv.Key, kv.Value))
                    .ToList();

                var capPoints = sortedPoints
                    .Select(p => new ChartPoint(p.Label, totalMaxSlots))
                    .ToList();

                charts.Add(new TargetChartData("All Pools",
                    new List<ClientAreaSeries> { new("total", "Total", sortedPoints) },
                    capPoints));
            }
            else
            {
                for (var poolIdx = 0; poolIdx < visiblePools.Count; poolIdx++)
                {
                    var pool = visiblePools[poolIdx];
                    var entries = breakdowns[poolIdx]?.Entries ?? [];

                    // Fetch all client histories for this pool in parallel
                    var clientHistoryTasks = entries.Select(entry =>
                        StatsService.GetHistoricalUsageAsync(
                            "ResourcePool", pool.ResourcePoolId, entry.ClientId,
                            from, now, "FiveMinute")).ToList();
                    var clientRecentTasks = entries.Select(entry =>
                        StatsService.GetHistoricalUsageAsync(
                            "ResourcePool", pool.ResourcePoolId, entry.ClientId,
                            recentFrom, now, "FiveMinute")).ToList();

                    var clientHistories = await Task.WhenAll(clientHistoryTasks);
                    var clientRecents = await Task.WhenAll(clientRecentTasks);

                    var clientAreas = new List<ClientAreaSeries>();

                    // Collect the union of all timestamps across all clients
                    var allTimestampSet = new SortedSet<string>();
                    var rawPointsByClient = new List<Dictionary<string, double>>();

                    for (var i = 0; i < entries.Count; i++)
                    {
                        var lookup = new Dictionary<string, double>();
                        foreach (var p in clientHistories[i]?.Points ?? [])
                        {
                            var label = p.Timestamp.ToLocalTime().ToString("HH:mm");
                            allTimestampSet.Add(label);
                            lookup[label] = (double)p.ActiveCount;
                        }
                        rawPointsByClient.Add(lookup);
                    }

                    var allTimestamps = allTimestampSet.ToList();

                    for (var i = 0; i < entries.Count; i++)
                    {
                        var entry = entries[i];
                        var lookup = rawPointsByClient[i];
                        var points = allTimestamps
                            .Select(t => new ChartPoint(t, lookup.GetValueOrDefault(t, 0)))
                            .ToList();

                        clientAreas.Add(new ClientAreaSeries(entry.ClientId, entry.ClientName, points));

                        var lastPoint = clientRecents[i]?.Points.LastOrDefault();
                        var active = (int)(lastPoint?.ActiveCount ?? 0);
                        var denied = clientRecents[i]?.Points.Sum(p => p.DeniedCount) ?? 0;

                        rows.Add(new AllocationClientRow(
                            entry.ClientId, entry.ClientName, pool.Name,
                            active, pool.MaxSlots, denied));
                    }

                    var capPoints = allTimestamps
                        .Select(t => new ChartPoint(t, pool.MaxSlots))
                        .ToList();

                    var aggregatedAreas = ChartAggregator.Aggregate(
                        clientAreas.Select(c => new ChartAggregator.AggregatedSeries(
                            c.ClientId, c.ClientName,
                            c.Points.Select(p => new ChartAggregator.AggregatedPoint(p.Label, p.Value)).ToList()
                        )).ToList());

                    clientAreas = aggregatedAreas.Select(a => new ClientAreaSeries(
                        a.Id, a.Name,
                        a.Points.Select(p => new ChartPoint(p.Label, p.Value)).ToList()
                    )).ToList();

                    charts.Add(new TargetChartData(pool.Name, clientAreas, capPoints));
                }
            }

            _targetCharts = charts;
            _clientDetailRows = rows;
            _error = null;
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to load data: {ex.Message}";
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }

    private record NamedItem(string Id, string Name);
    private record ChartPoint(string Label, double Value);
    private record ClientOption(string Id, string Name);
    private record ClientAreaSeries(string ClientId, string ClientName, List<ChartPoint> Points);
    private record TargetChartData(
        string TargetName, List<ClientAreaSeries> ClientSeries,
        List<ChartPoint> CapSeries);
    private record AllocationClientRow(
        string ClientId, string ClientName, string PoolName,
        int ActiveSlots, int MaxSlots, long DeniedLast5Min);
}
