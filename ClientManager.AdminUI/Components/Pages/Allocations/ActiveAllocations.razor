@page "/allocations"
@using ClientManager.Shared.Models.Responses
@inject StatisticsApiService StatsService
@inject ClientApiService ClientService
@inject GlobalRateLimitApiService RateLimitApi
@inject EntityColorService Colors
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="cm-page-header">
    <h1>Active Allocations</h1>
    <p>Resource pool utilization across all clients and pools.</p>
</div>

@if (_error is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Light">@_error</RadzenAlert>
}

@if (_loading)
{
    <SkeletonBlock CssClass="cm-skeleton--text" Style="height: 3px; margin-bottom: var(--space-sm);" />
}

<div class="cm-monitor__chart-card">
    <div class="cm-dashboard__chart-header">
        <div class="cm-dashboard__filters">
            <RadzenDropDown TValue="string" @bind-Value="_selectedPoolId"
                Data="@_poolOptions" TextProperty="Name" ValueProperty="Id"
                Placeholder="Select pool..." Style="width: 220px;"
                Change="@OnFilterChanged" />
            <RadzenDropDown @bind-Value="_selectedClientIds" Multiple="true"
                Data="@_clientOptions" TextProperty="Name" ValueProperty="Id"
                Placeholder="All clients" Style="width: 200px;"
                Change="@OnFilterChanged" />
            <RadzenDropDown TValue="string" @bind-Value="_selectedMetric"
                Data="@_metricOptions" TextProperty="Name" ValueProperty="Value"
                Style="width: 220px;"
                Change="@OnMetricChanged" />
        </div>
        <ChartSettingsDropdown OnTimeRangeChanged="OnTimeRangeChanged"
                                   OnPollingIntervalChanged="OnPollingIntervalChanged"
                                   OnAxisScaleChanged="OnAxisScaleChanged" />
    </div>
    @if (_targetCharts.Count > 0)
    {
        @foreach (var targetChart in _targetCharts)
        {
            <span class="cm-dashboard__chart-title">@targetChart.TargetName - @(IsAccessMetric ? "Access Requests" : "Active Allocations")</span>
            <RadzenChart Style="height: 400px;">
                @{
                    var allocSeries = _axisScaleType == AxisScaleType.Logarithmic
                        ? TransformStackedLogarithmic(targetChart.ClientSeries)
                        : targetChart.ClientSeries;
                }
                @foreach (var clientArea in allocSeries)
                {
                    <RadzenStackedAreaSeries Data="@clientArea.Points"
                        CategoryProperty="Label" ValueProperty="Value"
                        Title="@clientArea.ClientName"
                        Fill="@Colors.GetColor(clientArea.ClientId)"
                        Stroke="@Colors.GetColor(clientArea.ClientId)">
                        <TooltipTemplate Context="point">
                            <span>@clientArea.ClientName: @(point.OriginalValue.ToString("N0"))</span>
                        </TooltipTemplate>
                    </RadzenStackedAreaSeries>
                }
                <RadzenLineSeries Data="@TransformPoints(targetChart.CapSeries)"
                    CategoryProperty="Label" ValueProperty="Value"
                    Title="@(IsAccessMetric ? "Access Cap" : "Max Slots")" LineType="LineType.Dashed"
                    Stroke="var(--color-text-secondary)">
                    <TooltipTemplate Context="point">
                        <span>@(IsAccessMetric ? "Access Cap" : "Max Slots"): @(point.OriginalValue.ToString("N0"))</span>
                    </TooltipTemplate>
                </RadzenLineSeries>
                <RadzenCategoryAxis />
                <RadzenValueAxis Formatter="@(_axisScaleType == AxisScaleType.Logarithmic ? LogarithmicScaleHelper.FormatAxisLabel : LogarithmicScaleHelper.FormatLinearAxisLabel)" />
                <RadzenLegend Position="LegendPosition.Right" />
            </RadzenChart>
        }
    }
    else
    {
        <SkeletonBlock CssClass="cm-skeleton--heading" />
        <SkeletonBlock CssClass="cm-skeleton--chart" />
    }
</div>

<div class="cm-list-page__table-card" style="margin-top: var(--space-lg);">
    <div class="cm-dashboard__chart-header">
        <span class="cm-dashboard__chart-title">@(IsAccessMetric ? "Client Access Detail" : "Client Allocation Detail")</span>
    </div>
    <RadzenDataGrid @ref="_clientDetailGrid" Data="@_clientDetailRows" TItem="AllocationClientRow"
        AllowSorting="true" AllowPaging="true" PageSize="15"
        PagerHorizontalAlign="HorizontalAlign.Center">
        <Columns>
            <RadzenDataGridColumn TItem="AllocationClientRow" Property="ClientName" Title="Client" />
            <RadzenDataGridColumn TItem="AllocationClientRow" Property="PoolName" Title="Pool" />
            <RadzenDataGridColumn TItem="AllocationClientRow" Title="@(IsAccessMetric ? "Requests" : "Active")" Width="90px">
                <Template Context="row">@row.CurrentValue.ToString("N0")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AllocationClientRow" Title="@(IsAccessMetric ? "Cap (5m)" : "Max")" Width="90px">
                <Template Context="row">@(IsAccessMetric ? FormatCap(row.CapValue) : row.CapValue.ToString("N0"))</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AllocationClientRow" Title="Utilization" Width="180px">
                <Template Context="row">
                    @if (row.CapValue > 0 || !IsAccessMetric)
                    {
                        var pct = row.CapValue > 0
                            ? (int)(row.CurrentValue * 100.0 / row.CapValue) : 0;
                        var barStyle = GetProgressBarStyle(pct);
                        <RadzenProgressBar Value="@pct" Max="100" ShowValue="true"
                            ProgressBarStyle="@barStyle" Style="height: 18px;" />
                    }
                    else
                    {
                        <span>-</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AllocationClientRow" Property="DeniedLast5Min" Title="Denied (5m)" Width="110px" />
            <RadzenDataGridColumn TItem="AllocationClientRow" Title="Status" Width="120px" Sortable="false">
                <Template Context="row">
                    @if (!IsAccessMetric && row.CapValue > 0 && row.CurrentValue >= row.CapValue)
                    {
                        <span class="cm-badge" style="background: #fee2e2; color: #991b1b;">At Capacity</span>
                    }
                    else if (!IsAccessMetric && row.DeniedLast5Min > 0)
                    {
                        <span class="cm-badge" style="background: #fef3c7; color: #92400e;">Contention</span>
                    }
                    else if (IsAccessMetric && row.DeniedLast5Min > 0 && row.CapValue > 0 && row.CurrentValue >= row.CapValue * 0.9)
                    {
                        <span class="cm-badge" style="background: #fee2e2; color: #991b1b;">Hitting Limit</span>
                    }
                    else if (IsAccessMetric && row.DeniedLast5Min > 0)
                    {
                        <span class="cm-badge" style="background: #fef3c7; color: #92400e;">Denied</span>
                    }
                    else if (IsAccessMetric && row.CapValue > 0 && row.CurrentValue >= row.CapValue * 0.9)
                    {
                        <span class="cm-badge" style="background: #fef3c7; color: #92400e;">Near Limit</span>
                    }
                    else
                    {
                        <span class="cm-badge cm-badge--success">@(IsAccessMetric ? "Healthy" : "Available")</span>
                    }
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>

<hr class="cm-monitor__separator" />

<div class="cm-list-page__table-card" style="margin-top: var(--space-lg);">
    <div class="cm-dashboard__chart-header">
        <span class="cm-dashboard__chart-title">All Resource Pools</span>
    </div>
    <RadzenDataGrid @ref="_allPoolsGrid" Data="@_poolSummaryRows" TItem="PoolSummaryRow"
        AllowSorting="true" AllowPaging="true" PageSize="15"
        PagerHorizontalAlign="HorizontalAlign.Center">
        <Columns>
            <RadzenDataGridColumn TItem="PoolSummaryRow" Property="Name" Title="Pool" />
            <RadzenDataGridColumn TItem="PoolSummaryRow" Title="@(IsAccessMetric ? "Requests" : "Active")" Width="100px">
                <Template Context="pool">@pool.CurrentValue.ToString("N0")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="PoolSummaryRow" Title="@(IsAccessMetric ? "Cap (5m)" : "Max")" Width="100px">
                <Template Context="pool">@(IsAccessMetric ? FormatCap(pool.CapValue) : pool.CapValue.ToString("N0"))</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="PoolSummaryRow" Title="@(IsAccessMetric ? "Remaining" : "Available")" Width="110px">
                <Template Context="pool">@(IsAccessMetric ? FormatRemaining(pool.RemainingValue) : (pool.RemainingValue ?? 0).ToString("N0"))</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="PoolSummaryRow" Title="Utilization" Width="200px">
                <Template Context="pool">
                    @if (pool.CapValue > 0 || !IsAccessMetric)
                    {
                        var pct = pool.CapValue > 0
                            ? (int)(pool.CurrentValue * 100.0 / pool.CapValue) : 0;
                        var barStyle = GetProgressBarStyle(pct);
                        <RadzenProgressBar Value="@pct" Max="100" ShowValue="true"
                            ProgressBarStyle="@barStyle" Style="height: 20px;" />
                    }
                    else
                    {
                        <span>-</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="PoolSummaryRow" Title="Status" Width="120px" Sortable="false">
                <Template Context="pool">
                    @if (!IsAccessMetric && pool.RemainingValue == 0)
                    {
                        <span class="cm-badge" style="background: #fee2e2; color: #991b1b;">At Capacity</span>
                    }
                    else if (IsAccessMetric && pool.DeniedLast5Min > 0 && pool.CapValue > 0 && pool.CurrentValue >= pool.CapValue * 0.9)
                    {
                        <span class="cm-badge" style="background: #fee2e2; color: #991b1b;">Hitting Limit</span>
                    }
                    else if (IsAccessMetric && pool.DeniedLast5Min > 0)
                    {
                        <span class="cm-badge" style="background: #fef3c7; color: #92400e;">Denied</span>
                    }
                    else if (IsAccessMetric && pool.CapValue > 0 && pool.CurrentValue >= pool.CapValue * 0.9)
                    {
                        <span class="cm-badge" style="background: #fef3c7; color: #92400e;">Near Limit</span>
                    }
                    else
                    {
                        <span class="cm-badge cm-badge--success">Available</span>
                    }
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>

@code {
    private const string AllPoolsId = "__all__";
    private const string ActiveAllocationsMetricValue = "ActiveAllocations";
    private const string AccessRequestsMetricValue = "AccessRequests";
    private static readonly TimeSpan RecentWindow = TimeSpan.FromMinutes(5);
    private static readonly List<MetricOption> _metricOptions =
    [
        new(ActiveAllocationsMetricValue, "Active Allocations"),
        new(AccessRequestsMetricValue, "Access Requests")
    ];

    private List<ResourcePoolStatisticsResponse> _pools = [];
    private List<PoolSummaryRow> _poolSummaryRows = [];
    private List<NamedItem> _poolOptions = [];
    private List<ClientOption> _clientOptions = [];
    private List<ClientConfiguration> _allClients = [];
    private string _selectedPoolId = AllPoolsId;
    private IEnumerable<string>? _selectedClientIds;

    private bool _loading;
    private string? _error;
    private Timer? _timer;
    private TimeSpan _pollingInterval = TimeSpan.FromSeconds(10);
    private bool _isVisible = true;
    private IJSObjectReference? _visibilityModule;
    private DotNetObjectReference<ActiveAllocations>? _dotNetRef;
    private int _loadVersion;

    private TimeRangePreset _timeRange = TimeRangePreset.Default;
    private AxisScaleType _axisScaleType = AxisScaleType.Linear;
    private string _selectedMetric = ActiveAllocationsMetricValue;

    private List<TargetChartData> _targetCharts = [];
    private List<AllocationClientRow> _clientDetailRows = [];
    private RadzenDataGrid<AllocationClientRow>? _clientDetailGrid;
    private RadzenDataGrid<PoolSummaryRow>? _allPoolsGrid;

    private bool IsAccessMetric => _selectedMetric == AccessRequestsMetricValue;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        try
        {
            _pools = await StatsService.GetResourcePoolStatsAsync();
            var clients = await ClientService.GetAllAsync();
            _allClients = clients;
            _clientOptions = clients
                .Select(c => new ClientOption(c.Id, c.Name))
                .ToList();

            _poolOptions = new List<NamedItem> { new(AllPoolsId, "All Pools") }
                .Concat(_pools.Select(p => new NamedItem(p.ResourcePoolId, p.Name)))
                .ToList();
            _selectedPoolId = AllPoolsId;

            await LoadDataAsync();
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }

        StartTimer();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _visibilityModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/visibility.js");
            _dotNetRef = DotNetObjectReference.Create(this);
            await _visibilityModule.InvokeVoidAsync("register", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnVisibilityChanged(bool visible)
    {
        _isVisible = visible;
        if (visible)
        {
            await LoadDataAsync();
            await InvokeAsync(StateHasChanged);
            StartTimer();
        }
        else
        {
            _timer?.Dispose();
            _timer = null;
        }
    }

    private void StartTimer()
    {
        _timer?.Dispose();
        _timer = new Timer(async _ =>
        {
            await LoadDataAsync();
            await InvokeAsync(StateHasChanged);
        }, null, _pollingInterval, _pollingInterval);
    }

    private Task OnPollingIntervalChanged(PollingIntervalPreset preset)
    {
        _pollingInterval = preset.Interval;
        StartTimer();
        return Task.CompletedTask;
    }

    private Task OnAxisScaleChanged(AxisScaleType scale)
    {
        _axisScaleType = scale;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private List<ChartPoint> TransformPoints(List<ChartPoint> points) =>
        _axisScaleType == AxisScaleType.Logarithmic
            ? points.Select(p => p with { Value = LogarithmicScaleHelper.Transform(p.Value), OriginalValue = p.Value }).ToList()
            : points;

    private async Task OnTimeRangeChanged(TimeRangePreset preset)
    {
        _timeRange = preset;
        await LoadDataAsync();
    }

    private async Task OnMetricChanged()
    {
        _loading = true;
        StateHasChanged();
        await LoadDataAsync();
        _loading = false;
        StateHasChanged();
    }

    private async Task OnFilterChanged()
    {
        _loading = true;
        StateHasChanged();
        await LoadDataAsync();
        _loading = false;
        StateHasChanged();
    }

    private async Task LoadDataAsync()
    {
        var loadVersion = System.Threading.Interlocked.Increment(ref _loadVersion);

        try
        {
            var newPools = await StatsService.GetResourcePoolStatsAsync();

            var now = _timeRange.GetTo();
            var from = _timeRange.GetFrom(now);
            var granularity = _timeRange.Granularity;
            var recentFrom = now.Subtract(RecentWindow);
            var recentTo = now;
            var chartAggregationMode = GetChartAggregationMode();
            var chartTemplate = ChartBucketAggregator.Aggregate([], from, now, mode: chartAggregationMode);
            var chartBucketDuration = chartTemplate.BucketDuration;

            IReadOnlyDictionary<string, GlobalRateLimit> rateLimitLookup = new Dictionary<string, GlobalRateLimit>();
            if (IsAccessMetric)
            {
                rateLimitLookup = (await RateLimitApi.GetByTargetTypeAsync(TargetType.ResourcePool))
                    .ToDictionary(limit => limit.TargetId);
            }

            var visiblePools = _selectedPoolId == AllPoolsId
                ? newPools
                : newPools.Where(p => p.ResourcePoolId == _selectedPoolId).ToList();

            var visiblePoolIds = visiblePools.Select(p => p.ResourcePoolId).ToList();

            if (visiblePoolIds.Count == 0)
            {
                if (loadVersion != _loadVersion)
                {
                    return;
                }

                _targetCharts = [];
                _clientDetailRows.Clear();
                _pools.Clear();
                _pools.AddRange(newPools);
                _poolSummaryRows.Clear();
                _poolSummaryRows.AddRange(BuildPoolSummaryRows(newPools, [], rateLimitLookup));

                if (_clientDetailGrid is not null) await InvokeAsync(_clientDetailGrid.Reload);
                if (_allPoolsGrid is not null) await InvokeAsync(_allPoolsGrid.Reload);

                _error = null;
                return;
            }

            // Batch: one call for all breakdowns
            var breakdowns = await StatsService.GetClientUsageBreakdownAsync(
                "ResourcePool", visiblePoolIds, _selectedClientIds, from, now, granularity);
            var recentBreakdowns = await StatsService.GetClientUsageBreakdownAsync(
                "ResourcePool", visiblePoolIds, _selectedClientIds, recentFrom, recentTo, "FiveMinute");

            var summaryRecentBreakdowns = recentBreakdowns;
            if (IsAccessMetric && _selectedPoolId != AllPoolsId)
            {
                summaryRecentBreakdowns = await StatsService.GetClientUsageBreakdownAsync(
                    "ResourcePool",
                    newPools.Select(pool => pool.ResourcePoolId),
                    _selectedClientIds,
                    recentFrom,
                    recentTo,
                    "FiveMinute");
            }

            var charts = new List<TargetChartData>();
            var rows = new List<AllocationClientRow>();
            var poolRows = BuildPoolSummaryRows(newPools, summaryRecentBreakdowns, rateLimitLookup);
            
            if (_selectedPoolId == AllPoolsId)
            {
                var poolAggregations = new List<ChartBucketAggregator.AggregationResult>();
                var totalMaxSlots = 0;

                // Batch: one call for all histories across all visible pools
                var allHistories = await StatsService.GetHistoricalUsageAsync(
                    "ResourcePool", visiblePoolIds, null, from, now, granularity);

                foreach (var pool in visiblePools)
                {
                    totalMaxSlots += GetPoolChartCap(pool, rateLimitLookup, chartBucketDuration);

                    var breakdown = breakdowns.FirstOrDefault(b => b.TargetId == pool.ResourcePoolId);
                    var history = allHistories.FirstOrDefault(h => h.TargetId == pool.ResourcePoolId);
                    var recentEntries = recentBreakdowns
                        .FirstOrDefault(b => b.TargetId == pool.ResourcePoolId)?.Entries ?? [];

                    var rawPoints = (history?.Points ?? [])
                        .Select(point => new ChartBucketAggregator.RawPoint(point.Timestamp, GetHistoricalPointValue(point)))
                        .ToList();
                    if (rawPoints.Count > 0)
                    {
                        poolAggregations.Add(ChartBucketAggregator.Aggregate(rawPoints, from, now, mode: chartAggregationMode));
                    }

                    foreach (var entry in breakdown?.Entries ?? [])
                    {
                        var recentEntry = recentEntries.FirstOrDefault(e => e.ClientId == entry.ClientId);
                        rows.Add(CreateClientRow(entry.ClientId, entry.ClientName, pool, recentEntry, rateLimitLookup));
                    }
                }

                var referenceBuckets = poolAggregations.FirstOrDefault()?.Buckets
                    ?? chartTemplate.Buckets;
                var sortedPoints = referenceBuckets
                    .Select((bucket, index) => new ChartPoint(
                        bucket.Label,
                        poolAggregations.Sum(aggregation => aggregation.Buckets[index].Value)))
                    .ToList();

                var capPoints = sortedPoints
                    .Select(p => new ChartPoint(p.Label, totalMaxSlots))
                    .ToList();

                charts.Add(new TargetChartData("All Pools",
                    new List<ClientAreaSeries> { new("total", "Total", sortedPoints) },
                    capPoints));
            }
            else
            {
                foreach (var pool in visiblePools)
                {
                    var breakdown = breakdowns.FirstOrDefault(b => b.TargetId == pool.ResourcePoolId);
                    var recentEntries = recentBreakdowns
                        .FirstOrDefault(b => b.TargetId == pool.ResourcePoolId)?.Entries ?? [];
                    var entries = breakdown?.Entries ?? [];
                    var chartCap = GetPoolChartCap(pool, rateLimitLookup, chartBucketDuration);

                    var historiesByClientId = (await StatsService.GetHistoricalUsageByClientAsync(
                            "ResourcePool",
                            new[] { pool.ResourcePoolId },
                            entries.Select(entry => entry.ClientId),
                            from,
                            now,
                            granularity))
                        .ToDictionary(history => history.ClientId);

                    var clientAreas = new List<ClientAreaSeries>();
                    var clientAggregations = new Dictionary<string, ChartBucketAggregator.AggregationResult>();

                    foreach (var entry in entries)
                    {
                        historiesByClientId.TryGetValue(entry.ClientId, out var historyData);
                        var rawPoints = (historyData?.Points ?? [])
                            .Select(point => new ChartBucketAggregator.RawPoint(point.Timestamp, GetHistoricalPointValue(point)))
                            .ToList();

                        if (rawPoints.Count == 0)
                        {
                            continue;
                        }

                        clientAggregations[entry.ClientId] = ChartBucketAggregator.Aggregate(rawPoints, from, now, mode: chartAggregationMode);
                    }

                    var referenceBuckets = clientAggregations.Values.FirstOrDefault()?.Buckets
                        ?? chartTemplate.Buckets;

                    for (var i = 0; i < entries.Count; i++)
                    {
                        var entry = entries[i];
                        if (!clientAggregations.TryGetValue(entry.ClientId, out var aggregation))
                        {
                            continue;
                        }

                        var points = aggregation.Buckets
                            .Select(bucket => new ChartPoint(bucket.Label, bucket.Value))
                            .ToList();

                        clientAreas.Add(new ClientAreaSeries(entry.ClientId, entry.ClientName, points));

                        var recentEntry = recentEntries.FirstOrDefault(e => e.ClientId == entry.ClientId);
                        rows.Add(CreateClientRow(entry.ClientId, entry.ClientName, pool, recentEntry, rateLimitLookup));
                    }

                    var capPoints = referenceBuckets
                        .Select(bucket => new ChartPoint(bucket.Label, chartCap))
                        .ToList();

                    var aggregatedAreas = ChartAggregator.Aggregate(
                        clientAreas.Select(c => new ChartAggregator.AggregatedSeries(
                            c.ClientId, c.ClientName,
                            c.Points.Select(p => new ChartAggregator.AggregatedPoint(p.Label, p.Value)).ToList()
                        )).ToList());

                    clientAreas = aggregatedAreas.Select(a => new ClientAreaSeries(
                        a.Id, a.Name,
                        a.Points.Select(p => new ChartPoint(p.Label, p.Value)).ToList()
                    )).ToList();

                    charts.Add(new TargetChartData(pool.Name, clientAreas, capPoints));
                }
            }

            if (loadVersion != _loadVersion)
            {
                return;
            }

            _targetCharts = charts;
            _clientDetailRows.Clear();
            _clientDetailRows.AddRange(rows);
            _pools.Clear();
            _pools.AddRange(newPools);
            _poolSummaryRows.Clear();
            _poolSummaryRows.AddRange(poolRows);

            if (_clientDetailGrid is not null) await InvokeAsync(_clientDetailGrid.Reload);
            if (_allPoolsGrid is not null) await InvokeAsync(_allPoolsGrid.Reload);

            _error = null;
        }
        catch (HttpRequestException ex)
        {
            if (loadVersion != _loadVersion)
            {
                return;
            }

            _error = $"Unable to load data: {ex.Message}";
        }
    }

    private int GetClientPoolMaxSlots(string clientId, string poolId, int poolMaxSlots)
    {
        var client = _allClients.FirstOrDefault(c => c.Id == clientId);
        if (client?.ResourcePools.TryGetValue(poolId, out var settings) == true)
            return (int)settings.MaxSlots;
        return poolMaxSlots;
    }

    private AllocationClientRow CreateClientRow(
        string clientId,
        string clientName,
        ResourcePoolStatisticsResponse pool,
        ClientUsageEntry? recentEntry,
        IReadOnlyDictionary<string, GlobalRateLimit> rateLimitLookup)
    {
        var currentValue = IsAccessMetric
            ? recentEntry?.GrantedCount ?? 0
            : recentEntry?.ActiveCount ?? 0;
        var capValue = IsAccessMetric
            ? GetEffectiveClientPoolCap(clientId, pool.ResourcePoolId, rateLimitLookup, RecentWindow)
            : GetClientPoolMaxSlots(clientId, pool.ResourcePoolId, pool.MaxSlots);

        return new AllocationClientRow(
            clientId,
            clientName,
            pool.Name,
            currentValue,
            capValue,
            recentEntry?.DeniedCount ?? 0);
    }

    private List<PoolSummaryRow> BuildPoolSummaryRows(
        IEnumerable<ResourcePoolStatisticsResponse> pools,
        IReadOnlyList<TargetClientUsageBreakdownResponse> recentBreakdowns,
        IReadOnlyDictionary<string, GlobalRateLimit> rateLimitLookup)
    {
        if (!IsAccessMetric)
        {
            return pools
                .Select(pool => new PoolSummaryRow(
                    pool.ResourcePoolId,
                    pool.Name,
                    pool.ActiveAllocations,
                    pool.MaxSlots,
                    pool.AvailableSlots,
                    0))
                .ToList();
        }

        var rows = new List<PoolSummaryRow>();
        foreach (var pool in pools)
        {
            var recentEntries = recentBreakdowns
                .FirstOrDefault(breakdown => breakdown.TargetId == pool.ResourcePoolId)?.Entries ?? [];
            var currentValue = recentEntries.Sum(entry => entry.GrantedCount);
            var capValue = GetScaledGlobalPoolCap(pool.ResourcePoolId, rateLimitLookup, RecentWindow);
            long? remainingValue = capValue > 0
                ? Math.Max((long)capValue - currentValue, 0)
                : null;
            var deniedCount = recentEntries.Sum(entry => entry.DeniedCount);

            rows.Add(new PoolSummaryRow(
                pool.ResourcePoolId,
                pool.Name,
                currentValue,
                capValue,
                remainingValue,
                deniedCount));
        }

        return rows;
    }

    private ChartBucketAggregator.AggregationMode GetChartAggregationMode()
        => IsAccessMetric
            ? ChartBucketAggregator.AggregationMode.Sum
            : ChartBucketAggregator.AggregationMode.Latest;

    private double GetHistoricalPointValue(HistoricalUsagePoint point)
        => IsAccessMetric ? point.GrantedCount : point.ActiveCount;

    private int GetPoolChartCap(
        ResourcePoolStatisticsResponse pool,
        IReadOnlyDictionary<string, GlobalRateLimit> rateLimitLookup,
        TimeSpan comparisonWindow)
        => IsAccessMetric
            ? GetScaledGlobalPoolCap(pool.ResourcePoolId, rateLimitLookup, comparisonWindow)
            : pool.MaxSlots;

    private int GetEffectiveClientPoolCap(
        string clientId,
        string poolId,
        IReadOnlyDictionary<string, GlobalRateLimit> globalLimitsByPool,
        TimeSpan comparisonWindow)
    {
        var client = _allClients.FirstOrDefault(c => c.Id == clientId);
        if (client is null)
        {
            return GetScaledGlobalPoolCap(poolId, globalLimitsByPool, comparisonWindow);
        }

        var caps = new List<int>();

        if (client.GlobalRateLimit is not null)
        {
            caps.Add(ScaleRateLimitCap(client.GlobalRateLimit.MaxRequests, client.GlobalRateLimit.Window, comparisonWindow));
        }

        if (!client.ExemptFromGlobalLimits)
        {
            var globalCap = GetScaledGlobalPoolCap(poolId, globalLimitsByPool, comparisonWindow);
            if (globalCap > 0)
            {
                caps.Add(globalCap);
            }
        }

        return caps.Count > 0 ? caps.Min() : 0;
    }

    private static int GetScaledGlobalPoolCap(
        string poolId,
        IReadOnlyDictionary<string, GlobalRateLimit> globalLimitsByPool,
        TimeSpan comparisonWindow)
    {
        return globalLimitsByPool.TryGetValue(poolId, out var globalLimit)
            ? ScaleRateLimitCap(globalLimit.MaxRequests, globalLimit.Window, comparisonWindow)
            : 0;
    }

    private static int ScaleRateLimitCap(int maxRequests, TimeSpan configuredWindow, TimeSpan comparisonWindow)
    {
        if (maxRequests <= 0 || configuredWindow <= TimeSpan.Zero || comparisonWindow <= TimeSpan.Zero)
        {
            return 0;
        }

        var scaled = maxRequests * comparisonWindow.TotalSeconds / configuredWindow.TotalSeconds;
        return scaled > 0
            ? Math.Max(1, (int)Math.Round(scaled, MidpointRounding.AwayFromZero))
            : 0;
    }

    private static ProgressBarStyle GetProgressBarStyle(int percent)
        => percent >= 100 ? ProgressBarStyle.Danger
            : percent >= 75 ? ProgressBarStyle.Warning : ProgressBarStyle.Success;

    private static string FormatCap(int capValue) => capValue > 0 ? capValue.ToString("N0") : "-";

    private static string FormatRemaining(long? remainingValue)
        => remainingValue.HasValue ? remainingValue.Value.ToString("N0") : "-";

    public async ValueTask DisposeAsync()
    {
        _timer?.Dispose();
        if (_visibilityModule is not null)
        {
            await _visibilityModule.InvokeVoidAsync("unregister");
            await _visibilityModule.DisposeAsync();
        }
        _dotNetRef?.Dispose();
    }

    private record NamedItem(string Id, string Name);
    private record MetricOption(string Value, string Name);
    private record ChartPoint(string Label, double Value)
    {
        public double OriginalValue { get; init; } = Value;
    }
    private record ClientOption(string Id, string Name);
    private record ClientAreaSeries(string ClientId, string ClientName, List<ChartPoint> Points);
    private record TargetChartData(
        string TargetName, List<ClientAreaSeries> ClientSeries,
        List<ChartPoint> CapSeries);
    private record AllocationClientRow(
        string ClientId, string ClientName, string PoolName,
        long CurrentValue, int CapValue, long DeniedLast5Min);
    private record PoolSummaryRow(
        string PoolId, string Name, long CurrentValue,
        int CapValue, long? RemainingValue, long DeniedLast5Min);

    private static List<ClientAreaSeries> TransformStackedLogarithmic(List<ClientAreaSeries> series)
    {
        if (series.Count == 0) return series;

        var totals = new Dictionary<string, double>();
        foreach (var s in series)
            foreach (var p in s.Points)
                totals[p.Label] = totals.GetValueOrDefault(p.Label) + p.Value;

        return series.Select(s => new ClientAreaSeries(s.ClientId, s.ClientName,
            s.Points.Select(p =>
            {
                var total = totals.GetValueOrDefault(p.Label);
                if (total <= 0) return p with { Value = 0, OriginalValue = p.Value };
                var logTotal = LogarithmicScaleHelper.Transform(total);
                return p with { Value = (p.Value / total) * logTotal, OriginalValue = p.Value };
            }).ToList()
        )).ToList();
    }
