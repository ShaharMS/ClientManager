@using ClientManager.AdminUI.Models.Allocations
@using ClientManager.AdminUI.Localization

@if (!IsAccessMetric && Row.RemainingValue == 0)
{
    <StatusBadge Text="@L[TermKeys.DeniedOutOfSlots]" Variant="StatusBadgeVariant.Danger" />
}
else if (IsAccessMetric && (Row.DeniedLast5Min > 0
    || (Row.CapValue > 0 && Row.CurrentValue >= Row.CapValue * 0.9)))
{
    <StatusBadge Text="@L[TermKeys.DeniedThrottled]" Variant="StatusBadgeVariant.Warning" />
}
else if (Row.CapValue > 0 && Row.CurrentValue >= Row.CapValue * 0.9)
{
    <StatusBadge Text="@L[TermKeys.StateNearLimit]" Variant="StatusBadgeVariant.Warning" />
}
else
{
    <StatusBadge Text="@L[TermKeys.StateAvailable]" Variant="StatusBadgeVariant.Success" />
}

@code {
    [Parameter, EditorRequired] public PoolSummaryRow Row { get; set; } = null!;
    [Parameter] public bool IsAccessMetric { get; set; }
}
