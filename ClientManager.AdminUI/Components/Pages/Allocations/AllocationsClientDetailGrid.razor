@using ClientManager.AdminUI.Models
@using ClientManager.AdminUI.Models.Allocations
@using ClientManager.AdminUI.Utils

<div class="cm-list-page__table-card" style="margin-top: var(--space-lg);">
    <div class="cm-dashboard__chart-header">
        <span class="cm-dashboard__chart-title">@Title</span>
    </div>
    <RadzenDataGrid @ref="_grid" Data="@Rows" TItem="AllocationClientRow"
        AllowSorting="true" AllowPaging="true" PageSize="15"
        PagerHorizontalAlign="HorizontalAlign.Center">
        <Columns>
            <RadzenDataGridColumn TItem="AllocationClientRow" Property="ClientName" Title="Client"
                CssClass="@(ShowPoolColumn ? "cm-col-id" : "cm-col-label")"
                HeaderCssClass="@(ShowPoolColumn ? "cm-col-id" : "cm-col-label")" />
            @if (ShowPoolColumn)
            {
                <RadzenDataGridColumn TItem="AllocationClientRow" Property="PoolName" Title="Pool"
                    CssClass="cm-col-name" HeaderCssClass="cm-col-name" />
            }
            <RadzenDataGridColumn TItem="AllocationClientRow" Title="@(IsAccessMetric ? "Requests" : "Active")"
                CssClass="cm-col-scalar" HeaderCssClass="cm-col-scalar">
                <Template Context="row">@row.CurrentValue.ToString("N0")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AllocationClientRow" Title="@(IsAccessMetric ? "Cap" : "Max")"
                CssClass="cm-col-scalar" HeaderCssClass="cm-col-scalar">
                <Template Context="row">@(IsAccessMetric ? UtilizationHelper.FormatCap(row.CapValue) : row.CapValue.ToString("N0"))</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AllocationClientRow" Title="Denied"
                CssClass="cm-col-scalar-wide" HeaderCssClass="cm-col-scalar-wide">
                <Template Context="row">
                    <DeniedBreakdownCell Total="@row.DeniedLast5Min"
                        Unauthenticated="@row.DeniedUnauthenticatedCount"
                        Blocked="@row.DeniedBlockedCount"
                        RateLimited="@row.DeniedRateLimitedCount"
                        CapacityLimited="@row.DeniedCapacityLimitedCount"
                        ViewMode="@DeniedViewMode"
                        ShowBreakdown="@ShowDeniedBreakdown" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AllocationClientRow" Title="Utilization"
                CssClass="cm-col-bar" HeaderCssClass="cm-col-bar">
                <Template Context="row">
                    @if (row.CapValue > 0 || !IsAccessMetric)
                    {
                        var pct = row.CapValue > 0 ? (int)(row.CurrentValue * 100.0 / row.CapValue) : 0;
                        <UtilizationProgressBar Percent="@pct" HeightPx="18" />
                    }
                    else
                    {
                        <span>-</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="AllocationClientRow" Title="Status" Sortable="false"
                CssClass="cm-col-status" HeaderCssClass="cm-col-status">
                <Template Context="row">
                    <div class="cm-list-page__actions-cell">
                        <AllocationClientStatusBadge Row="row" IsAccessMetric="IsAccessMetric" />
                    </div>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Client Allocation Detail";
    [Parameter] public bool ShowPoolColumn { get; set; } = true;
    [Parameter] public List<AllocationClientRow> Rows { get; set; } = [];
    [Parameter] public bool IsAccessMetric { get; set; }
    [Parameter] public bool ShowDeniedBreakdown { get; set; }
    [Parameter] public DeniedViewMode DeniedViewMode { get; set; }
    private RadzenDataGrid<AllocationClientRow>? _grid;

    public async Task ReloadAsync(Func<Func<Task>, Task> dispatchAsync)
    {
        if (_grid is not null)
        {
            await dispatchAsync(_grid.Reload);
        }
    }
}
