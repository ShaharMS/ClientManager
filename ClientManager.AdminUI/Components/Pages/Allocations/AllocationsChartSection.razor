@using ClientManager.AdminUI.Models.Allocations
@using ClientManager.AdminUI.Models.Charts

<ChartCard Title="@ChartTitle"
           Spaced="true"
           OnTimeRangeChanged="OnTimeRangeChanged"
           OnPollingIntervalChanged="OnPollingIntervalChanged"
           OnAxisScaleChanged="OnAxisScaleChanged">
    <Filters>
        <ChartCardFilter>
            <RadzenDropDown TValue="MetricOption" Value="@SelectedMetricOption"
                ValueChanged="@OnMetricOptionChanged" AllowClear="false"
                Data="@MetricOptions" TextProperty="Name" />
        </ChartCardFilter>
        <ChartCardFilter>
            <RadzenDropDown TValue="string" Value="@SelectedPoolId"
                ValueChanged="@OnPoolChanged" AllowClear="false"
                Data="@PoolOptions" TextProperty="Name" ValueProperty="Id"
                Placeholder="Select pool..." />
        </ChartCardFilter>
        <ChartCardFilter Clients="true">
            <RadzenDropDown TValue="IEnumerable<string>" Value="@SelectedClientIds"
                ValueChanged="@OnClientsChanged" Multiple="true"
                Data="@ClientOptions" TextProperty="Name" ValueProperty="Id"
                Placeholder="All clients" />
        </ChartCardFilter>
    </Filters>
    <ChildContent>
        <StackedUsageChartList Charts="@TargetCharts" AxisScale="@AxisScaleType"
            CapLineTitle="@CapLineTitle" Loading="@Loading" ShowTitles="false"
            EmptyMessage="No allocation data available" />
    </ChildContent>
</ChartCard>

@code {
    public const string ActiveAllocationsMetric = "ActiveAllocations";
    public const string AccessRequestsMetric = "AccessRequests";

    private static readonly List<MetricOption> DefaultMetricOptions =
    [
        new(ActiveAllocationsMetric, "Active Allocations"),
        new(AccessRequestsMetric, "Access Requests")
    ];

    [Parameter] public string SelectedPoolId { get; set; } = "";
    [Parameter] public EventCallback<string> SelectedPoolIdChanged { get; set; }
    [Parameter] public IEnumerable<string>? SelectedClientIds { get; set; }
    [Parameter] public EventCallback<IEnumerable<string>?> SelectedClientIdsChanged { get; set; }
    [Parameter] public string SelectedMetric { get; set; } = ActiveAllocationsMetric;
    [Parameter] public EventCallback<string> SelectedMetricChanged { get; set; }
    [Parameter] public List<NamedItem> PoolOptions { get; set; } = [];
    [Parameter] public List<NamedItem> ClientOptions { get; set; } = [];
    [Parameter] public List<MetricOption> MetricOptions { get; set; } = DefaultMetricOptions;
    [Parameter] public string ChartTitle { get; set; } = "All Pools - Active Allocations";
    [Parameter] public List<TargetChartData> TargetCharts { get; set; } = [];
    [Parameter] public AxisScaleType AxisScaleType { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback OnFilterChanged { get; set; }
    [Parameter] public EventCallback MetricSelectionChanged { get; set; }
    [Parameter] public EventCallback<ChartTimeRange> OnTimeRangeChanged { get; set; }
    [Parameter] public EventCallback<PollingIntervalPreset> OnPollingIntervalChanged { get; set; }
    [Parameter] public EventCallback<AxisScaleType> OnAxisScaleChanged { get; set; }

    private bool IsAccessMetric => SelectedMetric == AccessRequestsMetric;
    private string CapLineTitle => IsAccessMetric ? "Access Cap" : "Max Slots";

    private MetricOption SelectedMetricOption =>
        MetricOptions.FirstOrDefault(m => m.Value == SelectedMetric)
        ?? DefaultMetricOptions[0];

    private async Task OnPoolChanged(string value)
    {
        await SelectedPoolIdChanged.InvokeAsync(value);
        await OnFilterChanged.InvokeAsync();
    }

    private async Task OnClientsChanged(IEnumerable<string>? value)
    {
        await SelectedClientIdsChanged.InvokeAsync(value);
        await OnFilterChanged.InvokeAsync();
    }

    private async Task OnMetricOptionChanged(MetricOption? value)
    {
        var metric = value?.Value ?? ActiveAllocationsMetric;
        await SelectedMetricChanged.InvokeAsync(metric);
        await MetricSelectionChanged.InvokeAsync();
    }
}
