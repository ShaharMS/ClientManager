@page "/clients"
@inject ClientApiService ClientApi
@inject NavigationManager Nav

<ListPageTemplate @ref="_list" TItem="ClientConfiguration"
    Title="Clients"
    Description="Manage client configurations and access control."
    SearchPlaceholder="Search clients..."
    CreateButtonText="Create Client"
    CreateUrl="/clients/new"
    LoadItemsAsync="LoadClientsAsync"
    SearchableValues="client => [client.Id, client.Name]">
    <ToolbarExtra>
        <RadzenDropDown TValue="bool?" Data="@EnabledFilterOptions"
            TextProperty="Label" ValueProperty="Value"
            Value="@_enabledFilter"
            ValueChanged="OnEnabledFilterChanged"
            Placeholder="All statuses" AllowClear="true"
            Style="width: 160px;" />
    </ToolbarExtra>
    <Columns>
        <RadzenDataGridColumn TItem="ClientConfiguration" Property="Id" Title="ID" Width="150px" />
        <RadzenDataGridColumn TItem="ClientConfiguration" Property="Name" Title="Name" />
        <RadzenDataGridColumn TItem="ClientConfiguration" Title="Status" Width="100px">
            <Template Context="client">
                <StatusBadge Text="@(client.IsEnabled ? "Enabled" : "Disabled")"
                    Variant="@(client.IsEnabled ? StatusBadgeVariant.Success : StatusBadgeVariant.Muted)" />
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ClientConfiguration" Title="Services" Width="100px">
            <Template Context="client">@client.Services.Count</Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ClientConfiguration" Title="Pools" Width="100px">
            <Template Context="client">@client.ResourcePools.Count</Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ClientConfiguration" Title="Actions" Width="160px" Sortable="false">
            <Template Context="client">
                <RadzenButton Icon="edit" Size="ButtonSize.Small" Variant="Variant.Text"
                    Click="@(() => Nav.NavigateTo($"/clients/{client.Id}"))" />
                <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Text"
                    ButtonStyle="ButtonStyle.Danger"
                    Click="@(() => DeleteAsync(client.Id))" />
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</ListPageTemplate>

@code {
    private ListPageTemplate<ClientConfiguration>? _list;
    private bool? _enabledFilter;

    private static readonly List<object> EnabledFilterOptions =
    [
        new { Label = "Enabled", Value = (bool?)true },
        new { Label = "Disabled", Value = (bool?)false }
    ];

    private async Task<IReadOnlyList<ClientConfiguration>> LoadClientsAsync()
    {
        if (_enabledFilter.HasValue)
        {
            var query = new DocumentQuery { Take = 100 }
                .Where(nameof(ClientConfiguration.IsEnabled), ClientManager.Shared.Models.Search.FilterOperator.Equals, _enabledFilter.Value);
            var result = await ClientApi.SearchAsync(query);
            return result.Items.ToList();
        }

        return await ClientApi.GetAllAsync();
    }

    private async Task OnEnabledFilterChanged(bool? value)
    {
        _enabledFilter = value;
        if (_list is not null)
        {
            await _list.ReloadAsync();
        }
    }

    private async Task DeleteAsync(string id)
    {
        await ClientApi.DeleteAsync(id);
        if (_list is not null)
        {
            await _list.ReloadAsync();
        }
    }
}
