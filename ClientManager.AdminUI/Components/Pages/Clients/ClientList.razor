@page "/clients"
@inject ClientApiService ClientApi
@inject NavigationManager Nav
@inject DialogService Dialog
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="cm-page-header">
    <h1>Clients</h1>
    <p>Manage client configurations and access control.</p>
</div>

@if (_actionError is not null)
{
    <div class="alert alert-danger">@_actionError</div>
}

@if (_loading)
{
    <TableSkeleton />
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="cm-list-page__table-card">
        <div class="cm-list-page__header cm-list-page__header--with-filter cm-list-page__header--clients">
            <div class="cm-list-page__filter-field">
                <RadzenDropDown TValue="bool?" Data="@_enabledOptions"
                    TextProperty="Label" ValueProperty="Value"
                    Value="@_enabledFilter"
                    ValueChanged="@((bool? v) => OnEnabledFilterChanged(v))"
                    Placeholder="All statuses" AllowClear="true" />
            </div>
            <div class="cm-list-page__header-actions">
                <RadzenButton Text="Create Client" Icon="add"
                    class="cm-list-page__create-btn"
                    title="Create client"
                    Click="@(() => Nav.NavigateTo("/clients/new"))"
                    ButtonStyle="ButtonStyle.Primary" />
            </div>
            <div class="cm-list-page__search-field">
                <RadzenTextBox Placeholder="Search clients..."
                    Value="@_search"
                    ValueChanged="@((string v) => { _search = v; StateHasChanged(); })"
                    @oninput="@(args => { _search = args.Value?.ToString(); StateHasChanged(); })" />
            </div>
        </div>

        <RadzenDataGrid Data="@_filteredClients" TItem="ClientConfiguration"
            AllowSorting="true" AllowPaging="true" PageSize="@_pageSize"
            PagerHorizontalAlign="HorizontalAlign.Center">
            <Columns>
                <RadzenDataGridColumn TItem="ClientConfiguration" Property="Id" Title="ID" Width="130px" />
                <RadzenDataGridColumn TItem="ClientConfiguration" Property="Name" Title="Name" MinWidth="220px" />
                <RadzenDataGridColumn TItem="ClientConfiguration" Title="Status" Width="130px" TextAlign="TextAlign.Center"
                    CssClass="cm-list-page__col-center cm-list-page__col-status">
                    <Template Context="client">
                        @if (client.IsEnabled)
                        {
                            <span class="cm-badge cm-badge--success">Enabled</span>
                        }
                        else
                        {
                            <span class="cm-badge cm-badge--muted">Disabled</span>
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ClientConfiguration" Title="Services" Width="110px" TextAlign="TextAlign.Center"
                    CssClass="cm-list-page__col-center">
                    <Template Context="client">@client.Services.Count</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ClientConfiguration" Title="Pools" Width="100px" TextAlign="TextAlign.Center"
                    CssClass="cm-list-page__col-center">
                    <Template Context="client">@client.ResourcePools.Count</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ClientConfiguration" Title="Actions" Width="120px" Sortable="false"
                    TextAlign="TextAlign.Center" CssClass="cm-list-page__col-center cm-list-page__col-actions">
                    <Template Context="client">
                        <div class="cm-list-page__actions-cell">
                        <RadzenButton Icon="edit" Size="ButtonSize.Small" Variant="Variant.Text"
                            title="Edit client"
                            Click="@(() => Nav.NavigateTo($"/clients/{client.Id}"))" />
                        @if (client.IsEnabled)
                        {
                            <RadzenButton Icon="block" Size="ButtonSize.Small" Variant="Variant.Text"
                                ButtonStyle="ButtonStyle.Warning" title="Disable client"
                                Click="@(async () => await ToggleEnabledAsync(client))" />
                        }
                        else
                        {
                            <RadzenButton Icon="lock_open" Size="ButtonSize.Small" Variant="Variant.Text"
                                ButtonStyle="ButtonStyle.Success" title="Enable client"
                                Click="@(async () => await ToggleEnabledAsync(client))" />
                        }
                        <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Text"
                            ButtonStyle="ButtonStyle.Danger" title="Delete client"
                            Click="@(async () => await DeleteAsync(client.Id))" />
                        </div>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private string? _actionError;
    private string? _search;
    private bool? _enabledFilter;
    private List<ClientConfiguration> _clients = [];
    private int _pageSize = 10;
    private IJSObjectReference? _tableJs;
    private DotNetObjectReference<ClientList>? _selfRef;

    private static readonly List<object> _enabledOptions =
    [
        new { Label = "Enabled", Value = (bool?)true },
        new { Label = "Disabled", Value = (bool?)false }
    ];

    private IEnumerable<ClientConfiguration> _filteredClients =>
        string.IsNullOrWhiteSpace(_search)
            ? _clients
            : _clients.Where(c =>
                c.Id.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                c.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _tableJs = await JS.InvokeAsync<IJSObjectReference>("import", "./js/table.js");
            _selfRef = DotNetObjectReference.Create(this);
            await _tableJs.InvokeVoidAsync("register", _selfRef);
            await RecalculatePageSizeAsync();
        }
    }

    [JSInvokable]
    public async Task OnWindowResize() => await RecalculatePageSizeAsync();

    private async Task RecalculatePageSizeAsync()
    {
        _pageSize = await _tableJs!.InvokeAsync<int>("getPageSize", 45);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_tableJs is not null)
        {
            await _tableJs.InvokeVoidAsync("unregister");
            await _tableJs.DisposeAsync();
        }
        _selfRef?.Dispose();
    }

    private async Task LoadAsync()
    {
        try
        {
            if (_enabledFilter.HasValue)
            {
                var query = new DocumentQuery { Take = 100 }
                    .Where(nameof(ClientConfiguration.IsEnabled), ClientManager.Shared.Models.Search.FilterOperator.Equals, _enabledFilter.Value);
                var result = await ClientApi.SearchAsync(query);
                _clients = result.Items.ToList();
            }
            else
            {
                _clients = await ClientApi.GetAllAsync();
            }
            _error = null;
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnEnabledFilterChanged(bool? value)
    {
        _enabledFilter = value;
        _loading = true;
        await LoadAsync();
    }

    private Task ToggleEnabledAsync(ClientConfiguration client) =>
        ListToggleEnabledSupport.ExecuteAsync(
            Dialog,
            "client",
            client.Id,
            client.IsEnabled,
            async () =>
            {
                var updated = client with { IsEnabled = !client.IsEnabled };
                await ClientApi.UpdateAsync(client.Id, updated);
            },
            LoadAsync,
            message => _actionError = message,
            StateHasChanged);

    private Task DeleteAsync(string id) =>
        ListDeleteSupport.ExecuteAsync(
            Dialog,
            "client",
            id,
            () => ClientApi.DeleteAsync(id),
            LoadAsync,
            message => _actionError = message,
            StateHasChanged);
}
