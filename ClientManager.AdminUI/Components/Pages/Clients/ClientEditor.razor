@page "/clients/new"
@page "/clients/{Id}"
@using ClientManager.AdminUI.Models.Client

<EditorPageTemplate TModel="ClientFormModel"
    Id="@Id" IsNew="@_isNew"
    BackPath="clients" BackLinkText="@L["Pages.Clients.BackLink"]"
    CreateTitle="@L["Pages.Clients.CreateTitle"]" CreateDescription="@L["Pages.Clients.CreateDescription"]"
    EditTitle="@(_isNew ? null : string.Format(L["Pages.Clients.EditTitle"], Id))"
    EditTitlePrefix="" EditDescription="@L["Pages.Clients.EditDescription"]"
    FormName="clientForm" Model="@_model" Loading="@_loading" Error="@_error"
    OnValidSubmit="SaveAsync">
    <ClientBasicConfigCard Model="_model" IsNew="_isNew" ExistingClientIds="_existingClientIds" />

    <ClientGlobalRateLimitCard HasRateLimit="_hasGlobalRateLimit"
        HasRateLimitChanged="OnGlobalRateLimitToggled"
        RateLimit="_globalRateLimit"
        WindowSeconds="_globalRateLimitWindowSeconds"
        WindowSecondsChanged="v => _globalRateLimitWindowSeconds = v" />

    <ClientServiceAccessCard Entries="_serviceEntries" ServiceIds="_serviceIds" />
</EditorPageTemplate>
