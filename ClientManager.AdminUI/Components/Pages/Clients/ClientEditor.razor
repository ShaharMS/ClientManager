@page "/clients/new"
@page "/clients/{Id}"
@using ClientManager.AdminUI.Models.Client

<div style="margin-bottom: var(--space-md);">
    <RadzenLink Path="clients" Text="← Back to Clients" Style="font-size: var(--font-size-sm);" />
</div>

<div class="cm-page-header">
    <h1>@(_isNew ? "Create Client" : $"Edit Client: {Id}")</h1>
    <p>@(_isNew ? "Configure a new client." : "Update client configuration.")</p>
</div>

@if (_loading)
{
    <FormSkeleton />
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="cm-editor">
        <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="clientForm">
            <DataAnnotationsValidator />

            <ClientBasicConfigCard Model="_model" IsNew="_isNew" ExistingClientIds="_existingClientIds" />

            <ClientGlobalRateLimitCard HasRateLimit="_hasGlobalRateLimit"
                HasRateLimitChanged="OnGlobalRateLimitToggled"
                RateLimit="_globalRateLimit"
                WindowSeconds="_globalRateLimitWindowSeconds"
                WindowSecondsChanged="v => _globalRateLimitWindowSeconds = v" />

            <ClientServiceAccessCard Entries="_serviceEntries" ServiceIds="_serviceIds" />

            <ClientResourcePoolsCard Entries="_poolEntries" PoolIds="_poolIds" />

            <div class="cm-editor__actions">
                <RadzenButton Text="Save" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary" />
                <RadzenButton Text="Cancel" Variant="Variant.Outlined" Click="@(() => Nav.NavigateTo("/clients"))" />
            </div>
        </EditForm>
    </div>
}
