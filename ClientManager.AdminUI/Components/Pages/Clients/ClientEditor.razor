@page "/clients/new"
@page "/clients/{Id}"
@inject ClientApiService ClientApi
@inject ServiceApiService ServiceApi
@inject ResourcePoolApiService PoolApi
@inject NavigationManager Nav

<div style="margin-bottom: var(--space-md);">
    <RadzenLink Path="clients" Text="← Back to Clients" Style="font-size: var(--font-size-sm);" />
</div>

<div class="cm-page-header">
    <h1>@(_isNew ? "Create Client" : $"Edit Client: {Id}")</h1>
    <p>@(_isNew ? "Configure a new client." : "Update client configuration.")</p>
</div>

@if (_loading)
{
    <FormSkeleton />
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="cm-editor">
        <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="clientForm">
            <DataAnnotationsValidator />

            @* Card 1 - Basic Configuration *@
            <div class="cm-editor__card">
                <div class="cm-editor__section-title">Basic Configuration</div>
                <div class="cm-editor__field">
                    <label>Client ID</label>
                    <EntityIdInput @bind-Value="_model.Id" Suggestions="_existingClientIds"
                        Mode="EntityIdInputMode.Unique" EntityName="client" Disabled="@(!_isNew)" />
                </div>
                <div class="cm-editor__field">
                    <label>Name</label>
                    <RadzenTextBox @bind-Value="_model.Name" Style="width: 100%;" />
                </div>
                <div class="cm-editor__field">
                    <label>Enabled</label>
                    <RadzenSwitch @bind-Value="_model.IsEnabled" />
                </div>
                <div class="cm-editor__field">
                    <label>Contributes to Global Limits</label>
                    <RadzenSwitch @bind-Value="_model.ContributesToGlobalLimits" />
                </div>
                <div class="cm-editor__field">
                    <label>Exempt from Global Limits</label>
                    <RadzenSwitch @bind-Value="_model.ExemptFromGlobalLimits" />
                </div>
            </div>

            @* Card 2 - Global Rate Limit *@
            <div class="cm-editor__card">
                <div class="cm-editor__nested-header">
                    <div class="cm-editor__section-title" style="margin-bottom: 0; border-bottom: none; padding-bottom: 0;">Global Rate Limit</div>
                    @if (_hasGlobalRateLimit)
                    {
                        <RadzenButton Text="Remove" Icon="delete" Size="ButtonSize.Small" Variant="Variant.Text"
                            ButtonStyle="ButtonStyle.Danger" Click="@(() => RemoveGlobalRateLimit())" />
                    }
                    else
                    {
                        <RadzenButton Text="Add" Icon="add" Size="ButtonSize.Small" Variant="Variant.Outlined"
                            Click="@(() => AddGlobalRateLimit())" />
                    }
                </div>
                @if (_hasGlobalRateLimit)
                {
                    <div class="cm-editor__field">
                        <label>Strategy</label>
                        <RadzenDropDown TValue="RateLimitStrategy" @bind-Value="_globalRateLimit.Strategy"
                            Data="@(Enum.GetValues<RateLimitStrategy>())" Style="width: 100%;"
                            Change="@(_ => StateHasChanged())" />
                    </div>
                    <div class="cm-editor__field">
                        <label>Max Requests</label>
                        <RadzenNumeric TValue="int" @bind-Value="_globalRateLimit.MaxRequests" Style="width: 100%;" />
                    </div>
                    <div class="cm-editor__field">
                        <label>Window (seconds)</label>
                        <RadzenNumeric TValue="double" @bind-Value="_globalRateLimitWindowSeconds" Style="width: 100%;" />
                    </div>
                    @if (_globalRateLimit.Strategy == RateLimitStrategy.TokenBucket)
                    {
                        <div class="cm-editor__field">
                            <label>Tokens Per Refill</label>
                            <RadzenNumeric TValue="int?" @bind-Value="_globalRateLimit.TokensPerRefill" Style="width: 100%;" />
                        </div>
                    }
                }
            </div>

            @* Card 3 - Service Access *@
            <div class="cm-editor__card">
                <div class="cm-editor__nested-header">
                    <div class="cm-editor__section-title" style="margin-bottom: 0; border-bottom: none; padding-bottom: 0;">Service Access (@_serviceEntries.Count)</div>
                    <RadzenButton Text="Add Service" Icon="add" Size="ButtonSize.Small" Variant="Variant.Outlined"
                        Click="@(() => AddServiceEntry())" />
                </div>
                @if (_serviceEntries.Count == 0)
                {
                    <p style="color: var(--color-text-muted);">No service access entries configured.</p>
                }
                @foreach (var entry in _serviceEntries)
                {
                    <div class="cm-editor__nested-item">
                        <div class="cm-editor__nested-header">
                            <strong style="font-size: var(--font-size-sm);">@(string.IsNullOrEmpty(entry.ServiceId) ? "New Service" : entry.ServiceId)</strong>
                            <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Text"
                                ButtonStyle="ButtonStyle.Danger" Click="@(() => RemoveServiceEntry(entry))" />
                        </div>
                        <div class="cm-editor__field">
                            <label>Service ID</label>
                            <EntityIdInput @bind-Value="entry.ServiceId" Suggestions="_serviceIds"
                                Mode="EntityIdInputMode.Reference" EntityName="service" />
                        </div>
                        <div class="cm-editor__field">
                            <label>Allowed</label>
                            <RadzenSwitch @bind-Value="entry.IsAllowed" />
                        </div>
                        <div class="cm-editor__field">
                            <label>Has Rate Limit</label>
                            <RadzenSwitch @bind-Value="entry.HasRateLimit" />
                        </div>
                        @if (entry.HasRateLimit)
                        {
                            <div class="cm-editor__field">
                                <label>Strategy</label>
                                <RadzenDropDown TValue="RateLimitStrategy" @bind-Value="entry.RateLimitStrategy"
                                    Data="@(Enum.GetValues<RateLimitStrategy>())" Style="width: 100%;"
                                    Change="@(_ => StateHasChanged())" />
                            </div>
                            <div class="cm-editor__field">
                                <label>Max Requests</label>
                                <RadzenNumeric TValue="int" @bind-Value="entry.RateLimitMaxRequests" Style="width: 100%;" />
                            </div>
                            <div class="cm-editor__field">
                                <label>Window (seconds)</label>
                                <RadzenNumeric TValue="double" @bind-Value="entry.RateLimitWindowSeconds" Style="width: 100%;" />
                            </div>
                            @if (entry.RateLimitStrategy == RateLimitStrategy.TokenBucket)
                            {
                                <div class="cm-editor__field">
                                    <label>Tokens Per Refill</label>
                                    <RadzenNumeric TValue="int?" @bind-Value="entry.RateLimitTokensPerRefill" Style="width: 100%;" />
                                </div>
                            }
                        }
                    </div>
                }
            </div>

            @* Card 4 - Resource Pools *@
            <div class="cm-editor__card">
                <div class="cm-editor__nested-header">
                    <div class="cm-editor__section-title" style="margin-bottom: 0; border-bottom: none; padding-bottom: 0;">Resource Pools (@_poolEntries.Count)</div>
                    <RadzenButton Text="Add Pool" Icon="add" Size="ButtonSize.Small" Variant="Variant.Outlined"
                        Click="@(() => AddPoolEntry())" />
                </div>
                @if (_poolEntries.Count == 0)
                {
                    <p style="color: var(--color-text-muted);">No resource pool entries configured.</p>
                }
                @foreach (var entry in _poolEntries)
                {
                    <div class="cm-editor__nested-item">
                        <div class="cm-editor__nested-header">
                            <strong style="font-size: var(--font-size-sm);">@(string.IsNullOrEmpty(entry.PoolId) ? "New Pool" : entry.PoolId)</strong>
                            <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Text"
                                ButtonStyle="ButtonStyle.Danger" Click="@(() => RemovePoolEntry(entry))" />
                        </div>
                        <div class="cm-editor__field">
                            <label>Pool ID</label>
                            <EntityIdInput @bind-Value="entry.PoolId" Suggestions="_poolIds"
                                Mode="EntityIdInputMode.Reference" EntityName="resource pool" />
                        </div>
                        <div class="cm-editor__field">
                            <label>Max Slots</label>
                            <RadzenNumeric TValue="uint" @bind-Value="entry.MaxSlots" Style="width: 100%;" />
                        </div>
                    </div>
                }
            </div>

            <div class="cm-editor__actions">
                <RadzenButton Text="Save" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary" />
                <RadzenButton Text="Cancel" Variant="Variant.Outlined" Click="@(() => Nav.NavigateTo("/clients"))" />
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter] public string? Id { get; set; }
    private bool _isNew => string.IsNullOrEmpty(Id) || Id == "new";
    private bool _loading = true;
    private string? _error;

    private ClientFormModel _model = new();
    private bool _hasGlobalRateLimit;
    private RateLimitFormModel _globalRateLimit = new();
    private double _globalRateLimitWindowSeconds = 60;
    private List<ServiceEntryModel> _serviceEntries = [];
    private List<PoolEntryModel> _poolEntries = [];
    private List<string> _existingClientIds = [];
    private List<string> _serviceIds = [];
    private List<string> _poolIds = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _existingClientIds = (await ClientApi.GetAllAsync()).Select(c => c.Id).ToList();
            _serviceIds = (await ServiceApi.GetAllAsync()).Select(s => s.Id).ToList();
            _poolIds = (await PoolApi.GetAllAsync()).Select(p => p.Id).ToList();

            if (!_isNew)
            {
                var config = await ClientApi.GetByIdAsync(Id!);
                if (config is null)
                {
                    _error = $"Client '{Id}' not found.";
                    return;
                }
                _model = new ClientFormModel
                {
                    Id = config.Id,
                    Name = config.Name,
                    IsEnabled = config.IsEnabled,
                    ContributesToGlobalLimits = config.ContributesToGlobalLimits,
                    ExemptFromGlobalLimits = config.ExemptFromGlobalLimits
                };

                if (config.GlobalRateLimit is not null)
                {
                    _hasGlobalRateLimit = true;
                    _globalRateLimit = new RateLimitFormModel
                    {
                        Strategy = config.GlobalRateLimit.Strategy,
                        MaxRequests = config.GlobalRateLimit.MaxRequests,
                        TokensPerRefill = config.GlobalRateLimit.TokensPerRefill
                    };
                    _globalRateLimitWindowSeconds = config.GlobalRateLimit.Window.TotalSeconds;
                }

                _serviceEntries = config.Services.Select(kvp => new ServiceEntryModel
                {
                    ServiceId = kvp.Key,
                    IsAllowed = kvp.Value.IsAllowed,
                    ContributesToGlobalLimit = kvp.Value.ContributesToGlobalLimit,
                    ExemptFromGlobalLimit = kvp.Value.ExemptFromGlobalLimit,
                    HasRateLimit = kvp.Value.RateLimit is not null,
                    RateLimitStrategy = kvp.Value.RateLimit?.Strategy ?? RateLimitStrategy.FixedWindow,
                    RateLimitMaxRequests = kvp.Value.RateLimit?.MaxRequests ?? 100,
                    RateLimitWindowSeconds = kvp.Value.RateLimit?.Window.TotalSeconds ?? 60,
                    RateLimitTokensPerRefill = kvp.Value.RateLimit?.TokensPerRefill
                }).ToList();

                _poolEntries = config.ResourcePools.Select(kvp => new PoolEntryModel
                {
                    PoolId = kvp.Key,
                    MaxSlots = kvp.Value.MaxSlots
                }).ToList();
            }
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        var config = new ClientConfiguration
        {
            Id = _model.Id,
            Name = _model.Name,
            IsEnabled = _model.IsEnabled,
            ContributesToGlobalLimits = _model.ContributesToGlobalLimits,
            ExemptFromGlobalLimits = _model.ExemptFromGlobalLimits,
            GlobalRateLimit = _hasGlobalRateLimit
                ? new ClientRateLimit
                {
                    Strategy = _globalRateLimit.Strategy,
                    MaxRequests = _globalRateLimit.MaxRequests,
                    Window = TimeSpan.FromSeconds(_globalRateLimitWindowSeconds),
                    TokensPerRefill = _globalRateLimit.Strategy == RateLimitStrategy.TokenBucket
                        ? _globalRateLimit.TokensPerRefill : null
                }
                : null,
            Services = _serviceEntries.ToDictionary(
                e => e.ServiceId,
                e => new ServiceAccessSettings
                {
                    IsAllowed = e.IsAllowed,
                    ContributesToGlobalLimit = e.ContributesToGlobalLimit,
                    ExemptFromGlobalLimit = e.ExemptFromGlobalLimit,
                    RateLimit = e.HasRateLimit
                        ? new ClientRateLimit
                        {
                            Strategy = e.RateLimitStrategy,
                            MaxRequests = e.RateLimitMaxRequests,
                            Window = TimeSpan.FromSeconds(e.RateLimitWindowSeconds),
                            TokensPerRefill = e.RateLimitStrategy == RateLimitStrategy.TokenBucket
                                ? e.RateLimitTokensPerRefill : null
                        }
                        : null
                }),
            ResourcePools = _poolEntries.ToDictionary(
                e => e.PoolId,
                e => new ResourcePoolSettings { MaxSlots = e.MaxSlots })
        };

        try
        {
            if (_isNew)
                await ClientApi.CreateAsync(config);
            else
                await ClientApi.UpdateAsync(Id!, config);

            Nav.NavigateTo("/clients");
        }
        catch (HttpRequestException ex)
        {
            _error = $"Save failed: {ex.Message}";
        }
    }

    private void AddGlobalRateLimit()
    {
        _hasGlobalRateLimit = true;
        _globalRateLimit = new RateLimitFormModel();
        _globalRateLimitWindowSeconds = 60;
    }

    private void RemoveGlobalRateLimit() => _hasGlobalRateLimit = false;
    private void AddServiceEntry() => _serviceEntries.Add(new ServiceEntryModel());
    private void RemoveServiceEntry(ServiceEntryModel entry) => _serviceEntries.Remove(entry);
    private void AddPoolEntry() => _poolEntries.Add(new PoolEntryModel());
    private void RemovePoolEntry(PoolEntryModel entry) => _poolEntries.Remove(entry);

    private class ClientFormModel
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public bool IsEnabled { get; set; } = true;
        public bool ContributesToGlobalLimits { get; set; } = true;
        public bool ExemptFromGlobalLimits { get; set; }
    }

    private class RateLimitFormModel
    {
        public RateLimitStrategy Strategy { get; set; }
        public int MaxRequests { get; set; } = 100;
        public int? TokensPerRefill { get; set; }
    }

    private class ServiceEntryModel
    {
        public string ServiceId { get; set; } = string.Empty;
        public bool IsAllowed { get; set; } = true;
        public bool? ContributesToGlobalLimit { get; set; }
        public bool? ExemptFromGlobalLimit { get; set; }
        public bool HasRateLimit { get; set; }
        public RateLimitStrategy RateLimitStrategy { get; set; }
        public int RateLimitMaxRequests { get; set; } = 100;
        public double RateLimitWindowSeconds { get; set; } = 60;
        public int? RateLimitTokensPerRefill { get; set; }
    }

    private class PoolEntryModel
    {
        public string PoolId { get; set; } = string.Empty;
        public uint MaxSlots { get; set; } = 1;
    }
}
