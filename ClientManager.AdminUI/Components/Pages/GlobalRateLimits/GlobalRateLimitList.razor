@page "/global-rate-limits"
@inject GlobalRateLimitApiService RateLimitApi
@inject NavigationManager Nav

<h1>Global Rate Limits</h1>
<button class="btn btn-primary mb-3" @onclick="Create">Create Global Rate Limit</button>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th><th>Target ID</th><th>Target Type</th>
                <th>Strategy</th><th>Max Requests</th><th>Window</th><th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var limit in _limits)
            {
                <tr>
                    <td>@limit.Id</td>
                    <td>@limit.TargetId</td>
                    <td>@limit.TargetType</td>
                    <td>@limit.Strategy</td>
                    <td>@limit.MaxRequests</td>
                    <td>@limit.Window.TotalSeconds s</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(limit.Id)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(limit.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private string? _error;
    private List<GlobalRateLimit> _limits = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            _limits = await RateLimitApi.GetAllAsync();
            _error = null;
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void Create() => Nav.NavigateTo("/global-rate-limits/new");
    private void Edit(string id) => Nav.NavigateTo($"/global-rate-limits/{id}");

    private async Task DeleteAsync(string id)
    {
        await RateLimitApi.DeleteAsync(id);
        await LoadAsync();
    }
}
