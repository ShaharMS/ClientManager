@page "/rate-limits/new"
@page "/rate-limits/{Id}"
@inject GlobalRateLimitApiService RateLimitApi
@inject ServiceApiService ServiceApi
@inject NavigationManager Nav

<EditorPageTemplate TModel="RateLimitFormModel"
    Id="@Id" IsNew="@_isNew"
    BackPath="rate-limits" BackLinkText="← Back to Rate Limits"
    CreateTitle="Create Rate Limit" CreateDescription="Define a rate limit for a service endpoint."
    EditTitlePrefix="Edit Rate Limit: " EditDescription="Update rate limit configuration."
    FormName="rateLimitForm" Model="@_model" Loading="@_loading" Error="@_error"
    OnValidSubmit="SaveAsync">
    <div class="cm-editor__field">
        <label>Rate Limit ID</label>
        <EntityIdInput @bind-Value="_model.Id" Suggestions="_existingIds"
            Mode="EntityIdInputMode.Unique" EntityName="rate limit" Disabled="@(!_isNew)" />
    </div>
    <div class="cm-editor__field">
        <label>Service</label>
        <EntityIdInput @bind-Value="_model.TargetId" Suggestions="_serviceIds"
            Mode="EntityIdInputMode.Reference" EntityName="service" />
    </div>
    <div class="cm-editor__field">
        <label>Strategy</label>
        <RadzenDropDown TValue="RateLimitStrategy" @bind-Value="_model.Strategy"
            Data="@(Enum.GetValues<RateLimitStrategy>())" Style="width: 100%;"
            Change="@(_ => StateHasChanged())" />
    </div>
    <div class="cm-editor__field">
        <label>Max Requests</label>
        <RadzenNumeric TValue="int" @bind-Value="_model.MaxRequests" Style="width: 100%;" />
    </div>
    <div class="cm-editor__field">
        <label>Window</label>
        <DurationInput @bind-Value="_model.WindowSeconds" />
    </div>
    @if (_model.Strategy == RateLimitStrategy.TokenBucket)
    {
        <div class="cm-editor__field">
            <label>Tokens Per Refill</label>
            <RadzenNumeric TValue="int?" @bind-Value="_model.TokensPerRefill" Style="width: 100%;" />
        </div>
    }
</EditorPageTemplate>

@code {
    [Parameter] public string? Id { get; set; }
    private bool _isNew => string.IsNullOrEmpty(Id) || Id == "new";
    private bool _loading = true;
    private string? _error;
    private RateLimitFormModel _model = new() { TargetType = TargetType.Service };
    private List<string> _existingIds = [];
    private List<string> _serviceIds = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _existingIds = (await RateLimitApi.GetAllAsync()).Select(l => l.Id).ToList();
            _serviceIds = (await ServiceApi.GetAllAsync()).Select(s => s.Id).ToList();

            if (!_isNew)
            {
                var limit = await RateLimitApi.GetByIdAsync(Id!);
                if (limit is null)
                {
                    _error = $"Rate limit '{Id}' not found.";
                    return;
                }

                _model = new RateLimitFormModel
                {
                    Id = limit.Id,
                    TargetId = limit.TargetId,
                    TargetType = TargetType.Service,
                    Strategy = limit.Strategy,
                    MaxRequests = limit.MaxRequests,
                    WindowSeconds = limit.Window.TotalSeconds,
                    TokensPerRefill = limit.TokensPerRefill
                };
            }
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        var limit = new GlobalRateLimit
        {
            Id = _model.Id,
            TargetId = _model.TargetId,
            TargetType = TargetType.Service,
            Strategy = _model.Strategy,
            MaxRequests = _model.MaxRequests,
            Window = TimeSpan.FromSeconds(_model.WindowSeconds),
            TokensPerRefill = _model.Strategy == RateLimitStrategy.TokenBucket
                ? _model.TokensPerRefill : null
        };

        try
        {
            if (_isNew)
            {
                await RateLimitApi.CreateAsync(limit);
            }
            else
            {
                await RateLimitApi.UpdateAsync(Id!, limit);
            }

            Nav.NavigateTo("/rate-limits");
        }
        catch (HttpRequestException ex)
        {
            _error = $"Save failed: {ex.Message}";
        }
    }
}
