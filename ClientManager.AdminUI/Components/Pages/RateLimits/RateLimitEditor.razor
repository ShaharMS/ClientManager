@page "/rate-limits/new"
@page "/rate-limits/{Id}"
@inject GlobalRateLimitApiService RateLimitApi
@inject ServiceApiService ServiceApi
@inject NavigationManager Nav

<EditorPageTemplate TModel="RateLimitFormModel"
    Id="@Id" IsNew="@_isNew"
    BackPath="rate-limits" BackLinkText="← Back to Rate Limits"
    CreateTitle="Create Rate Limit" CreateDescription="@_createDescription"
    EditTitle="@_editTitle" EditTitlePrefix="Edit Rate Limit: " EditDescription="Update rate limit configuration."
    FormName="rateLimitForm" Model="@_model" Loading="@_loading" Error="@_error"
    SubmitDisabled="@_submitDisabled" SubmitTitle="@_submitTitle"
    OnValidSubmit="SaveAsync">
    @if (_saveError is not null)
    {
        <div class="alert alert-danger" style="margin-bottom: var(--space-md);">@_saveError</div>
    }
    <div class="cm-editor__field">
        <label>Service</label>
        <EntityIdInput @bind-Value="_model.TargetId" Suggestions="_serviceIds"
            DisabledSuggestions="@_limitedServiceIds"
            DisabledSuggestionMessage="Already has a rate limit"
            Mode="EntityIdInputMode.Reference" EntityName="service"
            Disabled="@(_isNew && !_canCreate)" />
    </div>
    <div class="cm-editor__field">
        <label>Strategy</label>
        <RadzenDropDown TValue="RateLimitStrategy" @bind-Value="_model.Strategy"
            Data="@(Enum.GetValues<RateLimitStrategy>())" Style="width: 100%;"
            Change="@(_ => StateHasChanged())" />
    </div>
    <div class="cm-editor__field">
        <label>Max Requests</label>
        <RadzenNumeric TValue="int" @bind-Value="_model.MaxRequests" Style="width: 100%;" />
    </div>
    <div class="cm-editor__field">
        <label>Window</label>
        <DurationInput @bind-Value="_model.WindowSeconds" />
    </div>
    @if (_model.Strategy == RateLimitStrategy.TokenBucket)
    {
        <div class="cm-editor__field">
            <label>Tokens Per Refill</label>
            <RadzenNumeric TValue="int?" @bind-Value="_model.TokensPerRefill" Style="width: 100%;" />
        </div>
    }
</EditorPageTemplate>

@code {
    private const string AllServicesLimitedTooltip = "Every service already has a rate limit.";

    [Parameter] public string? Id { get; set; }
    private bool _isNew => string.IsNullOrEmpty(Id) || Id == "new";
    private bool _loading = true;
    private string? _error;
    private string? _saveError;
    private string _createDescription = "Define a rate limit for a service endpoint.";
    private string? _editTitle;
    private RateLimitFormModel _model = new() { TargetType = TargetType.Service };
    private List<string> _serviceIds = [];
    private List<string> _limitedServiceIds = [];
    private bool _canCreate;
    private bool _submitDisabled;
    private string? _submitTitle;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _serviceIds = (await ServiceApi.GetAllAsync()).Select(s => s.Id).ToList();
            var existingLimits = await RateLimitApi.GetByTargetTypeAsync(TargetType.Service);
            var limitedTargets = existingLimits
                .Select(l => l.TargetId)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            if (!_isNew)
            {
                var limit = await RateLimitApi.GetByIdAsync(Id!);
                if (limit is null)
                {
                    _error = "Rate limit not found.";
                    return;
                }

                _editTitle = $"Edit Rate Limit: {limit.TargetId}";

                limitedTargets.Remove(limit.TargetId);

                _model = new RateLimitFormModel
                {
                    Id = limit.Id,
                    TargetId = limit.TargetId,
                    TargetType = TargetType.Service,
                    Strategy = limit.Strategy,
                    MaxRequests = limit.MaxRequests,
                    WindowSeconds = limit.Window.TotalSeconds,
                    TokensPerRefill = limit.TokensPerRefill
                };
            }

            _limitedServiceIds = _serviceIds
                .Where(id => limitedTargets.Contains(id))
                .ToList();

            if (_isNew)
            {
                _model.TargetId = _serviceIds.FirstOrDefault(id => !limitedTargets.Contains(id)) ?? string.Empty;
                RefreshCreateState();
            }
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void RefreshCreateState()
    {
        if (!_isNew)
        {
            _submitDisabled = false;
            _submitTitle = null;
            return;
        }

        _canCreate = _serviceIds.Any(id => !_limitedServiceIds.Contains(id, StringComparer.OrdinalIgnoreCase));
        _submitDisabled = !_canCreate;
        _submitTitle = _canCreate ? null : AllServicesLimitedTooltip;
        _createDescription = _canCreate
            ? "Define a rate limit for a service endpoint."
            : AllServicesLimitedTooltip;
    }

    private async Task SaveAsync()
    {
        if (_isNew && (!_canCreate || _limitedServiceIds.Any(id => string.Equals(id, _model.TargetId, StringComparison.OrdinalIgnoreCase))))
        {
            _saveError = AllServicesLimitedTooltip;
            StateHasChanged();
            return;
        }

        var limit = new GlobalRateLimit
        {
            Id = _isNew ? EntityIdGenerator.FromTarget(_model.TargetId) : _model.Id,
            TargetId = _model.TargetId,
            TargetType = TargetType.Service,
            Strategy = _model.Strategy,
            MaxRequests = _model.MaxRequests,
            Window = TimeSpan.FromSeconds(_model.WindowSeconds),
            TokensPerRefill = _model.Strategy == RateLimitStrategy.TokenBucket
                ? _model.TokensPerRefill : null
        };

        try
        {
            _saveError = null;

            if (_isNew)
            {
                await RateLimitApi.CreateAsync(limit);
            }
            else
            {
                await RateLimitApi.UpdateAsync(Id!, limit with { Id = _model.Id });
            }
        }
        catch (HttpRequestException ex)
        {
            _saveError = $"Save failed: {ex.Message}";
            StateHasChanged();
            return;
        }

        Nav.NavigateTo("/rate-limits");
    }
}
