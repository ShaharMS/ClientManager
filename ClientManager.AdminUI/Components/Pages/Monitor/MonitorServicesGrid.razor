@using ClientManager.AdminUI.Models
@using ClientManager.AdminUI.Models.Monitor

<div class="cm-list-page__table-card" style="margin-top: var(--space-lg);">
    <div class="cm-dashboard__chart-header">
        <span class="cm-dashboard__chart-title">All Services</span>
    </div>
    <RadzenDataGrid @ref="_grid" Data="@Rows" TItem="ServiceSummaryRow"
        AllowSorting="true" AllowPaging="true" PageSize="15"
        PagerHorizontalAlign="HorizontalAlign.Center">
        <Columns>
            <RadzenDataGridColumn TItem="ServiceSummaryRow" Property="Name" Title="Service" />
            <RadzenDataGridColumn TItem="ServiceSummaryRow" Property="CurrentUsage" Title="Usage" Width="100px"
                TextAlign="TextAlign.Center" CssClass="cm-list-page__col-center" />
            <RadzenDataGridColumn TItem="ServiceSummaryRow" Property="Cap" Title="Cap" Width="100px"
                TextAlign="TextAlign.Center" CssClass="cm-list-page__col-center" />
            <RadzenDataGridColumn TItem="ServiceSummaryRow" Title="Denied" Width="110px"
                TextAlign="TextAlign.Center" CssClass="cm-list-page__col-center">
                <Template Context="row">
                    <DeniedBreakdownCell Total="@row.DeniedLast5Min"
                        Unauthenticated="@row.DeniedUnauthenticatedCount"
                        Blocked="@row.DeniedBlockedCount"
                        RateLimited="@row.DeniedRateLimitedCount"
                        CapacityLimited="@row.DeniedCapacityLimitedCount"
                        ViewMode="DeniedViewMode.RateLimitDenied"
                        ShowBreakdown="@ShowDeniedBreakdown" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServiceSummaryRow" Title="Utilization" Width="200px"
                TextAlign="TextAlign.Center" CssClass="cm-list-page__col-center">
                <Template Context="row">
                    @{
                        var pct = row.Cap > 0 ? (int)(row.CurrentUsage * 100.0 / row.Cap) : 0;
                    }
                    <UtilizationProgressBar Percent="@pct" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServiceSummaryRow" Title="Status" Width="110px" Sortable="false"
                TextAlign="TextAlign.Center" CssClass="cm-list-page__col-center cm-list-page__col-status">
                <Template Context="row">
                    <div class="cm-list-page__actions-cell">
                        @if (row.Cap > 0 && row.CurrentUsage >= row.Cap)
                        {
                            <StatusBadge Text="At Capacity" Variant="StatusBadgeVariant.Danger" />
                        }
                        else
                        {
                            <StatusBadge Text="Available" Variant="StatusBadgeVariant.Success" />
                        }
                    </div>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>

@code {
    [Parameter] public List<ServiceSummaryRow> Rows { get; set; } = [];
    [Parameter] public bool ShowDeniedBreakdown { get; set; }
    private RadzenDataGrid<ServiceSummaryRow>? _grid;

    public async Task ReloadAsync(Func<Func<Task>, Task> dispatchAsync)
    {
        if (_grid is not null)
        {
            await dispatchAsync(_grid.Reload);
        }
    }
}
