@using ClientManager.AdminUI.Models
@using ClientManager.AdminUI.Models.Monitor

<div class="cm-list-page__table-card cm-monitor-client-grid" style="margin-top: var(--space-lg);">
    <div class="cm-dashboard__chart-header">
        <span class="cm-dashboard__chart-title">@L["Pages.Monitor.ClientBreakdown"]</span>
    </div>
    @if (Loading)
    {
        <TableRowsSkeleton />
    }
    else
    {
    <RadzenDataGrid @ref="_grid" Data="@Rows" TItem="MonitorClientRow" EmptyText="@L["DataGrid.NoRecords"]"
        AllowSorting="true" AllowPaging="true" PageSize="15"
        PagerHorizontalAlign="HorizontalAlign.Center">
        <Columns>
            <RadzenDataGridColumn TItem="MonitorClientRow" Property="ClientName" Title="@L["Columns.Client"]"
                CssClass="cm-col-id" HeaderCssClass="cm-col-id">
                <Template Context="row">@row.ClientName</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="MonitorClientRow" Property="ServiceName" Title="@L["Columns.Service"]"
                CssClass="cm-col-name" HeaderCssClass="cm-col-name">
                <Template Context="row">@row.ServiceName</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="MonitorClientRow" Property="GrantedLast5Min" Title="@L["Columns.Requests"]"
                CssClass="cm-col-scalar" HeaderCssClass="cm-col-scalar" />
            <RadzenDataGridColumn TItem="MonitorClientRow" Title="@L["Columns.Denied"]"
                CssClass="cm-col-scalar-wide" HeaderCssClass="cm-col-scalar-wide">
                <Template Context="row">
                    <DeniedBreakdownCell Total="@row.DeniedLast5Min"
                        Unauthenticated="@row.DeniedUnauthenticatedCount"
                        Blocked="@row.DeniedBlockedCount"
                        RateLimited="@row.DeniedRateLimitedCount"
                        CapacityLimited="@row.DeniedCapacityLimitedCount"
                        ViewMode="DeniedViewMode.RateLimitDenied"
                        ShowBreakdown="@ShowDeniedBreakdown" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="MonitorClientRow" Title="@L["Columns.Cap"]"
                CssClass="cm-col-scalar" HeaderCssClass="cm-col-scalar">
                <Template Context="row">@UtilizationHelper.FormatCapDisplay(row.RateLimitCap)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="MonitorClientRow" Title="@L["Columns.Utilization"]"
                CssClass="cm-col-bar" HeaderCssClass="cm-col-bar">
                <Template Context="row">
                    @if (row.RateLimitCap > 0)
                    {
                        var pct = (int)(row.GrantedLast5Min * 100.0 / row.RateLimitCap);
                        <UtilizationProgressBar Percent="@pct" HeightPx="18" />
                    }
                    else
                    {
                        <span>-</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="MonitorClientRow" Title="@L["Columns.Status"]" Sortable="false"
                CssClass="cm-col-status" HeaderCssClass="cm-col-status">
                <Template Context="row">
                    <div class="cm-list-page__actions-cell">
                        <MonitorClientStatusBadge Row="row" />
                    </div>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
    }
</div>

@code {
    [Parameter] public List<MonitorClientRow> Rows { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool ShowDeniedBreakdown { get; set; }
    private RadzenDataGrid<MonitorClientRow>? _grid;

    public async Task ReloadAsync(Func<Func<Task>, Task> dispatchAsync)
    {
        if (_grid is not null)
        {
            await dispatchAsync(_grid.Reload);
        }
    }
}
