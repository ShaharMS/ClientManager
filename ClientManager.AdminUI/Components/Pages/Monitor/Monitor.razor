@page "/monitor"
@inject StatisticsApiService StatsService
@inject ServiceApiService ServiceService
@inject ClientApiService ClientService
@inject GlobalRateLimitApiService RateLimitApi
@inject EntityColorService Colors
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="cm-page-header">
    <h1>Monitor</h1>
    <p>Real-time request analytics across services and clients.</p>
</div>

@if (_error is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Light">@_error</RadzenAlert>
}

@if (_loading)
{
    <SkeletonBlock CssClass="cm-skeleton--text" Style="height: 3px; margin-bottom: var(--space-sm);" />
}

<div class="cm-monitor__chart-card">
    <div class="cm-dashboard__chart-header">
        <div class="cm-dashboard__filters">
            <RadzenDropDown TValue="string" @bind-Value="_selectedServiceId"
                Data="@_serviceOptions" TextProperty="Name" ValueProperty="Id"
                Placeholder="Select service..." Style="width: 220px;"
                Change="@OnFilterChanged" />
            <RadzenDropDown @bind-Value="_selectedClientIds" Multiple="true"
                Data="@_clientOptions" TextProperty="Name" ValueProperty="Id"
                Placeholder="All clients" Style="width: 200px;"
                Change="@OnFilterChanged" />
        </div>
        <ChartSettingsDropdown OnTimeRangeChanged="OnTimeRangeChanged"
                                   OnPollingIntervalChanged="OnPollingIntervalChanged"
                                   OnAxisScaleChanged="OnAxisScaleChanged" />
    </div>
    @if (_targetCharts.Count > 0)
    {
        @foreach (var targetChart in _targetCharts)
        {
            <span class="cm-dashboard__chart-title">@targetChart.TargetName - Usage</span>
            <RadzenChart Style="height: 400px;">
                @{
                    var monitorSeries = _axisScaleType == AxisScaleType.Logarithmic
                        ? TransformStackedLogarithmic(targetChart.ClientSeries)
                        : targetChart.ClientSeries;
                }
                @foreach (var clientArea in monitorSeries)
                {
                    <RadzenStackedAreaSeries Data="@clientArea.Points"
                        CategoryProperty="Label" ValueProperty="Value"
                        Title="@clientArea.ClientName"
                        Fill="@Colors.GetColor(clientArea.ClientId)"
                        Stroke="@Colors.GetColor(clientArea.ClientId)">
                        <TooltipTemplate Context="point">
                            <span>@clientArea.ClientName: @(point.OriginalValue.ToString("N0"))</span>
                        </TooltipTemplate>
                    </RadzenStackedAreaSeries>
                }
                <RadzenLineSeries Data="@TransformPoints(targetChart.CapSeries)"
                    CategoryProperty="Label" ValueProperty="Value"
                    Title="Cap" LineType="LineType.Dashed"
                    Stroke="var(--color-text-secondary)">
                    <TooltipTemplate Context="point">
                        <span>Cap: @(point.OriginalValue.ToString("N0"))</span>
                    </TooltipTemplate>
                </RadzenLineSeries>
                <RadzenCategoryAxis />
                <RadzenValueAxis Formatter="@(_axisScaleType == AxisScaleType.Logarithmic ? LogarithmicScaleHelper.FormatAxisLabel : LogarithmicScaleHelper.FormatLinearAxisLabel)" />
                <RadzenLegend Position="LegendPosition.Right" />
            </RadzenChart>
        }
    }
    else if (_loading)
    {
        <SkeletonBlock CssClass="cm-skeleton--heading" />
        <SkeletonBlock CssClass="cm-skeleton--chart" />
    }
    else
    {
        <div class="cm-chart-empty">No usage data available</div>
    }
</div>

    <div class="cm-list-page__table-card" style="margin-top: var(--space-lg);">
        <div class="cm-dashboard__chart-header">
            <span class="cm-dashboard__chart-title">Client Breakdown</span>
        </div>
        <RadzenDataGrid @ref="_clientRowsGrid" Data="@_clientRows" TItem="MonitorClientRow"
            AllowSorting="true" AllowPaging="true" PageSize="15"
            PagerHorizontalAlign="HorizontalAlign.Center">
            <Columns>
                <RadzenDataGridColumn TItem="MonitorClientRow" Property="ClientName" Title="Client" />
                <RadzenDataGridColumn TItem="MonitorClientRow" Property="ServiceName" Title="Service" Width="150px" />
                <RadzenDataGridColumn TItem="MonitorClientRow" Property="GrantedLast5Min" Title="Req (5m)" Width="100px" />
                <RadzenDataGridColumn TItem="MonitorClientRow" Property="DeniedLast5Min" Title="Denied (5m)" Width="110px" />
                <RadzenDataGridColumn TItem="MonitorClientRow" Title="Cap (5m)" Width="90px">
                    <Template Context="row">@FormatCap(row.RateLimitCap)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="MonitorClientRow" Title="Utilization" Width="180px">
                    <Template Context="row">
                        @if (row.RateLimitCap > 0)
                        {
                            var pct = (int)(row.GrantedLast5Min * 100.0 / row.RateLimitCap);
                            var barStyle = pct >= 100 ? ProgressBarStyle.Danger
                                : pct >= 75 ? ProgressBarStyle.Warning : ProgressBarStyle.Success;
                            <RadzenProgressBar Value="@pct" Max="100" ShowValue="true"
                                ProgressBarStyle="@barStyle" Style="height: 18px;" />
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="MonitorClientRow" Title="Status" Width="120px" Sortable="false">
                    <Template Context="row">
                        @if (row.DeniedLast5Min > 0 && row.RateLimitCap > 0 && row.GrantedLast5Min >= row.RateLimitCap * 0.9)
                        {
                            <StatusBadge Text="Hitting Limit" Variant="StatusBadgeVariant.Danger" />
                        }
                        else if (row.DeniedLast5Min > 0)
                        {
                            <StatusBadge Text="Denied" Variant="StatusBadgeVariant.Warning" />
                        }
                        else if (row.RateLimitCap > 0 && row.GrantedLast5Min >= row.RateLimitCap * 0.9)
                        {
                            <StatusBadge Text="Near Limit" Variant="StatusBadgeVariant.Warning" />
                        }
                        else
                        {
                            <StatusBadge Text="Healthy" Variant="StatusBadgeVariant.Success" />
                        }
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>

    <hr class="cm-monitor__separator" />

    <div class="cm-list-page__table-card" style="margin-top: var(--space-lg);">
        <div class="cm-dashboard__chart-header">
            <span class="cm-dashboard__chart-title">All Services</span>
        </div>
        <RadzenDataGrid @ref="_allServicesGrid" Data="@_allServiceStats" TItem="ServiceSummaryRow"
            AllowSorting="true" AllowPaging="true" PageSize="15"
            PagerHorizontalAlign="HorizontalAlign.Center">
            <Columns>
                <RadzenDataGridColumn TItem="ServiceSummaryRow" Property="Name" Title="Service" />
                <RadzenDataGridColumn TItem="ServiceSummaryRow" Property="CurrentUsage" Title="Current" Width="100px" />
                <RadzenDataGridColumn TItem="ServiceSummaryRow" Property="Cap" Title="Cap" Width="100px" />
                <RadzenDataGridColumn TItem="ServiceSummaryRow" Title="Utilization" Width="200px">
                    <Template Context="row">
                        @{
                            var pct = row.Cap > 0
                                ? (int)(row.CurrentUsage * 100.0 / row.Cap) : 0;
                            var barStyle = pct >= 100 ? ProgressBarStyle.Danger
                                : pct >= 75 ? ProgressBarStyle.Warning : ProgressBarStyle.Success;
                        }
                        <RadzenProgressBar Value="@pct" Max="100" ShowValue="true"
                            ProgressBarStyle="@barStyle" Style="height: 20px;" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ServiceSummaryRow" Title="Status" Width="110px" Sortable="false">
                    <Template Context="row">
                        @if (row.Cap > 0 && row.CurrentUsage >= row.Cap)
                        {
                            <StatusBadge Text="At Capacity" Variant="StatusBadgeVariant.Danger" />
                        }
                        else
                        {
                            <StatusBadge Text="Available" Variant="StatusBadgeVariant.Success" />
                        }
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>

@code {
    private const string AllServicesId = "__all__";
    private static readonly TimeSpan RecentWindow = TimeSpan.FromMinutes(5);

    private List<Service> _allServices = [];
    private List<NamedItem> _serviceOptions = [];
    private List<ClientOption> _clientOptions = [];
    private List<ClientConfiguration> _allClients = [];
    private string _selectedServiceId = AllServicesId;
    private IEnumerable<string>? _selectedClientIds;

    private bool _loading;
    private string? _error;
    private PagePollingLifecycle? _polling;
    private int _loadVersion;

    private List<TargetChartData> _targetCharts = [];
    private List<MonitorClientRow> _clientRows = [];
    private List<ServiceSummaryRow> _allServiceStats = [];
    private RadzenDataGrid<MonitorClientRow>? _clientRowsGrid;
    private RadzenDataGrid<ServiceSummaryRow>? _allServicesGrid;

    private TimeRangePreset _timeRange = TimeRangePreset.Default;
    private AxisScaleType _axisScaleType = AxisScaleType.Linear;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        try
        {
            _allServices = await ServiceService.GetAllAsync();
            var clients = await ClientService.GetAllAsync();
            _allClients = clients;
            _clientOptions = clients
                .Select(c => new ClientOption(c.Id, c.Name))
                .ToList();

            _serviceOptions = new List<NamedItem> { new(AllServicesId, "All Services") }
                .Concat(_allServices.Select(s => new NamedItem(s.Id, s.Name))).ToList();
            _selectedServiceId = AllServicesId;

            await LoadDataAsync();
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }

        _polling = new PagePollingLifecycle(JS, InvokeAsync, LoadDataAsync);
        _polling.Start();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _polling is not null)
        {
            await _polling.RegisterVisibilityAsync();
        }
    }

    private Task OnPollingIntervalChanged(PollingIntervalPreset preset)
    {
        _polling?.SetInterval(preset.Interval);
        return Task.CompletedTask;
    }

    private Task OnAxisScaleChanged(AxisScaleType scale)
    {
        _axisScaleType = scale;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private List<ChartPoint> TransformPoints(List<ChartPoint> points) =>
        _axisScaleType == AxisScaleType.Logarithmic
            ? points.Select(p => p with { Value = LogarithmicScaleHelper.Transform(p.Value), OriginalValue = p.Value }).ToList()
            : points;

    private async Task OnTimeRangeChanged(TimeRangePreset preset)
    {
        _timeRange = preset;
        await LoadDataAsync();
        StateHasChanged();
    }

    private async Task OnFilterChanged()
    {
        _loading = true;
        StateHasChanged();
        await LoadDataAsync();
        _loading = false;
        StateHasChanged();
    }

    private async Task LoadDataAsync()
    {
        var loadVersion = System.Threading.Interlocked.Increment(ref _loadVersion);

        try
        {
            var now = DateTime.UtcNow;
            var from = _timeRange.GetFrom(now);
            var recentFrom = now.Subtract(RecentWindow);
            var chartTemplate = ChartBucketAggregator.Aggregate([], from, now);
            var chartBucketDuration = chartTemplate.BucketDuration;

            var rateLimits = await RateLimitApi.GetByTargetTypeAsync(
                ClientManager.Shared.Models.Enums.TargetType.Service);
            var rateLimitLookup = rateLimits.ToDictionary(r => r.TargetId);

            var visibleServices = _selectedServiceId == AllServicesId
                ? _allServices
                : _allServices.Where(s => s.Id == _selectedServiceId).ToList();

            var visibleServiceIds = visibleServices.Select(s => s.Id).ToList();

            // Batch: one call for all breakdowns
            var breakdowns = await StatsService.GetClientUsageBreakdownAsync(
                "Service", visibleServiceIds, _selectedClientIds,
                from, now, _timeRange.Granularity);
            var recentBreakdowns = await StatsService.GetClientUsageBreakdownAsync(
                "Service", visibleServiceIds, _selectedClientIds,
                recentFrom, now, "FiveMinute");

            // Collect all client IDs that appear in breakdowns for history fetch
            var allClientIds = breakdowns
                .SelectMany(b => b.Entries.Select(e => e.ClientId))
                .Distinct()
                .ToList();

            // Batch: one call for all histories across all visible services
            var allHistories = allClientIds.Count > 0
                ? await StatsService.GetHistoricalUsageAsync(
                    "Service", visibleServiceIds, null, from, now, _timeRange.Granularity)
                : [];

            // Batch: one call for recent data across all visible services
            var allRecents = allClientIds.Count > 0
                ? await StatsService.GetHistoricalUsageAsync(
                    "Service", visibleServiceIds, null, recentFrom, now, "FiveMinute")
                : [];

            var charts = new List<TargetChartData>();
            var rows = new List<MonitorClientRow>();

            if (_selectedServiceId == AllServicesId)
            {
                var rawPoints = new List<ChartBucketAggregator.RawPoint>();
                var totalCap = 0;

                foreach (var service in visibleServices)
                {
                    totalCap += GetScaledGlobalServiceCap(service.Id, rateLimitLookup, chartBucketDuration);

                    var breakdown = breakdowns.FirstOrDefault(b => b.TargetId == service.Id);
                    var history = allHistories.FirstOrDefault(h => h.TargetId == service.Id);
                    var recentEntries = recentBreakdowns
                        .FirstOrDefault(b => b.TargetId == service.Id)?.Entries ?? [];

                    rawPoints.AddRange((history?.Points ?? [])
                        .Select(point => new ChartBucketAggregator.RawPoint(point.Timestamp, point.GrantedCount)));

                    foreach (var entry in breakdown?.Entries ?? [])
                    {
                        var recentEntry = recentEntries.FirstOrDefault(e => e.ClientId == entry.ClientId);
                        rows.Add(new MonitorClientRow(
                            entry.ClientId, entry.ClientName, service.Name,
                            recentEntry?.GrantedCount ?? 0,
                            recentEntry?.DeniedCount ?? 0,
                            GetEffectiveClientServiceCap(entry.ClientId, service.Id, rateLimitLookup, RecentWindow)));
                    }
                }

                var aggregation = ChartBucketAggregator.Aggregate(rawPoints, from, now);

                var sortedPoints = aggregation.Buckets
                    .Select(bucket => new ChartPoint(bucket.Label, bucket.Value))
                    .ToList();

                var capPoints = sortedPoints
                    .Select(p => new ChartPoint(p.Label, totalCap))
                    .ToList();

                charts.Add(new TargetChartData("All Services",
                    new List<ClientAreaSeries> { new("total", "Total", sortedPoints) },
                    capPoints));
            }
            else
            {
                foreach (var service in visibleServices)
                {
                    var chartCap = GetScaledGlobalServiceCap(service.Id, rateLimitLookup, chartBucketDuration);

                    var breakdown = breakdowns.FirstOrDefault(b => b.TargetId == service.Id);
                    var recentEntries = recentBreakdowns
                        .FirstOrDefault(b => b.TargetId == service.Id)?.Entries ?? [];
                    var entries = breakdown?.Entries ?? [];

                    var historiesByClientId = (await StatsService.GetHistoricalUsageByClientAsync(
                            "Service",
                            new[] { service.Id },
                            entries.Select(entry => entry.ClientId),
                            from,
                            now,
                            _timeRange.Granularity))
                        .ToDictionary(history => history.ClientId);

                    var clientAreas = new List<ClientAreaSeries>();
                    var clientAggregations = new Dictionary<string, ChartBucketAggregator.AggregationResult>();

                    foreach (var entry in entries)
                    {
                        historiesByClientId.TryGetValue(entry.ClientId, out var historyData);
                        var rawPoints = (historyData?.Points ?? [])
                            .Select(point => new ChartBucketAggregator.RawPoint(point.Timestamp, point.GrantedCount))
                            .ToList();

                        if (rawPoints.Count == 0)
                        {
                            continue;
                        }

                        clientAggregations[entry.ClientId] = ChartBucketAggregator.Aggregate(rawPoints, from, now);
                    }

                    var referenceBuckets = clientAggregations.Values.FirstOrDefault()?.Buckets
                        ?? chartTemplate.Buckets;

                    for (var i = 0; i < entries.Count; i++)
                    {
                        var entry = entries[i];
                        if (!clientAggregations.TryGetValue(entry.ClientId, out var aggregation))
                        {
                            continue;
                        }

                        var points = aggregation.Buckets
                            .Select(bucket => new ChartPoint(bucket.Label, bucket.Value))
                            .ToList();

                        clientAreas.Add(new ClientAreaSeries(entry.ClientId, entry.ClientName, points));

                        var recentEntry = recentEntries.FirstOrDefault(e => e.ClientId == entry.ClientId);

                        rows.Add(new MonitorClientRow(
                            entry.ClientId, entry.ClientName, service.Name,
                            recentEntry?.GrantedCount ?? 0,
                            recentEntry?.DeniedCount ?? 0,
                            GetEffectiveClientServiceCap(entry.ClientId, service.Id, rateLimitLookup, RecentWindow)));
                    }

                    var chartCapPoints = referenceBuckets
                        .Select(bucket => new ChartPoint(bucket.Label, chartCap))
                        .ToList();

                    var aggregated = ChartAggregator.Aggregate(
                        clientAreas.Select(c => new ChartAggregator.AggregatedSeries(
                            c.ClientId, c.ClientName,
                            c.Points.Select(p => new ChartAggregator.AggregatedPoint(p.Label, p.Value)).ToList()
                        )).ToList());

                    clientAreas = aggregated.Select(a => new ClientAreaSeries(
                        a.Id, a.Name,
                        a.Points.Select(p => new ChartPoint(p.Label, p.Value)).ToList()
                    )).ToList();

                    charts.Add(new TargetChartData(service.Name, clientAreas, chartCapPoints));
                }
            }

            if (loadVersion != _loadVersion)
            {
                return;
            }

            _targetCharts = charts;
            _clientRows.Clear();
            _clientRows.AddRange(rows);

            // All-services summary - one batch call for all services
            var allServiceIds = _allServices.Select(s => s.Id).ToList();
            var summaryBreakdowns = await StatsService.GetClientUsageBreakdownAsync(
                "Service", allServiceIds, null);

            var allServiceBreakdowns = new List<ServiceSummaryRow>();
            foreach (var service in _allServices)
            {
                var bd = summaryBreakdowns.FirstOrDefault(b => b.TargetId == service.Id);
                var totalUsage = bd?.Entries.Sum(e => e.GrantedCount) ?? 0;
                var cap = GetScaledGlobalServiceCap(service.Id, rateLimitLookup, RecentWindow);
                allServiceBreakdowns.Add(new ServiceSummaryRow(
                    service.Id, service.Name, totalUsage, cap));
            }
            _allServiceStats.Clear();
            _allServiceStats.AddRange(allServiceBreakdowns);

            if (_clientRowsGrid is not null) await InvokeAsync(_clientRowsGrid.Reload);
            if (_allServicesGrid is not null) await InvokeAsync(_allServicesGrid.Reload);

            _error = null;
        }
        catch (HttpRequestException ex)
        {
            if (loadVersion != _loadVersion)
            {
                return;
            }

            _error = $"Unable to load data: {ex.Message}";
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_polling is not null)
        {
            await _polling.DisposeAsync();
        }
    }

    private int GetEffectiveClientServiceCap(
        string clientId,
        string serviceId,
        IReadOnlyDictionary<string, GlobalRateLimit> globalLimitsByService,
        TimeSpan comparisonWindow)
    {
        var client = _allClients.FirstOrDefault(c => c.Id == clientId);
        if (client is null)
            return GetScaledGlobalServiceCap(serviceId, globalLimitsByService, comparisonWindow);

        var serviceSettings = client.Services.GetValueOrDefault(serviceId);
        var caps = new List<int>();

        if (serviceSettings?.RateLimit is not null)
        {
            caps.Add(ScaleRateLimitCap(serviceSettings.RateLimit.MaxRequests, serviceSettings.RateLimit.Window, comparisonWindow));
        }

        if (client.GlobalRateLimit is not null)
        {
            caps.Add(ScaleRateLimitCap(client.GlobalRateLimit.MaxRequests, client.GlobalRateLimit.Window, comparisonWindow));
        }

        var exemptFromServiceGlobal = serviceSettings?.ExemptFromGlobalLimit ?? client.ExemptFromGlobalLimits;
        if (!exemptFromServiceGlobal)
        {
            var globalCap = GetScaledGlobalServiceCap(serviceId, globalLimitsByService, comparisonWindow);
            if (globalCap > 0)
            {
                caps.Add(globalCap);
            }
        }

        return caps.Count > 0 ? caps.Min() : 0;
    }

    private static int GetScaledGlobalServiceCap(
        string serviceId,
        IReadOnlyDictionary<string, GlobalRateLimit> globalLimitsByService,
        TimeSpan comparisonWindow)
    {
        return globalLimitsByService.TryGetValue(serviceId, out var globalLimit)
            ? ScaleRateLimitCap(globalLimit.MaxRequests, globalLimit.Window, comparisonWindow)
            : 0;
    }

    private static int ScaleRateLimitCap(int maxRequests, TimeSpan configuredWindow, TimeSpan comparisonWindow)
    {
        if (maxRequests <= 0 || configuredWindow <= TimeSpan.Zero || comparisonWindow <= TimeSpan.Zero)
            return 0;

        var scaled = maxRequests * comparisonWindow.TotalSeconds / configuredWindow.TotalSeconds;
        return scaled > 0
            ? Math.Max(1, (int)Math.Round(scaled, MidpointRounding.AwayFromZero))
            : 0;
    }

    private static List<ClientAreaSeries> TransformStackedLogarithmic(List<ClientAreaSeries> series)
    {
        if (series.Count == 0) return series;

        var totals = new Dictionary<string, double>();
        foreach (var s in series)
            foreach (var p in s.Points)
                totals[p.Label] = totals.GetValueOrDefault(p.Label) + p.Value;

        return series.Select(s => new ClientAreaSeries(s.ClientId, s.ClientName,
            s.Points.Select(p =>
            {
                var total = totals.GetValueOrDefault(p.Label);
                if (total <= 0) return p with { Value = 0, OriginalValue = p.Value };
                var logTotal = LogarithmicScaleHelper.Transform(total);
                return p with { Value = (p.Value / total) * logTotal, OriginalValue = p.Value };
            }).ToList()
        )).ToList();
    }

    private static string FormatCap(int cap) => cap > 0 ? cap.ToString() : "-";

    private record NamedItem(string Id, string Name);
    private record ChartPoint(string Label, double Value)
    {
        public double OriginalValue { get; init; } = Value;
    }
    private record ClientOption(string Id, string Name);
    private record ClientAreaSeries(string ClientId, string ClientName, List<ChartPoint> Points);
    private record TargetChartData(
        string TargetName, List<ClientAreaSeries> ClientSeries,
        List<ChartPoint> CapSeries);
    private record MonitorClientRow(
        string ClientId, string ClientName, string ServiceName,
        long GrantedLast5Min, long DeniedLast5Min, int RateLimitCap);
    private record ServiceSummaryRow(
        string Id, string Name, long CurrentUsage, int Cap);
}
