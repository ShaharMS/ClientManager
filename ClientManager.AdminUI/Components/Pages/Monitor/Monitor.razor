@page "/monitor"
@using ClientManager.AdminUI.Models.Charts

<PageTitle>@string.Format(L["Common.PageTitleSuffix"], L["Pages.Monitor.Title"])</PageTitle>

<div class="cm-page-header">
    <h1>@L["Pages.Monitor.Title"]</h1>
    <p>@L["Pages.Monitor.Subtitle"]</p>
</div>

@if (_error is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Light">@_error</RadzenAlert>
}

<MonitorChartSection
    SelectedServiceId="@_selectedServiceId"
    SelectedServiceIdChanged="@(v => _selectedServiceId = v)"
    SelectedClientIds="@_selectedClientIds"
    SelectedClientIdsChanged="@(v => _selectedClientIds = v)"
    ServiceOptions="@_serviceOptions"
    ClientOptions="@_clientOptions"
    TargetCharts="@_targetCharts"
    AxisScaleType="@_axisScaleType"
    Loading="@_chartLoading"
    OnFilterChanged="OnFilterChanged"
    OnTimeRangeChanged="OnTimeRangeChanged"
    OnPollingIntervalChanged="OnPollingIntervalChanged"
    OnAxisScaleChanged="OnAxisScaleChanged" />

<MonitorClientGrid @ref="_clientGrid" Rows="@_clientRows" ShowDeniedBreakdown="@ShowDeniedBreakdown" />

<hr class="cm-monitor__separator" />

<MonitorServicesGrid @ref="_servicesGrid" Rows="@_allServiceStats" ShowDeniedBreakdown="@ShowDeniedBreakdown" />
