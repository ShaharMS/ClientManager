@page "/services/new"
@page "/services/{Id}"
@inject ServiceApiService ServiceApi
@inject NavigationManager Nav

<EditorPageTemplate TModel="ServiceFormModel"
    Id="@Id" IsNew="@_isNew"
    BackPath="services" BackLinkText="← Back to Services"
    CreateTitle="Create Service" CreateDescription="Define a new service."
    EditTitlePrefix="Edit Service: " EditDescription="Update service configuration."
    FormName="serviceForm" Model="@_model" Loading="@_loading" Error="@_error"
    OnValidSubmit="SaveAsync">
    <div class="cm-editor__field">
        <label>Service ID</label>
        <EntityIdInput @bind-Value="_model.Id" Suggestions="_existingIds"
            Mode="EntityIdInputMode.Unique" EntityName="service" Disabled="@(!_isNew)" />
    </div>
    <div class="cm-editor__field">
        <label>Name</label>
        <RadzenTextBox @bind-Value="_model.Name" Style="width: 100%;" />
    </div>
    <div class="cm-editor__field">
        <label>Enabled</label>
        <RadzenSwitch @bind-Value="_model.IsEnabled" />
    </div>
</EditorPageTemplate>

@code {
    [Parameter] public string? Id { get; set; }
    private bool _isNew => string.IsNullOrEmpty(Id) || Id == "new";
    private bool _loading = true;
    private string? _error;
    private ServiceFormModel _model = new();
    private List<string> _existingIds = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _existingIds = (await ServiceApi.GetAllAsync()).Select(s => s.Id).ToList();

            if (!_isNew)
            {
                var svc = await ServiceApi.GetByIdAsync(Id!);
                if (svc is null)
                {
                    _error = $"Service '{Id}' not found.";
                    return;
                }

                _model = new ServiceFormModel
                {
                    Id = svc.Id,
                    Name = svc.Name,
                    IsEnabled = svc.IsEnabled
                };
            }
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        var service = new Service
        {
            Id = _model.Id,
            Name = _model.Name,
            IsEnabled = _model.IsEnabled
        };

        try
        {
            if (_isNew)
            {
                await ServiceApi.CreateAsync(service);
            }
            else
            {
                await ServiceApi.UpdateAsync(Id!, service);
            }

            Nav.NavigateTo("/services");
        }
        catch (HttpRequestException ex)
        {
            _error = $"Save failed: {ex.Message}";
        }
    }
}
