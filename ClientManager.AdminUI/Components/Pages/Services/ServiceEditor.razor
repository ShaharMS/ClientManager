@page "/services/new"
@page "/services/{Id}"
@inject ServiceApiService ServiceApi
@inject NavigationManager Nav
@inject ApiErrorLocalizer errors

<EditorPageTemplate TModel="ServiceFormModel"
    Id="@Id" IsNew="@_isNew"
    BackPath="services" BackLinkText="@L["Pages.Services.BackLink"]"
    CreateTitle="@L["Pages.Services.CreateTitle"]" CreateDescription="@L["Pages.Services.CreateDescription"]"
    EditTitlePrefix="@L["Pages.Services.EditTitlePrefix"]" EditDescription="@L["Pages.Services.EditDescription"]"
    FormName="serviceForm" Model="@_model" Loading="@_loading" Error="@_error"
    OnValidSubmit="SaveAsync">
    <div class="cm-editor__field">
        <label>@L["Pages.Services.ServiceId"]</label>
        <EntityIdInput @bind-Value="_model.Id" Suggestions="_existingIds"
            Mode="EntityIdInputMode.Unique" EntityName="@L["Dialog.EntityLabel.Service"]" Disabled="@(!_isNew)" />
    </div>
    <div class="cm-editor__field">
        <label>@L["Pages.Services.Name"]</label>
        <RadzenTextBox @bind-Value="_model.Name" Style="width: 100%;" />
    </div>
    <div class="cm-editor__field">
        <label>@L["Pages.Services.Enabled"]</label>
        <RadzenSwitch @bind-Value="_model.IsEnabled" />
    </div>
</EditorPageTemplate>

@code {
    [Parameter] public string? Id { get; set; }
    private bool _isNew => string.IsNullOrEmpty(Id) || Id == "new";
    private bool _loading = true;
    private string? _error;
    private ServiceFormModel _model = new();
    private List<string> _existingIds = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _existingIds = (await ServiceApi.GetAllAsync()).Select(s => s.Id).ToList();

            if (!_isNew)
            {
                var svc = await ServiceApi.GetByIdAsync(Id!);
                if (svc is null)
                {
                    _error = L["Pages.Services.NotFound"];
                    return;
                }

                _model = new ServiceFormModel
                {
                    Id = svc.Id,
                    Name = svc.Name,
                    IsEnabled = svc.IsEnabled
                };
            }
        }
        catch (HttpRequestException ex)
        {
            _error = errors.Format("Api.UnableToConnect", ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        var service = new Service
        {
            Id = _model.Id,
            Name = _model.Name,
            IsEnabled = _model.IsEnabled
        };

        try
        {
            if (_isNew)
            {
                await ServiceApi.CreateAsync(service);
            }
            else
            {
                await ServiceApi.UpdateAsync(Id!, service);
            }
        }
        catch (HttpRequestException ex)
        {
            _error = errors.Format("Pages.Services.SaveFailed", ex);
            return;
        }

        Nav.NavigateTo("/services");
    }
}
