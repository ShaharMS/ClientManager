@page "/services/new"
@page "/services/{Id}"
@inject ServiceApiService ServiceApi
@inject NavigationManager Nav

<div style="margin-bottom: var(--space-md);">
    <RadzenLink Path="services" Text="← Back to Services" Style="font-size: var(--font-size-sm);" />
</div>

<div class="cm-page-header">
    <h1>@(_isNew ? "Create Service" : $"Edit Service: {Id}")</h1>
    <p>@(_isNew ? "Define a new service." : "Update service configuration.")</p>
</div>

@if (_loading)
{
    <FormSkeleton />
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="cm-editor">
        <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="serviceForm">
            <DataAnnotationsValidator />

            <div class="cm-editor__card">
                <div class="cm-editor__field">
                    <label>Service ID</label>
                    <EntityIdInput @bind-Value="_model.Id" Suggestions="_existingIds"
                        Mode="EntityIdInputMode.Unique" EntityName="service" Disabled="@(!_isNew)" />
                </div>
                <div class="cm-editor__field">
                    <label>Name</label>
                    <RadzenTextBox @bind-Value="_model.Name" Style="width: 100%;" />
                </div>
                <div class="cm-editor__field">
                    <label>Enabled</label>
                    <RadzenSwitch @bind-Value="_model.IsEnabled" />
                </div>
            </div>

            <div class="cm-editor__actions">
                <RadzenButton Text="Save" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary" />
                <RadzenButton Text="Cancel" Variant="Variant.Outlined" Click="@(() => Nav.NavigateTo("/services"))" />
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter] public string? Id { get; set; }
    private bool _isNew => string.IsNullOrEmpty(Id) || Id == "new";
    private bool _loading = true;
    private string? _error;
    private ServiceFormModel _model = new();
    private List<string> _existingIds = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var all = await ServiceApi.GetAllAsync();
            _existingIds = all.Select(s => s.Id).ToList();

            if (!_isNew)
            {
                var svc = await ServiceApi.GetByIdAsync(Id!);
                if (svc is null)
                {
                    _error = $"Service '{Id}' not found.";
                    return;
                }
                _model = new ServiceFormModel
                {
                    Id = svc.Id,
                    Name = svc.Name,
                    IsEnabled = svc.IsEnabled
                };
            }
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        var service = new Service
        {
            Id = _model.Id,
            Name = _model.Name,
            IsEnabled = _model.IsEnabled
        };

        try
        {
            if (_isNew)
                await ServiceApi.CreateAsync(service);
            else
                await ServiceApi.UpdateAsync(Id!, service);

            Nav.NavigateTo("/services");
        }
        catch (HttpRequestException ex)
        {
            _error = $"Save failed: {ex.Message}";
        }
    }

    private class ServiceFormModel
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public bool IsEnabled { get; set; } = true;
    }
}
