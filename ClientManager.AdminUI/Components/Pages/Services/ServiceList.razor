@page "/services"
@inject ServiceApiService ServiceApi
@inject NavigationManager Nav
@inject DialogService Dialog
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="cm-page-header">
    <h1>Services</h1>
    <p>Manage service definitions and availability.</p>
</div>

@if (_actionError is not null)
{
    <div class="alert alert-danger">@_actionError</div>
}

@if (_loading)
{
    <TableSkeleton />
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="cm-list-page__table-card">
        <div class="cm-list-page__header cm-list-page__header--with-filter cm-list-page__header--services">
            <div class="cm-list-page__filter-field">
                <RadzenDropDown TValue="bool?" Data="@_enabledOptions"
                    TextProperty="Label" ValueProperty="Value"
                    Value="@_enabledFilter"
                    ValueChanged="@((bool? v) => OnEnabledFilterChanged(v))"
                    Placeholder="All statuses" AllowClear="true" />
            </div>
            <div class="cm-list-page__header-actions">
                <RadzenButton Text="Create Service" Icon="add"
                    class="cm-list-page__create-btn"
                    title="Create service"
                    Click="@(() => Nav.NavigateTo("/services/new"))"
                    ButtonStyle="ButtonStyle.Primary" />
            </div>
            <div class="cm-list-page__search-field">
                <RadzenTextBox Placeholder="Search services..."
                    Value="@_search"
                    ValueChanged="@((string v) => { _search = v; StateHasChanged(); })"
                    @oninput="@(args => { _search = args.Value?.ToString(); StateHasChanged(); })" />
            </div>
        </div>

        <RadzenDataGrid Data="@_filteredServices" TItem="Service"
            AllowSorting="true" AllowPaging="true" PageSize="@_pageSize"
            PagerHorizontalAlign="HorizontalAlign.Center">
            <Columns>
                <RadzenDataGridColumn TItem="Service" Property="Id" Title="ID" Width="130px" />
                <RadzenDataGridColumn TItem="Service" Property="Name" Title="Name" MinWidth="220px" />
                <RadzenDataGridColumn TItem="Service" Title="Status" Width="130px" TextAlign="TextAlign.Center"
                    CssClass="cm-list-page__col-center cm-list-page__col-status">
                    <Template Context="svc">
                        @if (svc.IsEnabled)
                        {
                            <span class="cm-badge cm-badge--success">Enabled</span>
                        }
                        else
                        {
                            <span class="cm-badge cm-badge--muted">Disabled</span>
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Service" Title="Actions" Width="120px" Sortable="false"
                    TextAlign="TextAlign.Center" CssClass="cm-list-page__col-center cm-list-page__col-actions">
                    <Template Context="svc">
                        <div class="cm-list-page__actions-cell">
                        <RadzenButton Icon="edit" Size="ButtonSize.Small" Variant="Variant.Text"
                            title="Edit service"
                            Click="@(() => Nav.NavigateTo($"/services/{svc.Id}"))" />
                        @if (svc.IsEnabled)
                        {
                            <RadzenButton Icon="block" Size="ButtonSize.Small" Variant="Variant.Text"
                                ButtonStyle="ButtonStyle.Warning" title="Disable service"
                                Click="@(async () => await ToggleEnabledAsync(svc))" />
                        }
                        else
                        {
                            <RadzenButton Icon="lock_open" Size="ButtonSize.Small" Variant="Variant.Text"
                                ButtonStyle="ButtonStyle.Success" title="Enable service"
                                Click="@(async () => await ToggleEnabledAsync(svc))" />
                        }
                        <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Text"
                            ButtonStyle="ButtonStyle.Danger" title="Delete service"
                            Click="@(async () => await DeleteAsync(svc.Id))" />
                        </div>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private string? _actionError;
    private string? _search;
    private bool? _enabledFilter;
    private List<Service> _services = [];
    private int _pageSize = 10;
    private IJSObjectReference? _tableJs;
    private DotNetObjectReference<ServiceList>? _selfRef;

    private static readonly List<object> _enabledOptions =
    [
        new { Label = "Enabled", Value = (bool?)true },
        new { Label = "Disabled", Value = (bool?)false }
    ];

    private IEnumerable<Service> _filteredServices =>
        string.IsNullOrWhiteSpace(_search)
            ? _services
            : _services.Where(s =>
                s.Id.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                s.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _tableJs = await JS.InvokeAsync<IJSObjectReference>("import", "./js/table.js");
            _selfRef = DotNetObjectReference.Create(this);
            await _tableJs.InvokeVoidAsync("register", _selfRef);
            await RecalculatePageSizeAsync();
        }
    }

    [JSInvokable]
    public async Task OnWindowResize() => await RecalculatePageSizeAsync();

    private async Task RecalculatePageSizeAsync()
    {
        _pageSize = await _tableJs!.InvokeAsync<int>("getPageSize", 45);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_tableJs is not null)
        {
            await _tableJs.InvokeVoidAsync("unregister");
            await _tableJs.DisposeAsync();
        }
        _selfRef?.Dispose();
    }

    private async Task LoadAsync()
    {
        try
        {
            if (_enabledFilter.HasValue)
            {
                var query = new DocumentQuery { Take = 100 }
                    .Where(nameof(Service.IsEnabled), ClientManager.Shared.Models.Search.FilterOperator.Equals, _enabledFilter.Value);
                var result = await ServiceApi.SearchAsync(query);
                _services = result.Items.ToList();
            }
            else
            {
                _services = await ServiceApi.GetAllAsync();
            }
            _error = null;
        }
        catch (HttpRequestException ex)
        {
            _error = $"Unable to connect to the API: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnEnabledFilterChanged(bool? value)
    {
        _enabledFilter = value;
        _loading = true;
        await LoadAsync();
    }

    private Task ToggleEnabledAsync(Service service) =>
        ListToggleEnabledSupport.ExecuteAsync(
            Dialog,
            "service",
            service.Id,
            service.IsEnabled,
            async () =>
            {
                var updated = service with { IsEnabled = !service.IsEnabled };
                await ServiceApi.UpdateAsync(service.Id, updated);
            },
            LoadAsync,
            message => _actionError = message,
            StateHasChanged,
            disableMessage: $"Disable service \"{service.Id}\"? Requests to this service will be rejected until it is re-enabled.",
            enableMessage: $"Enable service \"{service.Id}\"? Requests will be allowed again, subject to access rules.");

    private Task DeleteAsync(string id) =>
        ListDeleteSupport.ExecuteAsync(
            Dialog,
            "service",
            id,
            () => ServiceApi.DeleteAsync(id),
            LoadAsync,
            message => _actionError = message,
            StateHasChanged);
}
