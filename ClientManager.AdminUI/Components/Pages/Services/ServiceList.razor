@page "/services"
@inject ServiceApiService ServiceApi
@inject NavigationManager Nav

<ListPageTemplate @ref="_list" TItem="Service"
    Title="Services"
    Description="Manage service definitions and availability."
    SearchPlaceholder="Search services..."
    CreateButtonText="Create Service"
    CreateUrl="/services/new"
    LoadItemsAsync="LoadServicesAsync"
    SearchableValues="service => [service.Id, service.Name]">
    <ToolbarExtra>
        <RadzenDropDown TValue="bool?" Data="@EnabledFilterOptions"
            TextProperty="Label" ValueProperty="Value"
            Value="@_enabledFilter"
            ValueChanged="OnEnabledFilterChanged"
            Placeholder="All statuses" AllowClear="true"
            Style="width: 160px;" />
    </ToolbarExtra>
    <Columns>
        <RadzenDataGridColumn TItem="Service" Property="Id" Title="ID" Width="200px" />
        <RadzenDataGridColumn TItem="Service" Property="Name" Title="Name" />
        <RadzenDataGridColumn TItem="Service" Title="Status" Width="100px">
            <Template Context="svc">
                <StatusBadge Text="@(svc.IsEnabled ? "Enabled" : "Disabled")"
                    Variant="@(svc.IsEnabled ? StatusBadgeVariant.Success : StatusBadgeVariant.Muted)" />
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="Service" Title="Actions" Width="160px" Sortable="false">
            <Template Context="svc">
                <RadzenButton Icon="edit" Size="ButtonSize.Small" Variant="Variant.Text"
                    Click="@(() => Nav.NavigateTo($"/services/{svc.Id}"))" />
                <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Text"
                    ButtonStyle="ButtonStyle.Danger"
                    Click="@(() => DeleteAsync(svc.Id))" />
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</ListPageTemplate>

@code {
    private ListPageTemplate<Service>? _list;
    private bool? _enabledFilter;

    private static readonly List<object> EnabledFilterOptions =
    [
        new { Label = "Enabled", Value = (bool?)true },
        new { Label = "Disabled", Value = (bool?)false }
    ];

    private async Task<IReadOnlyList<Service>> LoadServicesAsync()
    {
        if (_enabledFilter.HasValue)
        {
            var query = new DocumentQuery { Take = 100 }
                .Where(nameof(Service.IsEnabled), ClientManager.Shared.Models.Search.FilterOperator.Equals, _enabledFilter.Value);
            var result = await ServiceApi.SearchAsync(query);
            return result.Items.ToList();
        }

        return await ServiceApi.GetAllAsync();
    }

    private async Task OnEnabledFilterChanged(bool? value)
    {
        _enabledFilter = value;
        if (_list is not null)
        {
            await _list.ReloadAsync();
        }
    }

    private async Task DeleteAsync(string id)
    {
        await ServiceApi.DeleteAsync(id);
        if (_list is not null)
        {
            await _list.ReloadAsync();
        }
    }
}
