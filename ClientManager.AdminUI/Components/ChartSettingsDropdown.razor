@using ClientManager.AdminUI.Utils
@inject UserPreferencesService PreferencesService

<div class="cm-chart-settings-dropdown @(_isOpen ? "cm-chart-settings-dropdown--open" : null)">
    <button class="cm-chart-settings-dropdown__trigger" @onclick="ToggleFlyout" @onclick:stopPropagation="true">
        <RadzenIcon Icon="tune" class="cm-chart-settings-dropdown__icon" />
        <span class="cm-chart-settings-dropdown__label">@_rangeLabel</span>
    </button>
    @if (_isOpen)
    {
        <div class="cm-chart-settings-dropdown__layer">
            <div class="cm-chart-settings-dropdown__scrim" @onclick="CloseFlyout"></div>
            <div class="cm-chart-settings-dropdown__panel" @onclick:stopPropagation="true">
                <div class="cm-chart-settings-dropdown__relative">
                <div class="cm-chart-settings-dropdown__relative-duration">
                    <span class="cm-chart-settings-dropdown__field-label">@L["Charts.Settings.Last"]</span>
                    <DurationInput Value="_relativeSeconds"
                                   ValueChanged="OnRelativeDurationChanged"
                                   Style="flex: 1; min-width: 0;" />
                </div>
                <div class="cm-chart-settings-dropdown__refresh">
                    <span class="cm-chart-settings-dropdown__field-label">@L["Charts.Settings.Refresh"]</span>
                    <RadzenDropDown TValue="string"
                                    Value="_selectedPollingKey"
                                    Data="@_pollingOptions"
                                    TextProperty="Label"
                                    ValueProperty="Key"
                                    Style="width: 100%;"
                                    Change="@OnPollingIntervalChangedAsync" />
                </div>
            </div>

            <div class="cm-chart-settings-dropdown__divider">
                <hr />
                <span>@L["Charts.Settings.Or"]</span>
                <hr />
            </div>

            <div class="cm-chart-settings-dropdown__calendar @( _mode == ChartTimeRangeMode.Custom ? "cm-chart-settings-dropdown__calendar--active" : "" )">
                <div class="cm-chart-settings-dropdown__calendar-field">
                    <span class="cm-chart-settings-dropdown__field-label">@L["Charts.Settings.From"]</span>
                    <RadzenDatePicker TValue="DateTime?"
                                      Value="_customFromLocal"
                                      ShowTime="true"
                                      DateFormat="@_pickerDateFormat"
                                      Change="@OnCustomFromChanged" />
                </div>
                <div class="cm-chart-settings-dropdown__calendar-field">
                    <span class="cm-chart-settings-dropdown__field-label">@L["Charts.Settings.To"]</span>
                    <RadzenDatePicker TValue="DateTime?"
                                      Value="_customToLocal"
                                      ShowTime="true"
                                      DateFormat="@_pickerDateFormat"
                                      Change="@OnCustomToChanged" />
                </div>
            </div>

            <div class="cm-chart-settings-dropdown__divider cm-chart-settings-dropdown__divider--plain">
                <hr />
            </div>

            <div class="cm-chart-settings-dropdown__axis">
                <span class="cm-chart-settings-dropdown__axis-label">@L["Charts.Settings.AxisType"]</span>
                <div class="cm-chart-settings-dropdown__segmented" role="group" aria-label="@L["Charts.Settings.AxisType"]">
                    <button type="button"
                            class="cm-chart-settings-dropdown__segment @(_selectedAxisScale == AxisScaleType.Linear ? "cm-chart-settings-dropdown__segment--active" : "")"
                            @onclick="() => SelectAxisScale(AxisScaleType.Linear)">
                        @L["Common.Linear"]
                    </button>
                    <button type="button"
                            class="cm-chart-settings-dropdown__segment @(_selectedAxisScale == AxisScaleType.Logarithmic ? "cm-chart-settings-dropdown__segment--active" : "")"
                            @onclick="() => SelectAxisScale(AxisScaleType.Logarithmic)">
                        @L["Common.Logarithmic"]
                    </button>
                </div>
            </div>

            </div>
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<ChartTimeRange> OnTimeRangeChanged { get; set; }
    [Parameter] public EventCallback<PollingIntervalPreset> OnPollingIntervalChanged { get; set; }
    [Parameter] public EventCallback<AxisScaleType> OnAxisScaleChanged { get; set; }
    [Parameter] public string? PollingKey { get; set; }
    [Parameter] public string? InitialTimeRangeKey { get; set; }
    [Parameter] public string? InitialPollingKey { get; set; }
    [Parameter] public AxisScaleType? InitialAxisScale { get; set; }
    [Parameter] public DateTime? InitialCustomFromUtc { get; set; }
    [Parameter] public DateTime? InitialCustomToUtc { get; set; }
    [Parameter] public bool SkipInitialChartLoad { get; set; }

    private readonly string _pickerDateFormat = CultureDateFormats.ChartPicker();

    private bool _isOpen;
    private bool _initialized;
    private ChartTimeRangeMode _mode = ChartTimeRangeMode.Relative;
    private string _rangeLabel = "";
    private double _relativeSeconds = 3600;
    private string _selectedPollingKey = "10s";
    private AxisScaleType _selectedAxisScale = AxisScaleType.Linear;
    private DateTime? _customFromLocal;
    private DateTime? _customToLocal;
    private List<PollingOption> _pollingOptions = [];

    private record PollingOption(string Key, string Label);

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(PollingKey) && PollingKey != _selectedPollingKey)
        {
            _selectedPollingKey = PollingKey;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            _pollingOptions = PollingIntervalPreset.All
                .Select(p => new PollingOption(p.Key, p.GetLocalizedLabel(L)))
                .ToList();

            var defaultPreset = InitialTimeRangeKey is not null
                ? TimeRangePreset.FindByKey(InitialTimeRangeKey) ?? await PreferencesService.GetDefaultTimeRangeAsync()
                : await PreferencesService.GetDefaultTimeRangeAsync();

            if (string.Equals(InitialTimeRangeKey, "custom", StringComparison.OrdinalIgnoreCase)
                && InitialCustomFromUtc is not null && InitialCustomToUtc is not null)
            {
                _mode = ChartTimeRangeMode.Custom;
                _customFromLocal = InitialCustomFromUtc.Value.ToLocalTime();
                _customToLocal = InitialCustomToUtc.Value.ToLocalTime();
                var customRange = ChartTimeRange.FromCustom(InitialCustomFromUtc.Value, InitialCustomToUtc.Value);
                _rangeLabel = GetRangeLabel(customRange);
                if (!SkipInitialChartLoad)
                {
                    await OnTimeRangeChanged.InvokeAsync(customRange);
                }
            }
            else
            {
                _relativeSeconds = defaultPreset.Duration.TotalSeconds;
                _rangeLabel = GetRangeLabel(ChartTimeRange.FromPreset(defaultPreset));
                SetDefaultCustomRange();
                if (!SkipInitialChartLoad)
                {
                    await EmitRelativeRangeAsync();
                }
            }

            var defaultPolling = InitialPollingKey is not null
                ? PollingIntervalPreset.FindByKey(InitialPollingKey) ?? await PreferencesService.GetDefaultPollingIntervalAsync()
                : await PreferencesService.GetDefaultPollingIntervalAsync();
            _selectedPollingKey = defaultPolling.Key;

            _selectedAxisScale = InitialAxisScale ?? await PreferencesService.GetDefaultAxisScaleAsync();

            await OnPollingIntervalChanged.InvokeAsync(defaultPolling);
            await OnAxisScaleChanged.InvokeAsync(_selectedAxisScale);
            StateHasChanged();
        }
    }

    private string GetRangeLabel(ChartTimeRange range)
    {
        if (range.Mode == ChartTimeRangeMode.Custom)
        {
            return range.GetLocalizedDisplayLabel(L);
        }

        var preset = TimeRangePreset.All.FirstOrDefault(p => p.Duration == range.RelativeDuration);
        return preset is not null ? preset.GetLocalizedLabel(L) : range.GetLocalizedDisplayLabel(L);
    }

    private void SetDefaultCustomRange()
    {
        var to = DateTime.Now;
        var from = to.AddHours(-1);
        _customFromLocal = from;
        _customToLocal = to;
    }

    private void ToggleFlyout() => _isOpen = !_isOpen;

    private void CloseFlyout() => _isOpen = false;

    private async Task OnRelativeDurationChanged(double seconds)
    {
        _relativeSeconds = seconds;
        _mode = ChartTimeRangeMode.Relative;
        await EmitRelativeRangeAsync();
    }

    private async Task EmitRelativeRangeAsync()
    {
        var range = ChartTimeRange.FromRelative(TimeSpan.FromSeconds(_relativeSeconds));
        _rangeLabel = GetRangeLabel(range);
        await OnTimeRangeChanged.InvokeAsync(range);
    }

    private async Task OnCustomFromChanged(DateTime? value)
    {
        if (value is null)
        {
            return;
        }

        _customFromLocal = value;
        await EmitCustomRangeIfValidAsync();
    }

    private async Task OnCustomToChanged(DateTime? value)
    {
        if (value is null)
        {
            return;
        }

        _customToLocal = value;
        await EmitCustomRangeIfValidAsync();
    }

    private async Task EmitCustomRangeIfValidAsync()
    {
        if (_customFromLocal is null || _customToLocal is null)
        {
            return;
        }

        _mode = ChartTimeRangeMode.Custom;
        var range = ChartTimeRange.FromCustom(
            _customFromLocal.Value.ToUniversalTime(),
            _customToLocal.Value.ToUniversalTime());
        _rangeLabel = GetRangeLabel(range);
        await OnTimeRangeChanged.InvokeAsync(range);
    }

    private async Task OnPollingIntervalChangedAsync(object? value)
    {
        if (value is not string key)
        {
            return;
        }

        _selectedPollingKey = key;
        var preset = PollingIntervalPreset.FindByKey(key);
        if (preset is not null)
        {
            await OnPollingIntervalChanged.InvokeAsync(preset);
        }
    }

    private async Task SelectAxisScale(AxisScaleType scale)
    {
        _selectedAxisScale = scale;
        await OnAxisScaleChanged.InvokeAsync(scale);
    }
}
