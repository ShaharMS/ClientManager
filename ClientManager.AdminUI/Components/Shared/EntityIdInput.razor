@namespace ClientManager.AdminUI.Components.Shared
@using System.Linq.Expressions
@implements IDisposable

@* As-you-type ID input with notched-border validation:
   Unique — new ID must not collide; Reference — value must be a known ID from the list. *@
<ValidatedOutlinedField ValidationState="@_validationState"
                        ValidationMessage="@_validationMessage"
                        MessageElementId="@_messageElementId"
                        Disabled="@Disabled">
    @if (Mode == EntityIdInputMode.Reference)
    {
        <RadzenDropDown TValue="string"
                        Value="@Value"
                        Data="@Suggestions"
                        Disabled="@Disabled"
                        Style="@Style"
                        Placeholder="@Placeholder"
                        AllowFiltering="true"
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        Change="@OnReferenceChanged"
                        InputAttributes="@_inputAttributes" />
    }
    else
    {
        <RadzenTextBox TValue="string"
                       Value="@Value"
                       Disabled="@Disabled"
                       Style="@Style"
                       Placeholder="@Placeholder"
                       Change="@OnUniqueChanged"
                       InputAttributes="@_inputAttributes" />
    }
</ValidatedOutlinedField>

@code {
    private static int _nextMessageId;

    /// <summary>The current ID value (two-way bound).</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Raised as the user types so the bound value stays in sync.</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>Expression for the bound value; supplied automatically by <c>@bind-Value</c>.</summary>
    [Parameter] public Expression<Func<string?>>? ValueExpression { get; set; }

    /// <summary>Existing IDs used for validation (and as dropdown options in reference mode).</summary>
    [Parameter] public IEnumerable<string> Suggestions { get; set; } = [];

    /// <summary>Whether the typed value must be unique or must reference an existing entity.</summary>
    [Parameter] public EntityIdInputMode Mode { get; set; } = EntityIdInputMode.Reference;

    /// <summary>Human-readable entity noun used in accessible labels (for example "service" or "client").</summary>
    [Parameter] public string EntityName { get; set; } = "item";

    /// <summary>Disables the input (for example when editing an existing entity's immutable ID).</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Inline style applied to the underlying input.</summary>
    [Parameter] public string Style { get; set; } = "width: 100%;";

    /// <summary>Placeholder hint shown when empty.</summary>
    [Parameter] public string? Placeholder { get; set; }

    /// <summary>Accessible label for the input.</summary>
    [Parameter] public string? AriaLabel { get; set; }

    /// <summary>Raised when validation state changes.</summary>
    [Parameter] public EventCallback<InputValidationState> ValidationStateChanged { get; set; }

    /// <summary>Current validation state.</summary>
    public InputValidationState ValidationState => _validationState;

    [CascadingParameter] private EditContext? EditContext { get; set; }

    private readonly string _messageElementId = $"cm-entity-id-msg-{Interlocked.Increment(ref _nextMessageId)}";

    private InputValidationState _validationState = InputValidationState.Neutral;
    private string? _validationMessage;
    private IReadOnlyDictionary<string, object>? _inputAttributes;
    private bool _submitValidationRequested;
    private ValidationMessageStore? _messageStore;

    protected override void OnInitialized()
    {
        if (EditContext is not null)
        {
            _messageStore = new ValidationMessageStore(EditContext);
            EditContext.OnValidationRequested += OnValidationRequested;
            EditContext.OnFieldChanged += OnFieldChanged;
        }
    }

    protected override void OnParametersSet()
    {
        Validate(Value);
        RefreshInputAttributes();
    }

    public void Dispose()
    {
        if (EditContext is not null)
        {
            EditContext.OnValidationRequested -= OnValidationRequested;
            EditContext.OnFieldChanged -= OnFieldChanged;
        }
    }

    private void OnValidationRequested(object? sender, ValidationRequestedEventArgs e)
    {
        _submitValidationRequested = true;
        Validate(Value);
        RefreshInputAttributes();
        SyncEditContextValidation();
    }

    private void OnFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        if (ValueExpression is null)
        {
            return;
        }

        var fieldIdentifier = FieldIdentifier.Create(ValueExpression);
        if (!e.FieldIdentifier.Equals(fieldIdentifier))
        {
            return;
        }

        Validate(Value);
        RefreshInputAttributes();

        if (_submitValidationRequested)
        {
            SyncEditContextValidation();
        }
    }

    private async Task OnUniqueChanged(object? value) => await ApplyValueAsync(value as string);

    private async Task OnReferenceChanged(object? value) => await ApplyValueAsync(value as string);

    private async Task ApplyValueAsync(string? text)
    {
        Value = text;
        await ValueChanged.InvokeAsync(text);
        Validate(text);
        RefreshInputAttributes();
    }

    private void Validate(string? value)
    {
        var previous = _validationState;

        if (Disabled)
        {
            _validationState = InputValidationState.Neutral;
            _validationMessage = null;
        }
        else if (string.IsNullOrWhiteSpace(value))
        {
            if (_submitValidationRequested)
            {
                _validationState = InputValidationState.Invalid;
                _validationMessage = "Missing Field";
            }
            else
            {
                _validationState = InputValidationState.Neutral;
                _validationMessage = null;
            }
        }
        else
        {
            var trimmed = value.Trim();
            var exists = Suggestions.Any(s => string.Equals(s, trimmed, StringComparison.OrdinalIgnoreCase));

            if (Mode == EntityIdInputMode.Unique)
            {
                if (exists)
                {
                    _validationState = InputValidationState.Invalid;
                    _validationMessage = "Already Taken";
                }
                else
                {
                    _validationState = InputValidationState.Neutral;
                    _validationMessage = null;
                }
            }
            else if (exists)
            {
                _validationState = InputValidationState.Neutral;
                _validationMessage = null;
            }
            else
            {
                _validationState = InputValidationState.Invalid;
                _validationMessage = "Not found";
            }
        }

        if (previous != _validationState)
        {
            _ = ValidationStateChanged.InvokeAsync(_validationState);
        }

        if (_submitValidationRequested)
        {
            SyncEditContextValidation();
        }
    }

    private void SyncEditContextValidation()
    {
        if (EditContext is null || _messageStore is null || ValueExpression is null)
        {
            return;
        }

        var fieldIdentifier = FieldIdentifier.Create(ValueExpression);
        _messageStore.Clear(fieldIdentifier);

        if (_validationState == InputValidationState.Invalid
            && !string.IsNullOrWhiteSpace(_validationMessage))
        {
            _messageStore.Add(fieldIdentifier, _validationMessage);
        }

        EditContext.NotifyValidationStateChanged();
    }

    private void RefreshInputAttributes()
    {
        var label = AriaLabel ?? EntityName;
        var attrs = new Dictionary<string, object>
        {
            ["aria-label"] = label,
            ["aria-invalid"] = _validationState == InputValidationState.Invalid
        };

        if (_validationState == InputValidationState.Invalid
            && !string.IsNullOrWhiteSpace(_validationMessage))
        {
            attrs["aria-describedby"] = _messageElementId;
        }

        _inputAttributes = attrs;
    }
}
