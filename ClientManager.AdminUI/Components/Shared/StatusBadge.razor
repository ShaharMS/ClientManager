<span class="@CssClass" style="@Style">@Text</span>

@code {
    [Parameter, EditorRequired] public string Text { get; set; } = string.Empty;
    [Parameter] public StatusBadgeVariant Variant { get; set; } = StatusBadgeVariant.Success;
    [Parameter] public string? Style { get; set; }

    private string CssClass => Variant switch
    {
        StatusBadgeVariant.Success => "cm-badge cm-badge--success",
        StatusBadgeVariant.Muted => "cm-badge cm-badge--muted",
        StatusBadgeVariant.Warning => "cm-badge",
        StatusBadgeVariant.Danger => "cm-badge",
        _ => "cm-badge"
    };

    protected override void OnParametersSet()
    {
        if (Variant is StatusBadgeVariant.Warning or StatusBadgeVariant.Danger && string.IsNullOrEmpty(Style))
        {
            Style = Variant switch
            {
                StatusBadgeVariant.Warning => "background: #fef3c7; color: #92400e;",
                StatusBadgeVariant.Danger => "background: #fee2e2; color: #991b1b;",
                _ => Style
            };
        }
    }
}
