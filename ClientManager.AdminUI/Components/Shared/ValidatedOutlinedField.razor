@namespace ClientManager.AdminUI.Components.Shared

@* Outlined field wrapper — borders are applied directly on inner inputs via CSS. *@
<div class="cm-outlined @StateClass" aria-disabled="@Disabled">
    <div class="cm-outlined__inner">
        @ChildContent
    </div>
    @if (ShowMessage)
    {
        <div id="@MessageElementId" class="cm-outlined__message" role="alert">@ValidationMessage</div>
    }
</div>

@code {
    private static int _nextMessageId;

    /// <summary>Validation state controlling border and legend color.</summary>
    [Parameter] public InputValidationState ValidationState { get; set; } = InputValidationState.Neutral;

    /// <summary>Short text shown in the notched border for invalid states (for example "Already Taken").</summary>
    [Parameter] public string? ValidationMessage { get; set; }

    /// <summary>Disables the fieldset (mirrors the inner control's disabled state).</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Id for the legend element; used by <c>aria-describedby</c> on the inner input.</summary>
    [Parameter] public string? MessageElementId { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    protected override void OnInitialized()
    {
        MessageElementId ??= $"cm-outlined-msg-{Interlocked.Increment(ref _nextMessageId)}";
    }

    private bool ShowMessage =>
        !Disabled
        && ValidationState == InputValidationState.Invalid
        && !string.IsNullOrWhiteSpace(ValidationMessage);

    private string StateClass => ValidationState switch
    {
        InputValidationState.Valid => "cm-outlined--valid",
        InputValidationState.Invalid => "cm-outlined--invalid",
        _ => string.Empty
    };
}
