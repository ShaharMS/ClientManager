<aside class="cm-sidebar">
    <div class="cm-sidebar__brand">
        <div class="cm-sidebar__brand-icon">CM</div>
        <span class="cm-sidebar__brand-name">@L["Nav.BrandName"]</span>
    </div>

    <ul class="cm-sidebar__nav">
        <li class="cm-sidebar__nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <RadzenIcon Icon="dashboard" class="cm-sidebar__nav-icon" />
                <span class="cm-sidebar__nav-label">@L["Nav.Dashboard"]</span>
            </NavLink>
        </li>
        <li class="cm-sidebar__nav-item">
            <NavLink class="nav-link" href="clients">
                <RadzenIcon Icon="people" class="cm-sidebar__nav-icon" />
                <span class="cm-sidebar__nav-label">@L["Nav.Clients"]</span>
            </NavLink>
        </li>

        <li class="cm-sidebar__divider"></li>

        <li class="cm-sidebar__nav-item">
            <NavLink class="nav-link" href="services">
                <RadzenIcon Icon="build" class="cm-sidebar__nav-icon" />
                <span class="cm-sidebar__nav-label">@L["Nav.Services"]</span>
            </NavLink>
        </li>
        <li class="cm-sidebar__nav-item">
            <NavLink class="nav-link" href="rate-limits">
                <RadzenIcon Icon="speed" class="cm-sidebar__nav-icon" />
                <span class="cm-sidebar__nav-label">@L["Nav.RateLimits"]</span>
            </NavLink>
        </li>
        <li class="cm-sidebar__nav-item">
            <NavLink class="nav-link" href="monitor">
                <RadzenIcon Icon="monitoring" class="cm-sidebar__nav-icon" />
                <span class="cm-sidebar__nav-label">@L["Nav.Monitor"]</span>
            </NavLink>
        </li>

        <li class="cm-sidebar__divider"></li>

        <li class="cm-sidebar__nav-item">
            <NavLink class="nav-link" href="resource-pools">
                <RadzenIcon Icon="hub" class="cm-sidebar__nav-icon" />
                <span class="cm-sidebar__nav-label">@L["Nav.ResourcePools"]</span>
            </NavLink>
        </li>
        <li class="cm-sidebar__nav-item">
            <NavLink class="nav-link" href="quotas">
                <RadzenIcon Icon="tune" class="cm-sidebar__nav-icon" />
                <span class="cm-sidebar__nav-label">@L["Nav.Quotas"]</span>
            </NavLink>
        </li>
        <li class="cm-sidebar__nav-item">
            <NavLink class="nav-link" href="allocations">
                <RadzenIcon Icon="swap_horiz" class="cm-sidebar__nav-icon" />
                <span class="cm-sidebar__nav-label">@L["Nav.ActiveAllocations"]</span>
            </NavLink>
        </li>
    </ul>

    <div class="cm-sidebar__footer">
        <div class="cm-sidebar__nav-item">
            <NavLink class="nav-link" href="settings">
                <RadzenIcon Icon="settings" class="cm-sidebar__nav-icon" />
                <span class="cm-sidebar__nav-label">@L["Nav.Settings"]</span>
            </NavLink>
        </div>
    </div>
</aside>
