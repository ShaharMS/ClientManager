@inject UserPreferencesService PreferencesService

<div class="cm-polling-interval-dropdown">
    <button class="cm-polling-interval-dropdown__trigger" @onclick="ToggleDropdown" @onclick:stopPropagation="true">
        <span class="cm-polling-interval-dropdown__icon material-icons">update</span>
        <span class="cm-polling-interval-dropdown__label">@_selectedLabel</span>
    </button>
    @if (_isOpen)
    {
        <div class="cm-polling-interval-dropdown__overlay" @onclick="CloseDropdown"></div>
        <div class="cm-polling-interval-dropdown__menu">
            @foreach (var preset in PollingIntervalPreset.All)
            {
                <button class="cm-polling-interval-dropdown__item @(preset.Key == _selectedKey ? "cm-polling-interval-dropdown__item--active" : "")"
                        @onclick="() => SelectPreset(preset)" @onclick:stopPropagation="true">
                    @preset.Label
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<PollingIntervalPreset> OnIntervalChanged { get; set; }

    private string _selectedKey = "10s";
    private string _selectedLabel = "10 seconds";
    private bool _initialized;
    private bool _isOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;

            var defaultPreset = await PreferencesService.GetDefaultPollingIntervalAsync();
            _selectedKey = defaultPreset.Key;
            _selectedLabel = defaultPreset.Label;
            await OnIntervalChanged.InvokeAsync(defaultPreset);
            StateHasChanged();
        }
    }

    private void ToggleDropdown() => _isOpen = !_isOpen;

    private void CloseDropdown() => _isOpen = false;

    private async Task SelectPreset(PollingIntervalPreset preset)
    {
        _selectedKey = preset.Key;
        _selectedLabel = preset.Label;
        _isOpen = false;
        await OnIntervalChanged.InvokeAsync(preset);
    }
}
