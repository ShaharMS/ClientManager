{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Elasticsearch": {
      "Uri": "http://localhost:9200"
    }
  },
  "AllowedHosts": "*",
  "ApiVersioning": {
    "DefaultVersion": "1.0"
  },
  "Persistence": {
    "Provider": "JsonFile",
    "JsonFileDataDirectory": "./data",
    "MongoDbConnectionString": null,
    "MongoDbDatabaseName": "ClientManager",
    "RedisConnectionString": null
  },
  "Seed": {
    "ClientConfigurations": [],
    "Services": [],
    "ResourcePools": [],
    "GlobalRateLimits": []
  },
  "UsageTracking": {
    "FlushInterval": "00:05:00",
    "SecondRetention": "00:03:00",
    "FiveMinuteRetention": "1.00:00:00",
    "HourlyRetention": "7.00:00:00",
    "DailyRetention": "90.00:00:00"
  }
}
