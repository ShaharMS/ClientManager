{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "WindowAlignmentAnchor": "00:00:00"
  },
  "Seed": {
    "SeedApiEnabled": false
  },
  "StorageReadCache": {
    "CatalogTtl": "00:00:30",
    "HotPathCatalogTtl": "00:00:01",
    "HotPathClientServiceTtl": "00:00:05"
  },
  "Rpm": {
    "BucketSizeSeconds": 1,
    "Retention": "00:10:00",
    "FlushEventCount": 100,
    "FlushInterval": "00:00:01"
  },
  "Persistence": {
    "DefaultProvider": "Redis",
    "DefaultRedis": {
      "Host": "localhost",
      "Port": 6379,
      "DatabaseIndex": 0
    }
  }
}
