{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Elasticsearch": {
      "Uri": "http://localhost:9200"
    }
  },
  "AllowedHosts": "*",
  "ApiVersioning": {
    "DefaultVersion": "1.0"
  },
  "StorageApi": {
    "BaseUrl": "http://localhost:5063",
    "Timeout": "00:00:05",
    "ReadRetryCount": 2,
    "InitialRetryDelay": "00:00:00.200",
    "FailureThreshold": 3,
    "CircuitBreakDuration": "00:00:15"
  }
}
