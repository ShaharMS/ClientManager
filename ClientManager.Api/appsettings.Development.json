{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Observability": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Seed": {
    "SeedApiEnabled": true
  },
  "StorageReadCache": {
    "CatalogTtl": "00:00:30",
    "HotPathCatalogTtl": "00:00:01"
  },
  "Persistence": {
    "DefaultProvider": "Redis",
    "DefaultRedis": {
      "Host": "localhost",
      "Port": 6379,
      "DatabaseIndex": 0
    }
  }
}
