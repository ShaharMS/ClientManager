{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Persistence": {
    "DefaultProvider": "Lucene",
    "DefaultLucene": {
      "IndexDirectory": "./lucene-index"
    },
    "DefaultJsonFile": {
      "DataDirectory": "./data"
    }
  },
  "UsageTracking": {
    "FlushInterval": "00:00:15"
  }
}
