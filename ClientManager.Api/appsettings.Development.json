{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Observability": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "DangerZone": {
    "EnableStartupSeeding": true,
    "EnableSeedExport": true,
    "EnableSeedImport": true,
    "EnableUsagePruning": true,
    "StorageReadCache": {
      "CatalogTtl": "00:00:30",
      "HotPathCatalogTtl": "00:00:01",
      "StatisticsTtl": "00:00:05"
    }
  }
}
