{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Persistence": {
    "DefaultProvider": "Lucene",
    "DefaultLucene": {
      "IndexDirectory": "./lucene-index"
    },
    "DefaultJsonFile": {
      "DataDirectory": "./data"
    }
  },
  "StorageReadCache": {
    "CatalogTtl": "00:00:30",
    "StatisticsTtl": "00:00:05"
  },
  "UsageTracking": {
    "FlushInterval": "00:00:15"
  },
  "Observability": {
    "OtlpEndpoint": "http://localhost:4317"
  }
}